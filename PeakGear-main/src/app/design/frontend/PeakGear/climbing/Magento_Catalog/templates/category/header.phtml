<?php
/**
 * PeakGear Climbing Theme - Category Header
 *
 * @var \Magento\Catalog\Block\Category\View $block
 */
$category = $block->getCurrentCategory();
$imageUrl = $category->getImageUrl();
?>

<div class="category-page-header">
    <?php if ($imageUrl): ?>
        <div class="category-page-banner">
            <img src="<?= $block->escapeUrl($imageUrl) ?>"
                 alt="<?= $block->escapeHtmlAttr($category->getName()) ?>"
                 class="category-page-banner-image"/>
            <div class="category-page-banner-overlay"></div>
        </div>
    <?php endif; ?>

    <div class="category-page-info">
        <h1 class="category-page-title"><?= $block->escapeHtml($category->getName()) ?></h1>
        <?php if ($description = $category->getDescription()): ?>
            <div class="category-page-description">
                <?= /* @noEscape */ $description ?>
            </div>
        <?php endif; ?>
        <?php
            $productCount = $category->getProductCount();
        ?>
        <?php if ($productCount): ?>
            <p class="category-page-count">
                <?= (int)$productCount ?> sản phẩm
            </p>
        <?php endif; ?>
    </div>
</div>
