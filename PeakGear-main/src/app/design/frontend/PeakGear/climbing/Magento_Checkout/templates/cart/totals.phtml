<?php
/**
 * PeakGear Climbing Theme - Cart Totals
 *
 * @var \Magento\Checkout\Block\Cart\Totals $block
 */
$totals = $block->getTotals();

// Magento\Checkout\Block\Cart\Totals does not expose formatPrice(); use number_format() instead.
$formatVnd = static function (float $amount): string {
    $abs = number_format(abs($amount), 0, ',', '.');
    return ($amount < 0 ? '-' : '') . $abs . ' ₫';
};
?>

<div class="cart-totals-wrapper">
    <h3 class="cart-totals-title">Tổng Đơn Hàng</h3>

    <div class="cart-totals-rows">
        <?php foreach ($totals as $total): ?>
            <div class="cart-totals-row <?= $total->getCode() === 'grand_total' ? 'cart-totals-grand' : '' ?>">
                <span class="cart-totals-label"><?= $block->escapeHtml($total->getTitle()) ?></span>
                <span class="cart-totals-value"><?= /* @noEscape */ $formatVnd((float)$total->getValue()) ?></span>
            </div>
        <?php endforeach; ?>
    </div>
</div>
