<?xml version="1.0"?>
<!--
/**
 * PeakGear Catalog - Frontend Routes
 * Registers /products URL route
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="peakgear_catalog" frontName="products">
            <module name="PeakGear_Catalog"/>
        </route>
    </router>
</config>
