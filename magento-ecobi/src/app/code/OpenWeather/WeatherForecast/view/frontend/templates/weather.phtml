  $forecastList = $weather['forecast']['list'];

  $hourly = array_slice($forecastList, 0, 8);
  $daily = [];
  foreach ($forecastList as $forecast) {
    $date = date('Y-m-d', strtotime($forecast['dt_txt']));

    if (!isset($daily[$date]) && strpos($forecast['dt_txt'], '06:00:00') !== false) {
      $daily[$date] = [
        'temp_min' => $forecast['main']['temp_min'],
        'temp_max' => $forecast['main']['temp_max'],
        'weather' => $forecast['weather'][0]['description'],
        'icon' => $forecast['weather'][0]['icon']
      ];
    } elseif (isset($daily[$date])) {
      $daily[$date]['temp_min'] = min($daily[$date]['temp_min'], $forecast['main']['temp_min']);
      $daily[$date]['temp_max'] = max($daily[$date]['temp_max'], $forecast['main']['temp_max']);
    }
  }
  $daily = array_slice($daily, 0, 5);
