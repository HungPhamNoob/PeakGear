<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Cart Page Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    
    <body>
        <attribute name="class" value="checkout-cart-index"/>
        
        <!-- Cart Page Title -->
        <referenceBlock name="page.main.title">
            <arguments>
                <argument name="css_class" xsi:type="string">page-title-cart</argument>
            </arguments>
        </referenceBlock>
        
        <!-- Cart Form -->
        <referenceBlock name="checkout.cart.form">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Checkout::cart/form.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Cart Items -->
        <referenceBlock name="checkout.cart.item.renderers.default">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Checkout::cart/item/default.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Cart Totals -->
        <referenceBlock name="checkout.cart.totals">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Checkout::cart/totals.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Proceed to Checkout -->
        <referenceBlock name="checkout.cart.methods.bottom">
            <block class="Magento\Framework\View\Element\Template" 
                   name="peakgear.cart.proceed" 
                   template="Magento_Checkout::cart/proceed-checkout.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\CheckoutContext</argument>
                </arguments>
            </block>
        </referenceBlock>
        
        <!-- Cross-sell Products -->
        <referenceBlock name="checkout.cart.crosssell">
            <arguments>
                <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\ProductViewData</argument>
            </arguments>
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Checkout::cart/crosssell.phtml</argument>
            </action>
        </referenceBlock>
    </body>
</page>
