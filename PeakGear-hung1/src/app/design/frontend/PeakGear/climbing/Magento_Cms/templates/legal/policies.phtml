<!-- Tab Switching (vanilla JS, no jQuery) -->
<script>
    (function () {
        'use strict';

        var tabs   = document.querySelectorAll('.policies-tab');
        var panels = document.querySelectorAll('.policies-panel');

        if (!tabs.length || !panels.length) return;

        function activate(tabKey) {
            tabs.forEach(function (t) {
                var isTarget = t.getAttribute('data-tab') === tabKey;
                t.classList.toggle('is-active', isTarget);
                t.setAttribute('aria-selected', isTarget ? 'true' : 'false');
            });
            panels.forEach(function (p) {
                var isTarget = p.getAttribute('data-panel') === tabKey;
                p.classList.toggle('is-active', isTarget);
                if (isTarget) {
                    p.removeAttribute('hidden');
                } else {
                    p.setAttribute('hidden', '');
                }
            });
        }

        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                activate(this.getAttribute('data-tab'));
            });
        });

        // Keyboard navigation (left/right arrows between tabs)
        var tabArray = Array.prototype.slice.call(tabs);
        tabArray.forEach(function (tab, index) {
            tab.addEventListener('keydown', function (e) {
                var dir = 0;
                if (e.key === 'ArrowRight' || e.key === 'ArrowDown') dir = 1;
                if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   dir = -1;
                if (dir === 0) return;
                e.preventDefault();
                var next = (index + dir + tabArray.length) % tabArray.length;
                tabArray[next].focus();
                activate(tabArray[next].getAttribute('data-tab'));
            });
        });

        // Support direct linking via hash (e.g. #shipping)
        var hash = window.location.hash.replace('#', '');
        if (hash) {
            var match = document.querySelector('.policies-tab[data-tab="' + hash + '"]');
            if (match) activate(hash);
        }
    })();
</script>
