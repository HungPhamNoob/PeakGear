<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Login Page Layout
 * Social login buttons are now built into login.phtml directly.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    
    <body>
        <attribute name="class" value="customer-account-login"/>
        
        <!-- Login Form (includes social buttons) -->
        <referenceBlock name="customer_form_login">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Customer::form/login.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Hide the default "New Customers" block since login.phtml has its own register link -->
        <referenceBlock name="customer.new" remove="true"/>
        
        <!-- Remove the separate social login block (now built into login.phtml) -->
        <referenceBlock name="peakgear.social.login" remove="true"/>
        
        <!-- Remove default page title -->
        <referenceBlock name="page.main.title" remove="true"/>
    </body>
</page>
