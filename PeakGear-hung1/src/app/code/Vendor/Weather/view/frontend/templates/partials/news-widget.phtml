<script>
document.addEventListener('DOMContentLoaded', function () {
    var cards = document.querySelectorAll('.js-news-city-card');
    var chartWrap = document.getElementById('newsWeatherChart');
    var chartSvg = document.getElementById('newsWeatherChartSvg');
    var chartTitle = document.getElementById('newsWeatherChartTitle');
    var chartSub = document.getElementById('newsWeatherChartSub');
    var chartMeta = document.getElementById('newsWeatherChartMeta');
    var endpoint = '<?= $block->escapeJs($block->getUrl('weather/index/weekly')) ?>';
    var currentEndpoint = '<?= $block->escapeJs($block->getUrl('weather/index/data')) ?>';
    var weeklyCache = {};
    var inflight = {};
    var cacheTtlMs = 10 * 60 * 1000;
    var iconBase = 'https://openweathermap.org/img/wn/';

    var searchForm = document.getElementById('newsWeatherSearchForm');
    var searchInput = document.getElementById('newsWeatherSearchInput');
    var searchLoading = document.getElementById('newsWeatherSearchLoading');
    var searchResult = document.getElementById('newsWeatherSearchResult');
    var searchCity = document.getElementById('newsWeatherSearchCity');
    var searchIcon = document.getElementById('newsWeatherSearchIcon');
    var searchTemp = document.getElementById('newsWeatherSearchTemp');
    var searchDesc = document.getElementById('newsWeatherSearchDesc');
    var searchHumidity = document.getElementById('newsWeatherSearchHumidity');
    var searchWind = document.getElementById('newsWeatherSearchWind');

    if (!chartWrap || !chartSvg || !chartTitle || !chartMeta || !chartSub) {
        return;
    }

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatShortDate(dateText) {
        var date = new Date(dateText);
        if (Number.isNaN(date.getTime())) {
            return dateText;
        }
        var day = String(date.getDate()).padStart(2, '0');
        var month = String(date.getMonth() + 1).padStart(2, '0');
        return day + '/' + month;
    }

    function drawChart(days) {
        var width = 760;
        var height = 290;
        var left = 54;
        var right = 24;
        var top = 24;
        var bottom = 58;
        var innerW = width - left - right;
        var innerH = height - top - bottom;
        var step = days.length > 1 ? innerW / (days.length - 1) : innerW;

        var minTemp = Math.min.apply(null, days.map(function (item) { return Number(item.min); }));
        var maxTemp = Math.max.apply(null, days.map(function (item) { return Number(item.max); }));
        minTemp = Math.floor(minTemp - 2);
        maxTemp = Math.ceil(maxTemp + 2);
        if (maxTemp === minTemp) {
            maxTemp += 1;
        }

        function yFromTemp(temp) {
            var ratio = (Number(temp) - minTemp) / (maxTemp - minTemp);
            return top + innerH - (ratio * innerH);
        }

        var points = days.map(function (item, index) {
            var x = left + (step * index);
            return {
                x: x,
                y: yFromTemp(item.avg),
                date: formatShortDate(item.date),
                avg: Number(item.avg).toFixed(1),
                min: Number(item.min).toFixed(1),
                max: Number(item.max).toFixed(1),
                precipitation: Number(item.precipitation).toFixed(1)
            };
        });

        var line = points.map(function (p) { return p.x + ',' + p.y; }).join(' ');

        var horizontalGrid = '';
        var gridCount = 4;
        for (var i = 0; i <= gridCount; i++) {
            var gy = top + ((innerH / gridCount) * i);
            var labelTemp = (maxTemp - ((maxTemp - minTemp) / gridCount) * i).toFixed(0);
            horizontalGrid += '<line x1="' + left + '" y1="' + gy + '" x2="' + (width - right) + '" y2="' + gy + '" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>';
            horizontalGrid += '<text x="' + (left - 8) + '" y="' + (gy + 4) + '" text-anchor="end" fill="rgba(255,255,255,0.65)" font-size="11">' + labelTemp + '°</text>';
        }

        var dots = points.map(function (p) {
            return '<g>' +
                '<circle cx="' + p.x + '" cy="' + p.y + '" r="4.5" fill="#facc15"/>' +
                '<text x="' + p.x + '" y="' + (p.y - 10) + '" text-anchor="middle" fill="#fef3c7" font-size="11">' + p.avg + '°</text>' +
                '<text x="' + p.x + '" y="' + (height - 24) + '" text-anchor="middle" fill="rgba(255,255,255,0.72)" font-size="11">' + p.date + '</text>' +
                '</g>';
        }).join('');

        chartSvg.innerHTML =
            '<rect x="0" y="0" width="' + width + '" height="' + height + '" fill="transparent"></rect>' +
            horizontalGrid +
            '<polyline points="' + line + '" fill="none" stroke="#facc15" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"></polyline>' +
            dots;
    }

    function drawMeta(days) {
        chartMeta.innerHTML = days.map(function (item) {
            return '<div class="news-weather-day">' +
                '<div class="news-weather-day-top">' +
                    '<strong>' + escapeHtml(formatShortDate(item.date)) + '</strong>' +
                    '<span class="news-weather-day-label">' + escapeHtml(item.label || 'Dự báo') + '</span>' +
                '</div>' +
                '<div class="news-weather-day-row">' +
                    '<span>Nhiệt độ</span>' +
                    '<span class="news-weather-day-value">' + escapeHtml(Number(item.min).toFixed(1) + '°C - ' + Number(item.max).toFixed(1) + '°C') + '</span>' +
                '</div>' +
                '<div class="news-weather-day-row">' +
                    '<span>Lượng mưa</span>' +
                    '<span class="news-weather-day-value">' + escapeHtml(Number(item.precipitation).toFixed(1) + ' mm') + '</span>' +
                '</div>' +
            '</div>';
        }).join('');
    }

    function setActiveCard(city) {
        cards.forEach(function (card) {
            var active = card.getAttribute('data-city') === city;
            if (active) {
                card.classList.add('is-active');
            } else {
                card.classList.remove('is-active');
            }
        });
    }

    function getCached(city) {
        var cached = weeklyCache[city];
        if (!cached) {
            return null;
        }
        if (Date.now() - cached.timestamp > cacheTtlMs) {
            return null;
        }
        return cached;
    }

    function renderWeekly(city, days, source, timestamp) {
        chartWrap.hidden = false;
        chartTitle.textContent = 'Biểu đồ thời tiết 7 ngày - ' + city;
        drawChart(days);
        drawMeta(days);

        var sourceLabel = source === 'open-meteo' ? 'Open-Meteo' : 'PeakGear fallback';
        var timeLabel = '';
        if (timestamp) {
            timeLabel = new Date(timestamp).toLocaleTimeString('vi-VN', {
                hour: '2-digit',
                minute: '2-digit'
            });
        }
        chartSub.textContent = 'Nguồn: ' + sourceLabel + (timeLabel ? ' • Cập nhật ' + timeLabel : '');
    }

    function requestWeekly(city, silent) {
        var cached = getCached(city);
        if (cached) {
            if (!silent) {
                setActiveCard(city);
                renderWeekly(city, cached.days, cached.source, cached.timestamp);
            }
            return Promise.resolve(cached);
        }

        if (inflight[city]) {
            return inflight[city];
        }

        if (!silent) {
            chartWrap.hidden = false;
            chartTitle.textContent = 'Biểu đồ thời tiết 7 ngày - ' + city;
            chartSub.textContent = 'Đang tải dữ liệu dự báo...';
            chartSvg.innerHTML = '';
            chartMeta.innerHTML = '';
            setActiveCard(city);
        }

        inflight[city] = window.fetch(endpoint + '?city=' + encodeURIComponent(city), {
            credentials: 'same-origin',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        }).then(function (response) {
            if (!response.ok) {
                throw new Error('Load weekly weather failed');
            }
            return response.json();
        }).then(function (payload) {
            if (!payload || !payload.success || !Array.isArray(payload.days) || !payload.days.length) {
                throw new Error('No weekly payload');
            }
            weeklyCache[city] = {
                timestamp: Date.now(),
                days: payload.days,
                source: payload.source
            };
            if (!silent) {
                renderWeekly(city, payload.days, payload.source, weeklyCache[city].timestamp);
            }
            return weeklyCache[city];
        }).catch(function () {
            if (!silent) {
                chartSub.textContent = 'Không thể tải biểu đồ dự báo cho thành phố này.';
            }
            return null;
        }).finally(function () {
            delete inflight[city];
        });
        return inflight[city];
    }

    function loadWeekly(city) {
        requestWeekly(city, false);
    }

    function renderSearchWeather(weather) {
        if (!searchResult || !searchCity || !searchIcon || !searchTemp || !searchDesc || !searchHumidity || !searchWind) {
            return;
        }
        if (!weather || typeof weather !== 'object') {
            searchResult.hidden = true;
            return;
        }
        var tempVal = Number(weather.temperature);
        searchCity.textContent = weather.city_name || 'Không rõ thành phố';
        searchTemp.textContent = Number.isFinite(tempVal)
            ? tempVal.toFixed(1).replace(/\.0$/, '') + '°C'
            : 'Đang cập nhật';
        searchDesc.textContent = weather.description || 'Không có mô tả';
        searchHumidity.textContent = 'Độ ẩm: ' + Number(weather.humidity || 0) + '%';
        searchWind.textContent = 'Gió: ' + Number(weather.wind_speed || 0).toFixed(1) + ' m/s';
        if (weather.icon_code) {
            searchIcon.src = iconBase + weather.icon_code + '@2x.png';
            searchIcon.alt = weather.description || '';
        } else {
            searchIcon.src = '';
            searchIcon.alt = '';
        }
        searchResult.hidden = false;
    }

    function requestCurrentWeather(city) {
        return window.fetch(currentEndpoint + '?city=' + encodeURIComponent(city), {
            credentials: 'same-origin',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        }).then(function (response) {
            if (!response.ok) {
                throw new Error('Load current weather failed');
            }
            return response.json();
        }).then(function (payload) {
            if (!payload || !payload.success || !payload.city) {
                throw new Error('No current weather');
            }
            renderSearchWeather(payload.city);
            return payload.city;
        }).catch(function () {
            renderSearchWeather(null);
            return null;
        });
    }

    cards.forEach(function (card) {
        card.addEventListener('click', function () {
            loadWeekly(card.getAttribute('data-city') || '');
        });

        card.addEventListener('keydown', function (event) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                loadWeekly(card.getAttribute('data-city') || '');
            }
        });
    });

    // City search functionality
    if (searchForm && searchInput) {
        function showSearchLoading(show) {
            if (searchLoading) {
                searchLoading.hidden = !show;
            }
        }

        function handleCitySearch(city) {
            if (!city || !city.trim()) {
                return;
            }
            city = city.trim();
            showSearchLoading(true);
            searchInput.disabled = true;

            // Clear active state from existing cards since this is a searched city
            setActiveCard(city);

            Promise.all([
                requestCurrentWeather(city),
                requestWeekly(city, false)
            ]).then(function () {
                showSearchLoading(false);
                searchInput.disabled = false;

                if (searchResult && !searchResult.hidden) {
                    searchResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                } else if (chartWrap && !chartWrap.hidden) {
                    chartWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            }).catch(function () {
                showSearchLoading(false);
                searchInput.disabled = false;
            });
        }

        searchForm.addEventListener('submit', function (event) {
            event.preventDefault();
            handleCitySearch(searchInput.value);
        });

        // Also trigger search when user selects from datalist
        searchInput.addEventListener('change', function () {
            var val = searchInput.value.trim();
            if (val) {
                handleCitySearch(val);
            }
        });
    }

    var prefetchCards = Array.prototype.slice.call(cards, 0, 3);
    if (prefetchCards.length) {
        var prefetch = function () {
            prefetchCards.forEach(function (card, index) {
                var city = card.getAttribute('data-city') || '';
                if (!city) {
                    return;
                }
                window.setTimeout(function () {
                    requestWeekly(city, true);
                }, 400 + (index * 200));
            });
        };

        if ('requestIdleCallback' in window) {
            window.requestIdleCallback(prefetch);
        } else {
            window.setTimeout(prefetch, 800);
        }
    }
});
</script>
