# ===========================================
# PeakGear - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
# ===========================================

# --- Magento ---
MAGENTO_VERSION=2.4.7
COMPOSER_VERSION=2.7.0

# Magento Marketplace keys (REQUIRED)
# Get from: marketplace.magento.com > My Profile > Access Keys
MAGENTO_PUBLIC_KEY=your_public_key_here
MAGENTO_PRIVATE_KEY=your_private_key_here

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=magento
MYSQL_USER=magento
MYSQL_PASSWORD=magento

# --- OpenSearch ---
OPENSEARCH_PASSWORD=Admin@123456

# --- Redis ---
REDIS_PASSWORD=

# --- Magento Storefront ---
# Change to your domain for production (e.g., peakgear.com)
MAGENTO_HOST=localhost

# --- Magento Admin ---
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=admin123
MAGENTO_ADMIN_EMAIL=admin@example.com
MAGENTO_ADMIN_FIRSTNAME=Admin
MAGENTO_ADMIN_LASTNAME=Admin
