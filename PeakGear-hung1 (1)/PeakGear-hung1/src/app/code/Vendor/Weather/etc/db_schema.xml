<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="vendor_weather_cache" resource="default" engine="innodb" comment="Vendor Weather Cache Table">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="city_key" nullable="false" length="100" comment="City Key"/>
        <column xsi:type="varchar" name="city_name" nullable="false" length="255" comment="City Display Name"/>
        <column xsi:type="decimal" name="temperature" nullable="true" precision="5" scale="2" comment="Temperature"/>
        <column xsi:type="decimal" name="feels_like" nullable="true" precision="5" scale="2" comment="Feels Like"/>
        <column xsi:type="int" name="humidity" nullable="true" comment="Humidity"/>
        <column xsi:type="varchar" name="description" nullable="true" length="255" comment="Weather Description"/>
        <column xsi:type="varchar" name="icon_code" nullable="true" length="20" comment="Icon Code"/>
        <column xsi:type="decimal" name="wind_speed" nullable="true" precision="5" scale="2" comment="Wind Speed"/>
        <column xsi:type="mediumtext" name="weather_data" nullable="true" comment="Legacy Weather Data"/>
        <column xsi:type="timestamp" name="cached_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Cache Timestamp"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="VENDOR_WEATHER_CACHE_CITY_KEY">
            <column name="city_key"/>
        </constraint>
        <index referenceId="VENDOR_WEATHER_CACHE_CACHED_AT" indexType="btree">
            <column name="cached_at"/>
        </index>
    </table>
</schema>
