<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Terms of Use Page Layout
 *
 * CMS Page layout handle: set URL key "dieu-khoan-su-dung".
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <head>
        <title>Điều khoản sử dụng - PeakGear</title>
        <meta name="description" content="Điều khoản sử dụng dịch vụ và website PeakGear."/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="legal.terms"
                   template="Magento_Cms::legal/terms.phtml"
                   before="-"/>
        </referenceContainer>
        <referenceBlock name="cms_page" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>
    </body>
</page>
