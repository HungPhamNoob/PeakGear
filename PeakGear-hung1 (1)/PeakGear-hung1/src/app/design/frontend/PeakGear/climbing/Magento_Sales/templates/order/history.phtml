 */
$_orders = $block->getOrders();
?>

<div class="main-content">
    <section class="edit-hero">
        <div class="edit-hero-content">
            <h1>Đơn hàng của tôi</h1>
        </div>
    </section>

    <div class="edit-container">
        <div class="edit-form-card">
            <h2 class="form-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:1.25rem;height:1.25rem;margin-right:.5rem;color:#f5a623;">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                    <line x1="9" y1="12" x2="15" y2="12"/>
                    <line x1="9" y1="16" x2="12" y2="16"/>
                </svg>
                Lịch sử đơn hàng
            </h2>

            <?= $block->getChildHtml('info') ?>

            <?php if ($_orders && count($_orders)): ?>
                <div class="pg-table-scroll">
                    <table class="pg-table" id="my-orders-table">
                        <thead>
                            <tr>
                                <th><?= $block->escapeHtml(__('Mã đơn')) ?></th>
                                <th><?= $block->escapeHtml(__('Ngày đặt')) ?></th>
                                <?= $block->getChildHtml('extra.column.header') ?>
                                <th><?= $block->escapeHtml(__('Tổng tiền')) ?></th>
                                <th><?= $block->escapeHtml(__('Trạng thái')) ?></th>
                                <th><?= $block->escapeHtml(__('Thao tác')) ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($_orders as $_order):
                                $status = strtolower($_order->getStatus());
                            ?>
                            <tr>
                                <td class="pg-table__id">#<?= $block->escapeHtml($_order->getRealOrderId()) ?></td>
                                <td class="pg-table__muted"><?= /* @noEscape */ $block->formatDate($_order->getCreatedAt()) ?></td>
                                <?php $extra = $block->getChildBlock('extra.container'); ?>
                                <?php if ($extra): $extra->setOrder($_order); echo $extra->getChildHtml(); endif; ?>
                                <td class="pg-table__price"><?= /* @noEscape */ $_order->formatPrice($_order->getGrandTotal()) ?></td>
                                <td>
                                    <span class="pg-badge pg-badge--<?= $block->escapeHtmlAttr($status) ?>">
                                        <?= $block->escapeHtml($_order->getStatusLabel()) ?>
                                    </span>
                                </td>
                                <td class="pg-table__actions">
                                    <a href="<?= $block->escapeUrl($block->getViewUrl($_order)) ?>" class="pg-action-btn">
                                        Xem
                                    </a>
                                    <?php
                                    try {
                                        if ($this->helper(\Magento\Sales\Helper\Reorder::class)->canReorder($_order->getEntityId())):
                                    ?>
                                        <a href="#" data-post='<?= /* @noEscape */ $this->helper(\Magento\Framework\Data\Helper\PostHelper::class)->getPostData($block->getReorderUrl($_order)) ?>' class="pg-action-btn pg-action-btn--ghost">
                                            Đặt lại
                                        </a>
                                    <?php endif; } catch (\Exception $e) {} ?>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

                <?php if ($block->getPagerHtml()): ?>
                    <div class="pg-pager-wrap"><?= $block->getPagerHtml() ?></div>
                <?php endif; ?>

            <?php else: ?>
                <div class="pg-empty-notice">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                    <span>Bạn chưa có đơn hàng nào.</span>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
