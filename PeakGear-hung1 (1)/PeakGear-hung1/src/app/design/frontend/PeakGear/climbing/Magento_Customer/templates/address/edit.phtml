<style>
/* ============================================================
   PeakGear Combobox / Autocomplete
   ============================================================ */
.pg-combo {
    position: relative;
    width: 100%;
}

.pg-combo__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.pg-combo__input {
    width: 100%;
    height: 48px;
    padding: 0 2.75rem 0 1rem;        /* right room for icon */
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 0.5rem;
    color: #fff;
    font-size: 0.9375rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    box-sizing: border-box;
    caret-color: #f5a623;
}

.pg-combo__input::placeholder { color: rgba(255,255,255,0.35); }

.pg-combo__input:hover {
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.07);
}

.pg-combo__input:focus {
    border-color: #f5a623;
    background: rgba(255,255,255,0.07);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.15);
}

.pg-combo.is-open .pg-combo__input {
    border-color: #f5a623;
    background: rgba(255,255,255,0.07);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.15);
    border-radius: 0.5rem 0.5rem 0 0;
}

.pg-combo__icon {
    position: absolute;
    right: 0.75rem;
    display: flex;
    align-items: center;
    color: rgba(255,255,255,0.4);
    pointer-events: none;
}

.pg-combo__icon svg { width: 1rem; height: 1rem; }

.pg-combo.is-open .pg-combo__arrow svg {
    transform: rotate(180deg);
    transition: transform 0.2s;
}
.pg-combo__arrow svg { transition: transform 0.2s; }

/* Loading spinner */
.pg-spinner {
    display: inline-block;
    width: 1rem; height: 1rem;
    border: 2px solid rgba(245,166,35,0.3);
    border-top-color: #f5a623;
    border-radius: 50%;
    animation: pgSpin 0.7s linear infinite;
}
@keyframes pgSpin { to { transform: rotate(360deg); } }

/* Dropdown list */
.pg-combo__list {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 9999;
    list-style: none;
    margin: 0;
    padding: 0.375rem 0;
    background: #1a1e2e;
    border: 1px solid rgba(245,166,35,0.4);
    border-top: none;
    border-radius: 0 0 0.5rem 0.5rem;
    box-shadow: 0 12px 32px rgba(0,0,0,0.5);
    max-height: 220px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(245,166,35,0.4) transparent;
    animation: pgDropIn 0.15s ease;
}
@keyframes pgDropIn {
    from { opacity:0; transform:translateY(-6px); }
    to   { opacity:1; transform:translateY(0); }
}
.pg-combo__list::-webkit-scrollbar { width: 4px; }
.pg-combo__list::-webkit-scrollbar-thumb { background: rgba(245,166,35,0.45); border-radius: 4px; }

.pg-combo__list li {
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.82);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
}
.pg-combo__list li:hover,
.pg-combo__list li.is-focused {
    background: rgba(245,166,35,0.13);
    color: #f5a623;
}
.pg-combo__list li.is-selected {
    background: rgba(245,166,35,0.2);
    color: #f5a623;
    font-weight: 600;
}
.pg-combo__list li.pg-no-result {
    color: rgba(255,255,255,0.3);
    font-style: italic;
    pointer-events: none;
    text-align: center;
    padding: 1rem;
}

/* Disabled state */
.pg-combo.is-disabled .pg-combo__input {
    opacity: 0.45;
    cursor: not-allowed;
}
</style>

<script>
(function () {
    'use strict';

    var API_BASE          = 'https://provinces.open-api.vn/api';
    var defaultRegionName = "<?= $escaper->escapeJs($block->getRegion()) ?>";
    var defaultCity       = "<?= $escaper->escapeJs($block->getAddress()->getCity()) ?>";

    var allProvinces      = [];   // [{code, name}]
    var currentDistricts  = [];   // [{code, name}]

    /* ---- tiny combobox factory ---- */
    function Combo(cfg) {
        /* cfg: { wrap, input, list, arrow, spin?,
                  getItems, onPick, placeholder } */
        var wrap  = document.getElementById(cfg.wrap);
        var inp   = document.getElementById(cfg.input);
        var list  = document.getElementById(cfg.list);
        var arrow = document.getElementById(cfg.arrow);
        var spin  = cfg.spin ? document.getElementById(cfg.spin) : null;

        var shown = false;
        var focusIdx = -1;

        function showList(items) {
            list.innerHTML = '';
            if (!items || !items.length) {
                var li = document.createElement('li');
                li.className = 'pg-no-result';
                li.textContent = items === null ? 'Đang tải...' : 'Không tìm thấy kết quả';
                list.appendChild(li);
            } else {
                items.forEach(function (item, i) {
                    var li = document.createElement('li');
                    li.textContent = item.name;
                    li.addEventListener('mousedown', function (e) {
                        e.preventDefault();
                        pickItem(item);
                    });
                    list.appendChild(li);
                });
            }
            list.style.display = 'block';
            wrap.classList.add('is-open');
            shown = true;
            focusIdx = -1;
        }

        function hideList() {
            list.style.display = 'none';
            wrap.classList.remove('is-open');
            shown = false;
            focusIdx = -1;
        }

        function pickItem(item) {
            inp.value = item.name;
            hideList();
            if (cfg.onPick) cfg.onPick(item);
        }

        function filter(q) {
            var items = cfg.getItems();
            if (!q) return items;
            var lq = q.toLowerCase();
            return items.filter(function (it) { return it.name.toLowerCase().includes(lq); });
        }

        /* keyboard navigation */
        inp.addEventListener('keydown', function (e) {
            var lis = list.querySelectorAll('li:not(.pg-no-result)');
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                focusIdx = Math.min(focusIdx + 1, lis.length - 1);
                highlightLi(lis);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                focusIdx = Math.max(focusIdx - 1, 0);
                highlightLi(lis);
            } else if (e.key === 'Enter') {
                if (focusIdx >= 0 && lis[focusIdx]) {
                    e.preventDefault();
                    lis[focusIdx].dispatchEvent(new MouseEvent('mousedown'));
                }
            } else if (e.key === 'Escape') {
                hideList();
            }
        });

        function highlightLi(lis) {
            Array.prototype.forEach.call(lis, function (li, i) {
                li.classList.toggle('is-focused', i === focusIdx);
            });
            if (lis[focusIdx]) lis[focusIdx].scrollIntoView({ block: 'nearest' });
        }

        inp.addEventListener('input', function () {
            showList(filter(this.value));
        });
        inp.addEventListener('focus', function () {
            showList(filter(this.value));
        });
        inp.addEventListener('blur', function () {
            // small delay so mousedown on list fires first
            setTimeout(hideList, 150);
        });

        /* PUBLIC */
        function enable(placeholder) {
            wrap.classList.remove('is-disabled');
            inp.disabled = false;
            inp.placeholder = placeholder || cfg.placeholder;
        }
        function disable(placeholder) {
            wrap.classList.add('is-disabled');
            inp.disabled = true;
            inp.value = '';
            inp.placeholder = placeholder || cfg.placeholder;
            hideList();
        }
        function setVal(name) {
            inp.value = name || '';
        }
        function setLoading(show) {
            if (!spin) return;
            spin.style.display = show ? 'flex' : 'none';
            if (arrow) arrow.style.display = show ? 'none' : 'flex';
        }

        return { enable: enable, disable: disable, setVal: setVal, setLoading: setLoading };
    }

    /* ---- init ---- */
    var provCombo = Combo({
        wrap: 'pg-province-wrap', input: 'pg-province-input',
        list: 'pg-province-list', arrow: 'pg-province-arrow',
        spin: 'pg-province-spin',
        placeholder: 'Gõ hoặc chọn Tỉnh / Thành phố',
        getItems: function () { return allProvinces; },
        onPick: function (prov) {
            document.getElementById('region_id').value = prov.code;
            document.getElementById('region').value   = prov.name;
            document.getElementById('city').value     = '';
            distCombo.disable('Đang tải...');
            distCombo.setLoading(false);
            currentDistricts = [];
            loadDistricts(prov);
        }
    });

    var distCombo = Combo({
        wrap: 'pg-district-wrap', input: 'pg-district-input',
        list: 'pg-district-list', arrow: 'pg-district-arrow',
        placeholder: 'Gõ hoặc chọn Quận / Huyện',
        getItems: function () { return currentDistricts; },
        onPick: function (dist) {
            document.getElementById('city').value = dist.name;
        }
    });

    /* ---- Load districts for a province ---- */
    function loadDistricts(prov) {
        fetch(API_BASE + '/p/' + prov.code + '?depth=2')
            .then(function (r) { return r.json(); })
            .then(function (data) {
                currentDistricts = (data.districts || []).map(function (d) {
                    return { code: d.code, name: d.name };
                });
                distCombo.enable('Gõ hoặc chọn Quận / Huyện');

                if (defaultCity) {
                    var saved = currentDistricts.find(function (d) {
                        return d.name.toLowerCase() === defaultCity.toLowerCase();
                    });
                    if (saved) {
                        distCombo.setVal(saved.name);
                        document.getElementById('city').value = saved.name;
                    }
                    defaultCity = null;
                }
            })
            .catch(function () { distCombo.enable('Lỗi tải dữ liệu'); });
    }

    /* ---- Load all provinces on page load ---- */
    provCombo.setLoading(true);
    fetch(API_BASE + '/?depth=1')
        .then(function (r) { return r.json(); })
        .then(function (data) {
            allProvinces = data.map(function (p) { return { code: p.code, name: p.name }; });
            provCombo.setLoading(false);

            if (defaultRegionName) {
                var saved = allProvinces.find(function (p) {
                    return p.name.toLowerCase() === defaultRegionName.toLowerCase();
                });
                if (saved) {
                    provCombo.setVal(saved.name);
                    document.getElementById('region_id').value = saved.code;
                    document.getElementById('region').value   = saved.name;
                    distCombo.disable('Đang tải...');
                    loadDistricts(saved);
                }
            }
        })
        .catch(function () {
            provCombo.setLoading(false);
            document.getElementById('pg-province-input').placeholder = 'Lỗi tải dữ liệu';
        });

})();
</script>
