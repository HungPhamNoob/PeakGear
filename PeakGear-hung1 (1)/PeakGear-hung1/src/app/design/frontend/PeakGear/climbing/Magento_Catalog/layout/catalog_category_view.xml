<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Category Page Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    
    <body>
        <attribute name="class" value="page-products"/>
        
        <!-- Sidebar Filters -->
        <referenceContainer name="sidebar.main">
            <block class="Magento\Framework\View\Element\Template" 
                   name="peakgear.sidebar.filters" 
                   template="Magento_Catalog::category/sidebar-filters.phtml"
                   before="-"/>
        </referenceContainer>
        
        <!-- Category Header -->
        <referenceContainer name="category.view.container">
            <block class="Magento\Catalog\Block\Category\View" 
                   name="peakgear.category.header" 
                   template="Magento_Catalog::category/header.phtml"
                   before="-"/>
        </referenceContainer>
        
        <!-- Product List -->
        <referenceBlock name="category.products.list">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/list.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Toolbar -->
        <referenceBlock name="product_list_toolbar">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/list/toolbar.phtml</argument>
            </action>
        </referenceBlock>
        
        <!-- Layered Navigation -->
        <referenceBlock name="catalog.leftnav">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_LayeredNavigation::layer/view.phtml</argument>
            </action>
        </referenceBlock>
    </body>
</page>
