<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - View Configuration
 */
-->
<view xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:Config/etc/view.xsd">
    <media>
        <images module="Magento_Catalog">
            <!-- Small Product Image (Cart, Wishlist) -->
            <image id="cart_page_product_thumbnail" type="small_image">
                <width>165</width>
                <height>165</height>
            </image>
            
            <!-- Category Grid Image -->
            <image id="category_page_grid" type="small_image">
                <width>320</width>
                <height>320</height>
            </image>
            
            <!-- Category List Image -->
            <image id="category_page_list" type="small_image">
                <width>240</width>
                <height>300</height>
            </image>
            
            <!-- Product Page Main Image -->
            <image id="product_page_image_large" type="image">
                <width>700</width>
                <height>700</height>
            </image>
            
            <!-- Product Page Thumbnail -->
            <image id="product_page_image_medium" type="image">
                <width>100</width>
                <height>100</height>
            </image>
            
            <!-- Related Products -->
            <image id="related_products_list" type="small_image">
                <width>240</width>
                <height>300</height>
            </image>
            
            <!-- Upsell Products -->
            <image id="upsell_products_list" type="small_image">
                <width>240</width>
                <height>300</height>
            </image>
            
            <!-- Cross-sell Products -->
            <image id="cart_cross_sell_products" type="small_image">
                <width>200</width>
                <height>248</height>
            </image>
            
            <!-- New Products Widget -->
            <image id="new_products_content_widget_grid" type="small_image">
                <width>300</width>
                <height>375</height>
            </image>
            
            <!-- Wishlist Sidebar -->
            <image id="wishlist_sidebar_block" type="small_image">
                <width>75</width>
                <height>94</height>
            </image>
            
            <!-- Mini Cart -->
            <image id="mini_cart_product_thumbnail" type="thumbnail">
                <width>75</width>
                <height>75</height>
            </image>
        </images>
    </media>
    
    <vars module="Magento_Catalog">
        <var name="gallery_switch_strategy">replace</var>
        <var name="breakpoints">
            <var name="mobile">
                <var name="conditions">
                    <var name="max-width">767px</var>
                </var>
                <var name="options">
                    <var name="options">
                        <var name="nav">dots</var>
                    </var>
                </var>
            </var>
        </var>
    </vars>
    
    <vars module="Js_Cookie">
        <var name="expires">365</var>
        <var name="path">/</var>
    </vars>
</view>
