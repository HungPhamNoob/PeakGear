<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd" layout="1column" label="Customer My Account" design_abstraction="custom">
    <head>
        <title>Tài Khoản - PeakGear</title>
    </head>
    <body>
        <attribute name="class" value="account-page"/>
        
        <!-- Remove default Magento blocks -->
        <referenceBlock name="sidebar.main" remove="true"/>
        <referenceBlock name="sidebar.extra" remove="true"/>
        
        <!-- Add PeakGear dashboard -->
        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Account\Dashboard" name="peakgear_customer_dashboard" template="Magento_Customer::account/dashboard.phtml" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
