<script>
function toggleLoginPassword(btn) {
    var wrapper = btn.closest('.login-input-wrapper');
    var input = wrapper.querySelector('input');
    var eyeOpen = btn.querySelector('.eye-open');
    var eyeClosed = btn.querySelector('.eye-closed');
    if (input.type === 'password') {
        input.type = 'text';
        eyeOpen.style.display = 'none';
        eyeClosed.style.display = 'block';
    } else {
        input.type = 'password';
        eyeOpen.style.display = 'block';
        eyeClosed.style.display = 'none';
    }
}

require([
    'jquery',
    'mage/mage',
    'mage/storage',
    'Magento_Customer/js/customer-data',
    'mage/validation',
    'mage/translate'
], function ($, mage, storage, customerData) {
    'use strict';

    function normalizePhone(phone) {
        var trimmed = $.trim(phone);
        var digits = trimmed.replace(/\D+/g, '');

        if (trimmed.charAt(0) === '+' && digits.indexOf('84') === 0) {
            return '0' + digits.substring(2);
        }

        if (digits.indexOf('84') === 0 && digits.length >= 11) {
            return '0' + digits.substring(2);
        }

        return digits;
    }

    function isValidEmail(value) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
    }

    $.validator.addMethod(
        'validate-login-identifier',
        function (value) {
            var trimmed = $.trim(value);

            if (!trimmed.length) {
                return true;
            }

            return isValidEmail(trimmed) || /^0[0-9]{9,10}$/.test(normalizePhone(trimmed));
        },
        $.mage.__('Vui lòng nhập email hợp lệ hoặc số điện thoại hợp lệ.')
    );

    var form = $('#login-form');
    var usernameField = $('#email');
    var passwordField = $('#pass');
    var passwordErrorContainer = $('#login-password-errors');
    var submitButton = form.find('.login-submit-btn');

    function escapeHtml(text) {
        return $('<div>').text(text).html();
    }

    function setPasswordServerError(message) {
        passwordErrorContainer.html(
            '<div class="login-inline-error login-inline-error--server">' + escapeHtml(message) + '</div>'
        );
        passwordField.closest('.login-field').addClass('has-server-error');
    }

    function normalizeServerMessage(message) {
        var normalized = (message || '').toLowerCase();

        if (
            normalized.indexOf('invalid login or password') !== -1
            || normalized.indexOf('invalid login or password.') !== -1
            || normalized.indexOf('account sign-in was incorrect') !== -1
            || normalized.indexOf('login and a password are required') !== -1
        ) {
            return 'Sai tên đăng nhập hoặc mật khẩu.';
        }

        return message || 'Không thể đăng nhập. Vui lòng thử lại.';
    }

    form.mage('validation', {
        errorClass: 'mage-error',
        errorElement: 'div',
        errorPlacement: function (error, element) {
            var field = element.closest('.login-field');
            var errorContainer = field.find('.login-field-errors').first();

            if (errorContainer.length) {
                errorContainer.empty().append(error);
                return;
            }

            error.insertAfter(element);
        }
    });

    form.find('.login-input').on('input', function () {
        passwordErrorContainer.find('.login-inline-error--server').remove();
        $(this).closest('.login-field').removeClass('has-server-error');
    });

    form.on('submit', function (event) {
        var payload;

        if (!form.validation('isValid')) {
            return;
        }

        event.preventDefault();

        passwordErrorContainer.find('.login-inline-error--server').remove();
        passwordField.closest('.login-field').removeClass('has-server-error');
        submitButton.prop('disabled', true);

        payload = {
            username: $.trim(usernameField.val()),
            password: passwordField.val()
        };

        storage.post(
            'customer/ajax/login',
            JSON.stringify(payload),
            true
        ).done(function (response) {
            if (response && response.errors) {
                setPasswordServerError(normalizeServerMessage(response.message));
                return;
            }

            customerData.invalidate(['customer']);

            if (response && response.redirectUrl) {
                window.location.href = response.redirectUrl;
                return;
            }

            window.location.reload();
        }).fail(function () {
            setPasswordServerError('Không thể đăng nhập. Vui lòng thử lại.');
        }).always(function () {
            submitButton.prop('disabled', false);
        });
    });
});

</script>
