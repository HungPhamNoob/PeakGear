/**
 * PeakGear Climbing Theme - Login Form Template
 * Matches Next.js app/login/page.tsx exactly
 *
 * @var \Magento\Customer\Block\Form\Login $block
 */

$username = trim((string) $block->getUsername());
$serverErrors = [];

try {
    /** @var \Magento\Framework\Message\ManagerInterface $messageManager */
    $messageManager = \Magento\Framework\App\ObjectManager::getInstance()
        ->get(\Magento\Framework\Message\ManagerInterface::class);

    foreach ($messageManager->getMessages(true)->getItemsByType(\Magento\Framework\Message\MessageInterface::TYPE_ERROR) as $message) {
        $text = trim((string) $message->getText());
        if ($text === '') {
            continue;
        }

        if (stripos($text, 'captcha') !== false) {
            continue;
        }

        $serverErrors[] = $block->escapeHtml($text);
    }
} catch (\Throwable $e) {
    // Keep the login form usable even if message extraction fails.
}
