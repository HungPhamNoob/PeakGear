<script>
function toggleRegPassword(btn) {
    var input = btn.parentElement.querySelector('input');
    var eyeOpen = btn.querySelector('.eye-open');
    var eyeClosed = btn.querySelector('.eye-closed');
    if (input.type === 'password') {
        input.type = 'text';
        eyeOpen.style.display = 'none';
        eyeClosed.style.display = 'block';
    } else {
        input.type = 'password';
        eyeOpen.style.display = 'block';
        eyeClosed.style.display = 'none';
    }
}

function toggleTerms(btn) {
    var icon = btn.querySelector('.terms-check-icon');
    var isChecked = btn.classList.toggle('checked');
    icon.style.display = isChecked ? 'block' : 'none';
}

document.addEventListener('DOMContentLoaded', function() {
    var passwordInput = document.getElementById('password');
    var confirmInput = document.getElementById('password-confirmation');
    var strengthGrid = document.getElementById('password-strength-grid');
    var mismatchMsg = document.getElementById('password-mismatch');

    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            var val = this.value;
            strengthGrid.style.display = val.length > 0 ? 'grid' : 'none';
            toggleCheck('check-length', val.length >= 8);
            toggleCheck('check-uppercase', /[A-Z]/.test(val));
            toggleCheck('check-lowercase', /[a-z]/.test(val));
            toggleCheck('check-number', /[0-9]/.test(val));
        });
    }

    if (confirmInput && passwordInput) {
        confirmInput.addEventListener('input', function() {
            if (this.value && passwordInput.value !== this.value) {
                mismatchMsg.style.display = 'block';
            } else {
                mismatchMsg.style.display = 'none';
            }
        });
    }

    // Split full name into first/last on submit
    var form = document.getElementById('form-validate');
    var fullnameInput = document.getElementById('fullname');
    if (form && fullnameInput) {
        form.addEventListener('submit', function() {
            var fullname = fullnameInput.value.trim();
            var parts = fullname.split(/\s+/);
            if (parts.length >= 2) {
                document.getElementById('firstname').value = parts[0];
                document.getElementById('lastname').value = parts.slice(1).join(' ');
            } else {
                document.getElementById('firstname').value = fullname;
                document.getElementById('lastname').value = fullname;
            }
        });
    }
});

function toggleCheck(id, passed) {
    var el = document.getElementById(id);
    if (el) {
        if (passed) {
            el.classList.add('passed');
            el.classList.remove('not-passed');
        } else {
            el.classList.remove('passed');
            el.classList.add('not-passed');
        }
    }
}
</script>
