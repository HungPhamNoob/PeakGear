<?php
/**
 * PeakGear Climbing Theme - Account Dashboard
 *
 * @var \Magento\Customer\Block\Account\Dashboard $block
 */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$customerSession = $objectManager->get(\Magento\Customer\Model\Session::class);
$customer = $customerSession->getCustomer();
$customerName = '';
$customerEmail = '';
if ($customer && $customer->getId()) {
    $customerName = $customer->getFirstname() . ' ' . $customer->getLastname();
    $customerEmail = $customer->getEmail();
}
$initial = $customerName ? strtoupper($customerName[0]) : 'U';

$shippingAddressInfo = 'Chưa cập nhật địa chỉ';
$shippingPhoneInfo = 'Chưa cập nhật số điện thoại';
if ($customer && $customer->getId()) {
    $primaryShipping = $customer->getPrimaryShippingAddress();
    if ($primaryShipping) {
        $street = $primaryShipping->getStreet();
        $streetStr = is_array($street) ? implode(', ', $street) : (string)$street;
        $city = $primaryShipping->getCity();
        
        $fullAddress = [];
        if ($streetStr) $fullAddress[] = $streetStr;
        if ($city) $fullAddress[] = $city;
        
        if (!empty($fullAddress)) {
            $shippingAddressInfo = implode(', ', $fullAddress);
        }
        $telephone = $primaryShipping->getTelephone();
        if ($telephone) {
            $shippingPhoneInfo = $telephone;
        }
    }
}
?>

