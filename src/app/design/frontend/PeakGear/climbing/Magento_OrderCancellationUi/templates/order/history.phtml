<?php
/**
 * PeakGear Climbing Theme – Order History With Cancellation
 *
 * @var \Magento\Sales\Block\Order\History $block
 * @var \Magento\OrderCancellationUi\ViewModel\Config $viewModel
 */
// phpcs:disable Magento2.Templates.ThisInTemplate
$viewModel = $block->getViewModel();
$_orders = $block->getOrders();
$reorderHelper = $this->helper(\Magento\Sales\Helper\Reorder::class);
$postHelper = $this->helper(\Magento\Framework\Data\Helper\PostHelper::class);
?>

<div class="main-content">
    <section class="edit-hero">
        <div class="edit-hero-content">
            <h1>Đơn hàng của tôi</h1>
        </div>
    </section>

    <div class="edit-container">
        <div class="edit-form-card">
            <h2 class="form-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:1.25rem;height:1.25rem;margin-right:.5rem;color:#f5a623;">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                    <line x1="9" y1="12" x2="15" y2="12"/>
                    <line x1="9" y1="16" x2="12" y2="16"/>
                </svg>
                Lịch sử đơn hàng
            </h2>

            <?= $block->getChildHtml('info') ?>

            <?php if ($_orders && count($_orders)): ?>
                <div class="pg-order-history-list" id="my-orders-table">
                    <?php foreach ($_orders as $_order): ?>
                        <?php
                        $status = strtolower(str_replace([' ', '/'], '_', (string)$_order->getStatus()));
                        $isCancellationRequested = $_order->getStatus() === 'cancellation_requested';
                        $isCancellationApproved = $_order->getStatus() === 'cancellation_approved';
                        $extra = $block->getChildBlock('extra.container');
                        $extraHtml = '';

                        if ($extra) {
                            $extra->setOrder($_order);
                            $extraHtml = trim((string)$extra->getChildHtml());
                        }
                        ?>
                        <article class="pg-order-history-card">
                            <div class="pg-order-history-card__head">
                                <div class="pg-order-history-card__identity">
                                    <p class="pg-order-history-card__eyebrow">Đơn hàng</p>
                                    <h3 class="pg-order-history-card__title">#<?= $block->escapeHtml($_order->getRealOrderId()) ?></h3>
                                </div>
                                <span class="pg-badge pg-badge--<?= $block->escapeHtmlAttr($status) ?>">
                                    <?= $block->escapeHtml($_order->getStatusLabel()) ?>
                                </span>
                            </div>

                            <div class="pg-order-history-card__meta">
                                <div class="pg-order-history-card__meta-item">
                                    <span class="pg-order-history-card__label">Ngày đặt</span>
                                    <strong><?= /* @noEscape */ $block->formatDate($_order->getCreatedAt()) ?></strong>
                                </div>
                                <div class="pg-order-history-card__meta-item">
                                    <span class="pg-order-history-card__label">Tổng tiền</span>
                                    <strong class="pg-order-history-card__price"><?= /* @noEscape */ $_order->formatPrice($_order->getGrandTotal()) ?></strong>
                                </div>
                                <?php if ($extraHtml !== ''): ?>
                                    <div class="pg-order-history-card__meta-item pg-order-history-card__meta-item--extra">
                                        <span class="pg-order-history-card__label">Thông tin thêm</span>
                                        <div class="pg-order-history-card__extra"><?= /* @noEscape */ $extraHtml ?></div>
                                    </div>
                                <?php endif; ?>
                            </div>

                            <?php if ($isCancellationRequested): ?>
                                <div class="pg-cancellation-request-notice">
                                    Yêu cầu hủy đang chờ quản trị viên duyệt.
                                    Nếu đơn đã thanh toán, cửa hàng sẽ hoàn tiền sau khi chấp thuận.
                                </div>
                            <?php elseif ($isCancellationApproved): ?>
                                <div class="pg-cancellation-request-notice">
                                    Yêu cầu hủy đã được duyệt. Cửa hàng đang xử lý hoàn tiền cho đơn đã thanh toán.
                                </div>
                            <?php endif; ?>

                            <?php if ($_order->getStatus() !== 'received'): ?>
                                <div class="pg-order-history-card__foot">
                                    <a href="<?= $block->escapeUrl($block->getViewUrl($_order)) ?>" class="pg-action-btn">
                                        Xem chi tiết
                                    </a>
                                    <?php if ($reorderHelper->canReorder($_order->getEntityId())): ?>
                                        <a href="#"
                                           data-post='<?= /* @noEscape */ $postHelper->getPostData($block->getReorderUrl($_order)) ?>'
                                           class="pg-action-btn pg-action-btn--ghost">
                                            Đặt lại
                                        </a>
                                    <?php endif; ?>
                                    <?php if ($viewModel && $viewModel->canCancel($_order->getEntityId())): ?>
                                        <a href="#"
                                           class="pg-action-btn pg-action-btn--danger cancel-order"
                                           id="cancel-order-<?= /* @noEscape */ $_order->getId() ?>"
                                           data-mage-init='{"cancelOrderModal":{"url":"<?= /* @noEscape */ $block->getBaseUrl(); ?>","order_id":"<?= $block->escapeHtml($_order->getId()); ?>"}}'>
                                            Yêu cầu hủy
                                        </a>
                                        <?= $this->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
                                            ->setOrder($_order)
                                            ->setReasons($viewModel->getCancellationReasons($_order->getEntityId()))
                                            ->setTemplate('Magento_OrderCancellationUi::cancel-order-modal.phtml')
                                            ->toHtml()
                                        ?>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>

                <?php if ($block->getPagerHtml()): ?>
                    <div class="pg-pager-wrap"><?= $block->getPagerHtml() ?></div>
                <?php endif; ?>
            <?php else: ?>
                <div class="pg-empty-notice">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                    <span><?= $block->escapeHtml($block->getEmptyOrdersMessage()) ?></span>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
