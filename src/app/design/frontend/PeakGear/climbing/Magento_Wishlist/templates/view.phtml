<script id="form-tmpl" type="text/x-magento-template">
    <form id="wishlist-hidden-form" method="post" action="<%- data.url %>" class="no-display">
        <% if (data.qty) { %><input name="qty" value="<%- data.qty %>"><% } %>
        <% if (data.item) { %><input name="item" value="<%- data.item %>"><% } %>
        <% if (data.entity) { %><input name="entity" value="<%- data.entity %>"><% } %>
    </form>
</script>

<script>
    require([
        'jquery',
        'Magento_Customer/js/customer-data',
        'mage/translate'
    ], function ($, customerData, $t) {
        'use strict';

        function showTopMessage(messageHtml, type) {
            var $placeholder = $('[data-placeholder="messages"]').first(),
                $messages,
                messageClass;

            if (!$placeholder.length) {
                return;
            }

            $messages = $placeholder.children('.messages');
            if (!$messages.length) {
                $messages = $('<div class="messages"></div>');
                $placeholder.append($messages);
            }

            messageClass = type === 'error'
                ? 'message message-error error'
                : 'message message-success success';

            var $message = $('<div class="' + messageClass + '"><div>' + messageHtml + '</div></div>');
            $messages.append($message);

            setTimeout(function () {
                $message.addClass('toast-dismiss');
                setTimeout(function () {
                    $message.remove();
                }, 350);
            }, 3500);
        }

        $(document).on('click', '#wishlist-view-form .action.ajax-tocart', function (event) {
            var $button = $(this),
                $box = $button.closest('.box-tocart'),
                url = $button.data('cart-url'),
                itemId = $button.data('item-id'),
                qty = $box.find('[data-role="qty"]').val() || 1,
                formKey = $('input[name="form_key"]').first().val(),
                requestData;

            event.preventDefault();
            event.stopImmediatePropagation();

            if ($button.hasClass('disabled') || !url || !itemId) {
                return false;
            }

            requestData = {
                item: itemId,
                qty: qty
            };

            if (formKey) {
                requestData.form_key = formKey;
            }

            $button.addClass('disabled').css('opacity', '0.6');
            $button.find('span').text($t('Adding'));

            $.ajax({
                url: url,
                data: requestData,
                type: 'post',
                dataType: 'json',
                showLoader: true
            }).done(function (response) {
                if (response && response.redirectUrl && !response.success) {
                    window.location.href = response.redirectUrl;
                    return;
                }

                if (response && response.success) {
                    customerData.invalidate(['cart']);
                    customerData.reload(['cart'], true);
                    showTopMessage(response.message || $t('Thêm sản phẩm vào giỏ hàng thành công.'));

                    $button.find('span').text($t('Added'));
                    $button.css({
                        'opacity': '1',
                        'background-color': '#111',
                        'border-color': '#111',
                        'color': '#fff'
                    });

                    setTimeout(function () {
                        $button.removeClass('disabled').removeAttr('style');
                        $button.find('span').text($t('Add to cart'));
                    }, 3000);

                    return;
                }

                showTopMessage(
                    response && response.message ? response.message : $t('Không thể thêm sản phẩm vào giỏ hàng lúc này.'),
                    'error'
                );
                $button.removeClass('disabled').css('opacity', '1');
                $button.find('span').text($t('Add to cart'));
            }).fail(function () {
                showTopMessage($t('Không thể thêm sản phẩm vào giỏ hàng lúc này.'), 'error');
                $button.removeClass('disabled').css('opacity', '1');
                $button.find('span').text($t('Add to cart'));
            });

            return false;
        });
    });
</script>
