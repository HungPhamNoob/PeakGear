<?php
/**
 * PeakGear Climbing Theme - Product List Toolbar
 *
 * @var \Magento\Catalog\Block\Product\ProductList\Toolbar $block
 */
$availableOrders = $block->getAvailableOrders();
$currentOrder = $block->getCurrentOrder();
$currentDirection = $block->getCurrentDirection();
$availableLimit = $block->getAvailableLimit();
$currentLimit = $block->getLimit();
$currentMode = $block->getCurrentMode() ?: 'grid';

$widget = $this->helper(\Magento\Framework\Json\Helper\Data::class)->jsonDecode($block->getWidgetOptionsJson());
$widgetOptions = $this->helper(\Magento\Framework\Json\Helper\Data::class)->jsonEncode($widget['productListToolbarForm']);
?>

<div class="product-list-toolbar" data-mage-init='{"productListToolbarForm":<?= /* @noEscape */ $widgetOptions ?>}'>
    <!-- View Mode -->
    <div class="toolbar-view-mode">
        <button type="button" class="toolbar-view-btn <?= $currentMode === 'grid' ? 'active' : '' ?>" data-custom-mode="grid" title="<?= $block->escapeHtmlAttr(__('Lưới')) ?>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
            </svg>
        </button>

        <button type="button" class="toolbar-view-btn <?= $currentMode === 'list' ? 'active' : '' ?>" data-custom-mode="list" title="<?= $block->escapeHtmlAttr(__('Danh sách')) ?>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="6" x2="21" y2="6"/>
                <line x1="8" y1="12" x2="21" y2="12"/>
                <line x1="8" y1="18" x2="21" y2="18"/>
                <line x1="3" y1="6" x2="3.01" y2="6"/>
                <line x1="3" y1="12" x2="3.01" y2="12"/>
                <line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
        </button>
    </div>

    <!-- Sort By -->
    <div class="toolbar-sorter">
        <label for="sorter" class="toolbar-label">Sắp xếp:</label>
        <select id="sorter" class="toolbar-select" data-role="sorter">
            <?php foreach ($availableOrders as $orderCode => $orderLabel): ?>
                <option value="<?= $block->escapeHtmlAttr($orderCode) ?>"
                    <?= $currentOrder == $orderCode ? 'selected' : '' ?>>
                    <?php 
                    $translations = [
                        'relevance' => 'Mức độ phù hợp',
                        'name' => 'Theo tên',
                        'price' => 'Theo giá',
                        'position' => 'Mặc định'
                    ];
                    $translatedLabel = isset($translations[$orderCode]) ? $translations[$orderCode] : __($orderLabel);
                    ?>
                    <?= $block->escapeHtml($translatedLabel) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>

    <!-- Per Page -->
    <div class="toolbar-limiter">
        <label for="limiter" class="toolbar-label">Hiển thị:</label>
        <select id="limiter" class="toolbar-select" data-role="limiter">
            <?php foreach ($availableLimit as $key => $limit): ?>
                <option value="<?= $block->escapeHtmlAttr($key) ?>"
                    <?= $currentLimit == $key ? 'selected' : '' ?>>
                    <?= $block->escapeHtml($limit) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>

    <!-- Pager (Pagination) -->
    <?= $block->getPagerHtml() ?>
</div>

<script>
require(['jquery'], function($) {
    $(document).ready(function() {
        // Toggle view mode without page reload
        $('.toolbar-view-btn[data-custom-mode]').on('click', function(e) {
            e.preventDefault();
            var mode = $(this).data('custom-mode');
            
            // Update buttons visually
            $('.toolbar-view-btn[data-custom-mode]').removeClass('active');
            $('.toolbar-view-btn[data-custom-mode="' + mode + '"]').addClass('active');
            
            // Update grid container class
            $('.products-grid').removeClass('mode-grid mode-list').addClass('mode-' + mode);
        });
    });
});
</script>
