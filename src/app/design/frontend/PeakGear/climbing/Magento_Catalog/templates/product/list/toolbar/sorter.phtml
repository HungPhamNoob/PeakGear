$translations = [
    'Relevance' => 'Mức độ phù hợp',
    'relevance' => 'Mức độ phù hợp',
    'Name' => 'Theo tên',
    'name' => 'Theo tên',
    'Price' => 'Theo giá',
    'price' => 'Theo giá',
    'Position' => 'Mặc định',
    'position' => 'Mặc định'
];
?>
<div class="toolbar-sorter sorter">
    <label class="sorter-label" for="sorter">Sắp xếp:</label>
    <div class="pg-select-wrapper">
        <select id="sorter" data-role="sorter" class="sorter-options custom-sorter-select">
            <?php foreach ($block->getAvailableOrders() as $_key => $_order) : ?>
                <?php 
                $translatedLabel = isset($translations[$_key]) ? $translations[$_key] : __($_order);
                ?>
                <option value="<?= $block->escapeHtmlAttr($_key) ?>"
                    <?php if ($block->isOrderCurrent($_key)) : ?>
                        selected="selected"
                    <?php endif; ?>
                    >
                    <?= $block->escapeHtml($translatedLabel) ?>
                </option>
            <?php endforeach; ?>
        </select>
        <svg class="select-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </div>
    <?php if ($block->getCurrentDirection() == 'desc') : ?>
        <a title="Tăng dần"
           href="#"
           class="action sorter-action sort-desc custom-sort-action"
           data-role="direction-switcher"
           data-value="asc">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 16 4 4 4-4"/><path d="M7 20V4"/><path d="M11 4h10"/><path d="M11 8h7"/><path d="M11 12h4"/></svg>
        </a>
    <?php else : ?>
        <a title="Giảm dần"
           href="#"
           class="action sorter-action sort-asc custom-sort-action"
           data-role="direction-switcher"
           data-value="desc">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/><path d="M11 4h10"/><path d="M11 8h7"/><path d="M11 12h4"/></svg>
        </a>
