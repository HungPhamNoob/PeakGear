<?php
/**
 * PeakGear Climbing Theme - Add to Cart actions
 * Layout: Qty → Buy Now (primary) → Add to Cart (secondary) → Wishlist link
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
$product = $block->getProduct();

// ── Cập nhật trạng thái Wishlist hoàn toàn xử lý bằng JavaScript (CustomerData) ──
$isInWishlist = false;
?>

<?php if ($product->isSaleable()): ?>
    <input type="hidden" name="qty" id="qty" value="1"/>

    <!-- Quantity Row -->
    <div class="pdp-qty-row">
        <label class="pdp-qty-label" for="qty-input">Số lượng:</label>
        <div class="pdp-qty-selector">
            <button type="button" class="pdp-qty-btn pdp-qty-decrease" aria-label="Giảm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <input type="number" name="qty" id="qty-input" value="1" min="1" class="pdp-qty-input"
                   data-validate="{required:true, 'validate-item-quantity':{'minAllowed':1}}"/>
            <button type="button" class="pdp-qty-btn pdp-qty-increase" aria-label="Tăng">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
        </div>
    </div>

    <!-- CTA Buttons -->
    <div class="pdp-actions">
        <button type="button" class="pdp-buynow-btn" id="pdp-buynow-btn">MUA NGAY</button>
        <button type="submit" class="pdp-addtocart-btn">THÊM VÀO GIỎ</button>
    </div>

    <!-- Wishlist -->
    <div class="pdp-wishlist-row">
        <button type="button"
                class="pdp-wishlist-btn<?= $isInWishlist ? ' is-wishlisted' : '' ?>"
                id="pdp-wishlist-btn"
                data-product-id="<?= (int)$product->getId() ?>"
                data-wishlist-url="<?= $block->escapeUrl($block->getUrl('wishlist/index/add')) ?>"
                data-wishlist-remove-url="<?= $block->escapeUrl($block->getUrl('wishlist/index/remove')) ?>"
                data-login-url="<?= $block->escapeUrl($block->getUrl('customer/account/login')) ?>"
                <?= $isInWishlist ? 'disabled' : '' ?>
                aria-label="Yêu thích">
            <svg class="pdp-wishlist-icon"
                 viewBox="0 0 24 24"
                 fill="<?= $isInWishlist ? 'currentColor' : 'none' ?>"
                 stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="pdp-wishlist-label">
                <?= $isInWishlist ? 'Đã thêm vào yêu thích' : 'Thêm vào danh sách yêu thích' ?>
            </span>
        </button>
    </div>

<?php else: ?>
    <div class="pdp-unavailable">
        <p>Sản phẩm hiện đang hết hàng</p>
    </div>
<?php endif; ?>

<script>
require(['jquery', 'Magento_Customer/js/customer-data'], function($, customerData) {
    'use strict';

    // ── Qty ──────────────────────────────────────────────────────────────────
    var qtyInput = $('#qty-input');
    var hiddenQty = $('#qty');

    function syncQty(val) {
        val = Math.max(1, val);
        qtyInput.val(val);
        hiddenQty.val(val);
    }

    $('.pdp-qty-decrease').on('click', function() {
        syncQty((parseInt(qtyInput.val()) || 1) - 1);
    });
    $('.pdp-qty-increase').on('click', function() {
        syncQty((parseInt(qtyInput.val()) || 1) + 1);
    });
    qtyInput.on('change input', function() {
        hiddenQty.val($(this).val());
    });

    // ── Buy Now ───────────────────────────────────────────────────────────────
    $('#pdp-buynow-btn').on('click', function() {
        var form = $('#product_addtocart_form');
        if (form.length) {
            form.find('input[name="return_url"]').remove();
            form.append('<input type="hidden" name="return_url" value="' + window.BASE_URL + 'checkout/"/>');
            form.trigger('submit');
        }
    });

    // ── Add To Cart Notification ──────────────────────────────────────────────
    var isAdding = false;
    $('.pdp-addtocart-btn').on('click', function() {
        isAdding = true;
    });

    $(document).on('ajax:addToCart', function(event, data) {
        if (data.response && !data.response.error) {
            var productName = '<?= $block->escapeJs($product->getName()) ?>';
            showTopMessage('Đã thêm ' + productName + ' vào giỏ hàng.');
            isAdding = false;
        }
    });

    customerData.get('cart').subscribe(function (cartInfo) {
        if (isAdding) {
            var productName = '<?= $block->escapeJs($product->getName()) ?>';
            showTopMessage('Đã thêm ' + productName + ' vào giỏ hàng.');
            isAdding = false;
        }
    });

    function showTopMessage(messageHtml) {
        var $placeholder = $('[data-placeholder="messages"]').first();
        if (!$placeholder.length) {
            return;
        }

        var $messages = $placeholder.children('.messages');
        if (!$messages.length) {
            $messages = $('<div class="messages"></div>');
            $placeholder.append($messages);
        }

        var $message = $('<div class="message message-success success"><div>' + messageHtml + '</div></div>');
        $messages.append($message);

        setTimeout(function() {
            $message.addClass('toast-dismiss');
            setTimeout(function() {
                $message.remove();
            }, 350);
        }, 3500);
    }

    // ── Wishlist (Frontend customerData) ──────────────────────────────────────
    var $wishlistBtn   = $('#pdp-wishlist-btn');
    var productId      = $wishlistBtn.data('product-id');
    var alreadyInWishlist = false;

    var wishlistData = customerData.get('wishlist');
    
    function updateWishlistState(wishlist) {
        var isInWishlist = false;
        var removeUrl = '';
        var wishlistItemId = null;

        if (wishlist && wishlist.items && wishlist.items.length) {
            wishlist.items.forEach(function(item) {
                // Ensure correct parsing
                if (parseInt(item.product_id, 10) === parseInt(productId, 10)) {
                    isInWishlist = true;
                    // M2 contains delete_item_params as a JSON string
                    if (item.delete_item_params) {
                        try {
                            var params = JSON.parse(item.delete_item_params);
                            removeUrl = params.action || '';
                            if (params.data && params.data.item) {
                                wishlistItemId = params.data.item;
                            }
                        } catch (e) {
                            console.error(e);
                        }
                    }
                }
            });
        }
        
        if (isInWishlist) {
            alreadyInWishlist = true;
            $wishlistBtn.data('wishlist-dynamic-remove-url', removeUrl);
            $wishlistBtn.data('wishlist-dynamic-item', wishlistItemId);
            $wishlistBtn.find('.pdp-wishlist-icon').attr('fill', 'currentColor');
            $wishlistBtn.find('.pdp-wishlist-label').text('Đã thêm vào yêu thích');
            $wishlistBtn.addClass('is-wishlisted');
        } else {
            alreadyInWishlist = false;
            $wishlistBtn.data('wishlist-dynamic-remove-url', '');
            $wishlistBtn.data('wishlist-dynamic-item', '');
            $wishlistBtn.find('.pdp-wishlist-icon').attr('fill', 'none');
            $wishlistBtn.find('.pdp-wishlist-label').text('Thêm vào danh sách yêu thích');
            $wishlistBtn.removeClass('is-wishlisted');
        }
        $wishlistBtn.prop('disabled', false); // Always ensure it is clickable
    }
    
    // Check local storage immediately
    updateWishlistState(wishlistData());
    // Auto update when ajax fetches section
    wishlistData.subscribe(updateWishlistState);

    $wishlistBtn.on('click', function () {
        var formKey = $('input[name="form_key"]').first().val();
        var loginUrl = $wishlistBtn.data('login-url');
        var formData = new FormData();
        var endpoint = '';

        if (alreadyInWishlist) {
            endpoint = $wishlistBtn.data('wishlist-dynamic-remove-url') || $wishlistBtn.data('wishlist-remove-url');
            var itemId = $wishlistBtn.data('wishlist-dynamic-item');
            if (itemId) {
                formData.append('item', itemId);
            }
            $wishlistBtn.find('.pdp-wishlist-label').text('Đang xoá...');
        } else {
            endpoint = $wishlistBtn.data('wishlist-url');
            formData.append('product', productId);
            $wishlistBtn.find('.pdp-wishlist-label').text('Đang thêm...');
        }
        
        formData.append('form_key', formKey);
        formData.append('uenc', btoa(window.location.href));
        
        $wishlistBtn.prop('disabled', true);

        fetch(endpoint, {
            method: 'POST',
            body: formData,
            redirect: 'follow',
            credentials: 'same-origin'
        })
        .then(function(response) {
            var finalUrl = response.url || '';
            if (finalUrl.indexOf('customer/account/login') !== -1) {
                window.location.href = loginUrl;
                return;
            }
            
            // Xóa cache và force reload state, which will automatically fix UI
            customerData.invalidate(['wishlist']);
            customerData.reload(['wishlist'], true);
        })
        .catch(function() {
            $wishlistBtn.find('.pdp-wishlist-label').text('Có lỗi xảy ra, thử lại!');
            $wishlistBtn.prop('disabled', false);
        });
    });
});
</script>

<script type="text/x-magento-init">
    {
        "#product_addtocart_form": {
            "Magento_Catalog/js/catalog-add-to-cart": {
                "bindSubmit": false
            }
        }
    }
</script>
