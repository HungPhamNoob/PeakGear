<?php
/**
 * PeakGear Climbing Theme - Add to Cart (full right-column product info)
 * Renders: category badge, name, rating, price, description, stock, qty, cart btn, wishlist, trust badges
 * Matches React PDP right column exactly
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
$product = $block->getProduct();
$viewModel = $block->getData('view_model');

// Category
$categoryName = $viewModel ? $viewModel->getPrimaryCategoryName($product) : '';

// Rating (default values for display)
$reviewCount = 0;
$ratingSummary = 0;
try {
    $reviewSummary = $product->getRatingSummary();
    if ($reviewSummary) {
        $ratingSummary = $reviewSummary->getRatingSummary() ?: 0;
        $reviewCount = $reviewSummary->getReviewsCount() ?: 0;
    }
} catch (\Exception $e) {}
$ratingStars = $ratingSummary ? round($ratingSummary / 20, 1) : 0;
$ratingFull = (int)floor($ratingStars);

// Prices
$finalPrice = $product->getFinalPrice();
$originalPrice = $product->getPrice();
$hasDiscount = ($originalPrice > $finalPrice);
$discountPercent = $hasDiscount ? round((1 - $finalPrice / $originalPrice) * 100) : 0;

// Stock
$stockStatus = $product->isAvailable();

?>

<div class="pdp-info-wrapper">
    <!-- Category Badge -->
    <?php if ($categoryName): ?>
        <span class="pdp-category-badge"><?= $block->escapeHtml($categoryName) ?></span>
    <?php endif; ?>

    <!-- Product Name -->
    <h1 class="pdp-product-name"><?= $block->escapeHtml($product->getName()) ?></h1>

    <!-- Rating -->
    <?php if ($reviewCount > 0): ?>
    <div class="pdp-rating">
        <div class="pdp-rating-stars">
            <?php for ($i = 0; $i < 5; $i++): ?>
                <?php if ($i < $ratingFull): ?>
                    <svg class="pdp-star pdp-star-filled" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <?php else: ?>
                    <svg class="pdp-star pdp-star-empty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <?php endif; ?>
            <?php endfor; ?>
        </div>
        <span class="pdp-rating-text"><?= $block->escapeHtml($ratingStars) ?> (<?= (int)$reviewCount ?> đánh giá)</span>
    </div>
    <?php else: ?>
    <div class="pdp-rating">
        <span class="pdp-rating-text pdp-no-reviews">Chưa có đánh giá</span>
    </div>
    <?php endif; ?>

    <!-- Price -->
    <div class="pdp-price">
        <span class="pdp-price-final"><?= /* @noEscape */ ($viewModel ? $viewModel->formatPrice((float)$finalPrice) : '') ?></span>
        <?php if ($hasDiscount): ?>
            <span class="pdp-price-original"><?= /* @noEscape */ ($viewModel ? $viewModel->formatPrice((float)$originalPrice) : '') ?></span>
            <?php if ($discountPercent > 0): ?>
                <span class="pdp-discount-badge">-<?= (int)$discountPercent ?>%</span>
            <?php endif; ?>
        <?php endif; ?>
    </div>

    <!-- Short Description -->
    <?php if ($shortDescription = $product->getShortDescription()): ?>
        <p class="pdp-description"><?= /* @noEscape */ $shortDescription ?></p>
    <?php else: ?>
        <p class="pdp-description"><?= $block->escapeHtml($product->getName()) ?> - Sản phẩm chất lượng cao dành cho người đam mê leo núi và hoạt động ngoài trời.</p>
    <?php endif; ?>

    <!-- Stock Status -->
    <div class="pdp-stock-status">
        <span class="pdp-stock-dot <?= $stockStatus ? 'pdp-stock-in' : 'pdp-stock-out' ?>"></span>
        <span class="pdp-stock-text <?= $stockStatus ? 'pdp-stock-in-text' : 'pdp-stock-out-text' ?>">
            <?= $stockStatus ? 'Còn hàng' : 'Hết hàng' ?>
        </span>
    </div>

    <!-- Quantity & Add to Cart -->
    <?php if ($product->isSaleable()): ?>
        <input type="hidden" name="qty" id="qty" value="1"/>

        <div class="pdp-actions">
            <!-- Quantity Selector -->
            <div class="pdp-qty-selector">
                <button type="button" class="pdp-qty-btn pdp-qty-decrease" aria-label="Giảm">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <input type="number" name="qty" id="qty-input" value="1" min="1" class="pdp-qty-input"
                       data-validate="{required:true, 'validate-item-quantity':{'minAllowed':1}}"/>
                <button type="button" class="pdp-qty-btn pdp-qty-increase" aria-label="Tăng">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
            </div>

            <div class="pdp-cta-group">
                <!-- Add to Cart Button -->
                <button type="submit" class="pdp-addtocart-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    Thêm vào giỏ hàng
                </button>

                <!-- Buy Now Button -->
                <button type="button" class="pdp-buynow-btn" id="pdp-buynow-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    Mua ngay
                </button>
            </div>

            <!-- Wishlist Button -->
            <button type="button" class="pdp-wishlist-btn" aria-label="Yêu thích">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
        </div>
    <?php else: ?>
        <div class="pdp-unavailable">
            <p>Sản phẩm hiện đang hết hàng</p>
        </div>
    <?php endif; ?>

    <!-- Trust Features -->
    <div class="pdp-trust-features">
        <div class="pdp-trust-item">
            <svg class="pdp-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <div class="pdp-trust-text">
                <p class="pdp-trust-title">Miễn phí ship</p>
                <p class="pdp-trust-desc">Đơn từ 1 triệu</p>
            </div>
        </div>
        <div class="pdp-trust-item">
            <svg class="pdp-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div class="pdp-trust-text">
                <p class="pdp-trust-title">Bảo hành</p>
                <p class="pdp-trust-desc">12 tháng chính hãng</p>
            </div>
        </div>
        <div class="pdp-trust-item">
            <svg class="pdp-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
            <div class="pdp-trust-text">
                <p class="pdp-trust-title">Đổi trả</p>
                <p class="pdp-trust-desc">30 ngày miễn phí</p>
            </div>
        </div>
    </div>
</div>

<script>
require(['jquery'], function($) {
    'use strict';
    var qtyInput = $('#qty-input');
    var hiddenQty = $('#qty');

    $('.pdp-qty-decrease').on('click', function() {
        var val = parseInt(qtyInput.val()) || 1;
        if (val > 1) {
            qtyInput.val(val - 1).trigger('change');
            hiddenQty.val(val - 1);
        }
    });

    $('.pdp-qty-increase').on('click', function() {
        var val = parseInt(qtyInput.val()) || 1;
        qtyInput.val(val + 1).trigger('change');
        hiddenQty.val(val + 1);
    });

    qtyInput.on('change', function() {
        hiddenQty.val($(this).val());
    });

    // Buy Now: submit the form, then redirect to checkout
    $('#pdp-buynow-btn').on('click', function() {
        var form = $(this).closest('form');
        if (!form.length) {
            form = $('#product_addtocart_form');
        }
        if (form.length) {
            // Set a flag so after add-to-cart succeeds we redirect to checkout
            var originalAction = form.attr('action');
            form.find('input[name="return_url"]').remove();
            form.append('<input type="hidden" name="return_url" value="' + window.BASE_URL + 'cart/checkout/#shipping"/>');
            form.submit();
        }
    });
});
</script>
