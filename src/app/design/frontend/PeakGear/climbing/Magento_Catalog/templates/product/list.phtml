<?php
/**
 * PeakGear Climbing Theme - Product List Template
 *
 * @var \Magento\Catalog\Block\Product\ListProduct $block
 */

use Magento\Framework\App\Action\Action;

$_productCollection = $block->getLoadedProductCollection();
$_helper = $block->getData('outputHelper');
?>

<?php if (!$_productCollection->count()): ?>
    <div class="empty-products">
        <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21L16.65 16.65"/>
            </svg>
        </div>
        <h3 class="empty-title">Không tìm thấy sản phẩm</h3>
        <p class="empty-text">Vui lòng thử lại với bộ lọc khác</p>
    </div>
<?php else: ?>
    <?= $block->getToolbarHtml() ?>
    
    <div class="products-grid mode-<?= $block->getMode() ?>" data-bind="scope: 'productList'">
        <?php foreach ($_productCollection as $_product): ?>
            <?php
                $productImage = $block->getImage($_product, 'category_page_grid');
                $productUrl = $_product->getProductUrl();
                $productName = $_product->getName();
                $productPrice = $block->getProductPrice($_product);
                $reviewsHtml = $block->getReviewsSummaryHtml($_product, 'short');
                $productId = $_product->getId();
                $addToCartParams = $block->getAddToCartPostParams($_product);
            ?>
            
            <div class="product-card animate-fade-in-up" data-product-id="<?= $block->escapeHtmlAttr($productId) ?>">
                <!-- Product Image -->
                <div class="product-image-wrapper">
                    <a href="<?= $block->escapeUrl($productUrl) ?>" class="product-image-link">
                        <img src="<?= $block->escapeUrl($productImage->getImageUrl()) ?>" 
                             alt="<?= $block->escapeHtmlAttr($productName) ?>"
                             class="product-image"
                             loading="lazy"/>
                    </a>
                    
                    <!-- Product Badges -->
                    <div class="product-badges">
                        <?php if ($_product->isAvailable()): ?>
                            <?php if ($_product->getData('is_new')): ?>
                                <span class="badge badge-new">Mới</span>
                            <?php endif; ?>
                            <?php if ($_product->getSpecialPrice()): ?>
                                <?php $discount = round(100 - ($_product->getSpecialPrice() / $_product->getPrice() * 100)); ?>
                                <span class="badge badge-sale">-<?= $block->escapeHtml($discount) ?>%</span>
                            <?php endif; ?>
                        <?php else: ?>
                            <span class="badge badge-soldout">Hết hàng</span>
                        <?php endif; ?>
                    </div>
                    
                    <!-- Quick Actions -->
                    <div class="product-actions">
                        <?php if ($block->helper(\Magento\Wishlist\Helper\Data::class)->isAllow()): ?>
                            <a href="#" 
                               class="action-btn action-wishlist"
                               title="Thêm vào yêu thích"
                               data-post='<?= /* @noEscape */ $block->helper(\Magento\Wishlist\Helper\Data::class)->getAddParams($_product) ?>'
                               data-action="add-to-wishlist"
                               data-product-id="<?= $block->escapeHtmlAttr($productId) ?>">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61C20.33 4.1 19.72 3.7 19.05 3.43C18.38 3.16 17.67 3.02 16.95 3.02C16.23 3.02 15.52 3.16 14.85 3.43C14.18 3.7 13.57 4.1 13.06 4.61L12 5.67L10.94 4.61C9.9 3.57 8.51 2.99 7.05 2.99C5.59 2.99 4.2 3.57 3.16 4.61C2.12 5.65 1.54 7.04 1.54 8.5C1.54 9.96 2.12 11.35 3.16 12.39L4.22 13.45L12 21.23L19.78 13.45L20.84 12.39C21.35 11.88 21.75 11.27 22.02 10.6C22.29 9.93 22.43 9.22 22.43 8.5C22.43 7.78 22.29 7.07 22.02 6.4C21.75 5.73 21.35 5.12 20.84 4.61Z"/>
                                </svg>
                            </a>
                        <?php endif; ?>
                        
                        <style>
                            .product-actions {
                                position: relative;
                                z-index: 50;
                                pointer-events: auto;
                            }
                            .action-wishlist.added svg {
                                fill: currentColor;
                            }
                        </style>
                        
                        <a href="<?= $block->escapeUrl($productUrl) ?>" 
                           class="action-btn action-quickview"
                           title="Xem nhanh">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12S5 4 12 4 23 12 23 12 19 20 12 20 1 12 1 12Z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </a>
                        
                        <?php if ($_product->isAvailable()): ?>
                            <form data-role="tocart-form" 
                                  data-product-sku="<?= $block->escapeHtmlAttr($_product->getSku()) ?>"
                                  action="<?= $block->escapeUrl($addToCartParams['action']) ?>" 
                                  data-mage-init='{"catalogAddToCart": {}}'
                                  method="post"
                                  class="action-cart-form">
                                <?= $block->getBlockHtml('formkey') ?>
                                <input type="hidden" name="product" value="<?= $block->escapeHtmlAttr($productId) ?>">
                                <input type="hidden" name="<?= /* @noEscape */ Action::PARAM_NAME_URL_ENCODED ?>" 
                                       value="<?= /* @noEscape */ $addToCartParams['data'][Action::PARAM_NAME_URL_ENCODED] ?>">
                                <button type="submit" 
                                        class="action-btn action-cart"
                                        title="Thêm vào giỏ">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="9" cy="21" r="1"/>
                                        <circle cx="20" cy="21" r="1"/>
                                        <path d="M1 1H5L7.68 14.39C7.77 14.83 8.02 15.23 8.37 15.5C8.73 15.78 9.17 15.92 9.62 15.9H19.55C20 15.92 20.44 15.78 20.79 15.5C21.15 15.23 21.4 14.83 21.49 14.39L23 6H6"/>
                                    </svg>
                                </button>
                            </form>
                        <?php endif; ?>
                    </div>
                </div>
                
                <!-- Product Info -->
                <div class="product-info">
                    <?php if ($reviewsHtml): ?>
                        <div class="product-rating">
                            <?= /* @noEscape */ $reviewsHtml ?>
                        </div>
                    <?php endif; ?>
                    
                    <h3 class="product-name">
                        <a href="<?= $block->escapeUrl($productUrl) ?>"><?= $block->escapeHtml($productName) ?></a>
                    </h3>
                    
                    <div class="product-price">
                        <?= /* @noEscape */ $productPrice ?>
                    </div>
                </div>
            </div>
        <?php endforeach; ?>
    </div>
    
    <?= $block->getToolbarHtml() ?>
<?php endif; ?>

<script type="text/x-magento-init">
{
    "[data-bind='scope: productList']": {
        "Magento_Ui/js/core/app": {
            "components": {
                "productList": {
                    "component": "PeakGear_Climbing/js/product-list"
                }
            }
        }
    }
}
</script>
