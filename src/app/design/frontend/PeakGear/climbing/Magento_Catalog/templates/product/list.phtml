<?php
/**
 * PeakGear Climbing Theme - Product List Template
 *
 * @var \Magento\Catalog\Block\Product\ListProduct $block
 */

use Magento\Framework\App\Action\Action;

$_productCollection = $block->getLoadedProductCollection();
$_helper = $block->getData('outputHelper');
?>

<?php if (!$_productCollection->count()): ?>
    <div class="empty-products">
        <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21L16.65 16.65"/>
            </svg>
        </div>
        <h3 class="empty-title">Không tìm thấy sản phẩm</h3>
        <p class="empty-text">Vui lòng thử lại với bộ lọc khác</p>
    </div>
<?php else: ?>
    <?= $block->getToolbarHtml() ?>
    
    <div class="products-grid mode-<?= $block->getMode() ?>" data-bind="scope: 'productList'">
        <?php foreach ($_productCollection as $index => $_product): ?>
            <?php
                $productImageObj = $block->getImage($_product, 'category_page_grid');
                $productUrl = $_product->getProductUrl();
                $productName = $_product->getName();
                
                // Get Prices 
                $finalPrice = $_product->getFinalPrice();
                $regularPrice = $_product->getPrice();
                $hasSpecialPrice = $finalPrice < $regularPrice;
                $discount = $hasSpecialPrice ? round((1 - $finalPrice / $regularPrice) * 100) : 0;
                
                $productId = $_product->getId();
                $addToCartParams = $block->getAddToCartPostParams($_product);
                
                // Rating
                $ratingSummary = $_product->getRatingSummary();
                $reviewCount = $_product->getReviewsCount();
                $rating = $ratingSummary ? round($ratingSummary / 20, 1) : 0;
                $fullStars = (int)floor($rating);
                $emptyStars = 5 - $fullStars;
                
                $hasImage = $productImageObj && $productImageObj->getImageUrl() && strpos($productImageObj->getImageUrl(), 'placeholder') === false;
            ?>
            <div class="product-card hover-lift animate-fade-in-up" style="animation-delay: <?= 0.05 * ($index + 1) ?>s" data-price="<?= (float)$finalPrice ?>" data-product-id="<?= $block->escapeHtmlAttr($productId) ?>">
                <!-- Sale Badge -->
                <?php if ($discount > 0): ?>
                    <div class="product-sale-badge">-<?= $discount ?>%</div>
                <?php endif; ?>

                <!-- Image Container -->
                <a href="<?= $block->escapeUrl($productUrl) ?>" class="product-image-container">
                    <?php if ($hasImage): ?>
                        <img src="<?= $block->escapeUrl($productImageObj->getImageUrl()) ?>"
                             alt="<?= $block->escapeHtmlAttr($productName) ?>"
                             class="product-real-image"
                             loading="lazy"
                             width="300"
                             height="300"/>
                    <?php else: ?>
                        <div class="product-placeholder">
                            <div class="product-placeholder-circle">
                                <span class="product-placeholder-initial">P</span>
                            </div>
                        </div>
                    <?php endif; ?>

                    <!-- Quick Actions Overlay -->
                    <div class="product-quick-actions">
                        <button type="button" class="product-action-btn product-action-wishlist" title="Yêu thích" data-action="add-to-wishlist" data-product-id="<?= $block->escapeHtmlAttr($productId) ?>">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        </button>
                        <span class="product-action-btn product-action-view" title="Xem chi tiết" onclick="window.location.href='<?= $block->escapeUrl($productUrl) ?>'">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                        </span>
                        
                        <?php if ($_product->isAvailable()): ?>
                            <form data-role="tocart-form" 
                                  data-product-sku="<?= $block->escapeHtmlAttr($_product->getSku()) ?>"
                                  action="<?= $block->escapeUrl($addToCartParams['action']) ?>" 
                                  method="post"
                                  class="action-cart-form" style="display: contents;">
                                <?= $block->getBlockHtml('formkey') ?>
                                <input type="hidden" name="product" value="<?= $block->escapeHtmlAttr($productId) ?>">
                                <input type="hidden" name="<?= /* @noEscape */ Action::PARAM_NAME_URL_ENCODED ?>" 
                                       value="<?= /* @noEscape */ $addToCartParams['data'][Action::PARAM_NAME_URL_ENCODED] ?>">
                                <button type="submit" class="product-action-btn product-action-cart" title="Thêm vào giỏ">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                                </button>
                            </form>
                        <?php endif; ?>
                    </div>
                </a>

                <!-- Content -->
                <div class="product-content">
                    <!-- Name -->
                    <h4 class="product-card-name">
                        <a href="<?= $block->escapeUrl($productUrl) ?>"><?= $block->escapeHtml($productName) ?></a>
                    </h4>

                    <!-- Rating -->
                    <?php if ($rating > 0): ?>
                    <div class="product-rating-row">
                        <div class="product-stars">
                            <?php for ($i = 0; $i < $fullStars; $i++): ?>
                                <svg class="star star-filled" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <?php endfor; ?>
                            <?php for ($i = 0; $i < $emptyStars; $i++): ?>
                                <svg class="star star-empty" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <?php endfor; ?>
                        </div>
                        <span class="product-rating-value"><?= number_format($rating, 1) ?></span>
                        <span class="product-reviews-count">(<?= $reviewCount ?>)</span>
                    </div>
                    <?php endif; ?>

                    <!-- Price -->
                    <div class="product-price-row">
                        <?php $priceHelper = $this->helper(\Magento\Framework\Pricing\Helper\Data::class); ?>
                        <span class="product-current-price"><?= /* @noEscape */ $priceHelper->currency($finalPrice, true, false) ?></span>
                        <?php if ($hasSpecialPrice): ?>
                            <span class="product-original-price"><?= /* @noEscape */ $priceHelper->currency($regularPrice, true, false) ?></span>
                        <?php endif; ?>
                    </div>
                </div>

                <!-- Bottom Accent Line -->
                <div class="product-accent-line"></div>
            </div>
        <?php endforeach; ?>
    </div>
    <div class="toolbar-bottom">
        <?= $block->getToolbarHtml() ?>
    </div>
<?php endif; ?>

<script type="text/x-magento-init">
{
    "[data-bind='scope: productList']": {
        "Magento_Ui/js/core/app": {
            "components": {
                "productList": {
                    "component": "PeakGear_Climbing/js/product-list"
                }
            }
        }
    }
}
</script>
