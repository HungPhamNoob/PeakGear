                        <form class="pdp-review-form"
                              id="pdpReviewForm"
                              action="<?= $block->escapeUrl($reviewPostUrl) ?>"
                              method="post">
                            <?= $block->getBlockHtml('formkey') ?>
                            <input type="hidden" name="product_id" value="<?= (int)$product->getId() ?>"/>
                            <input type="hidden" name="rating" value="" data-role="review-rating-input"/>

                            <div class="pdp-review-field">
