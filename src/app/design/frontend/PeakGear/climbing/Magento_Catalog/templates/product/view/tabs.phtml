<?php
/**
 * PeakGear Climbing Theme - Product Tabs Container
 * Renders tabs for Specs, Description, and Reviews with JS switching
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
$product   = $block->getProduct();
$productId = (int)$product->getId();
$storeId   = (int)$block->getLayout()->createBlock(\Magento\Store\Block\Switcher::class)->getCurrentStoreId();

// ── Mô tả & Thông số kỹ thuật ────────────────────────────────────────────────
$description    = $product->getDescription();
$attributesBlock = $block->getChildBlock('peakgear.tab.attributes');
$additionalData  = $attributesBlock ? $attributesBlock->getAdditionalData() : [];

// ── Lấy dữ liệu đánh giá trực tiếp từ Magento Review module ─────────────────
$reviewCount  = 0;
$reviewItems  = [];

// ── Kiểm tra đăng nhập & lấy tên tự động ─────────────────────────────────────
$isLoggedIn      = false;
$customerNickname = '';
$loginUrl         = $block->getUrl('customer/account/login',
                        ['referer' => base64_encode($block->getUrl('*/*/*', ['_use_rewrite' => true]))]);
try {
    $objectManager   = \Magento\Framework\App\ObjectManager::getInstance();
    $customerSession = $objectManager->get(\Magento\Customer\Model\Session::class);
    $isLoggedIn      = $customerSession->isLoggedIn();

    if ($isLoggedIn) {
        $customer = $customerSession->getCustomer();
        $firstName = $customer->getFirstname() ?: '';
        $lastName  = $customer->getLastname()  ?: '';
        // Hiển thị: Tên + chữ cái đầu của họ (ví dụ: "Hiếu N.")
        $customerNickname = trim($firstName . ($lastName ? ' ' . mb_substr($lastName, 0, 1) . '.' : ''));
    }

    // Lấy collection review đã approved
    $reviewCollection = $objectManager->create(\Magento\Review\Model\ResourceModel\Review\Collection::class);
    $reviewCollection
        ->addStoreFilter($storeId)
        ->addStatusFilter(\Magento\Review\Model\Review::STATUS_APPROVED)
        ->addEntityFilter('product', $productId)
        ->setDateOrder()
        ->addRateVotes();

    $reviewCount = $reviewCollection->getSize();
    if ($reviewCount > 0) {
        $reviewItems = $reviewCollection->getItems();
    }
} catch (\Exception $e) {
    $reviewCount = 0;
}
?>


