    </div>
</div>

<script>
require(['jquery'], function ($) {
    'use strict';

    function syncTabContentHeight(section) {
        var activePanel = section.find('.pdp-tab-panel.active');
        var contentWrap = section.find('.pdp-tabs-content');

        if (!activePanel.length || !contentWrap.length) {
            return;
        }

        contentWrap.css('min-height', activePanel.outerHeight() + 'px');
    }

    function normalizePdpStructure() {
        var main = $('.page-product-view .column.main').first();
        if (!main.length) {
            return false;
        }

        var breadcrumb = $('.page-product-view .pdp-breadcrumb').first();
        if (breadcrumb.length && !breadcrumb.parent().is(main)) {
            main.prepend(breadcrumb);
        }

        var tabs = $('.page-product-view .pdp-tabs-section').first();
        var infoMain = main.find('.product-info-main').first();
        if (tabs.length && infoMain.length && !tabs.parent().is(main)) {
            tabs.insertAfter(infoMain);
        }

        return !!(tabs.length && infoMain.length && tabs.parent().is(main));
    }

    function stabilizePdpLayout() {
        var retries = 0;
        var maxRetries = 12;

        function runNormalize() {
            var done = normalizePdpStructure();
            retries += 1;
            if (!done && retries < maxRetries) {
                window.setTimeout(runNormalize, 120);
            }
        }

        runNormalize();
    }

    function escapeHtml(value) {
        return $('<div/>').text(value || '').html();
    }

    function nl2br(value) {
        return escapeHtml(value).replace(/\n/g, '<br>');
    }

    function renderReviewStars(stars) {
        var html = '';
        var index;

        for (index = 1; index <= 5; index += 1) {
            html += '<svg viewBox="0 0 24 24" width="14" height="14"'
                + ' fill="' + (index <= stars ? 'currentColor' : 'none') + '"'
                + ' stroke="currentColor" stroke-width="1.5"'
                + ' class="pdp-star ' + (index <= stars ? 'pdp-star-filled' : 'pdp-star-empty') + '">'
                + '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>'
                + '</svg>';
        }

        return html;
    }

    function updateSummaryStars($section, average) {
        var rounded = Math.round(average);
        var $stars = $('[data-role="pdp-review-summary-stars"]').find('.pdp-star');

        $stars.each(function (index) {
            var $star = $(this);
            if (index < rounded) {
                $star
                    .removeClass('pdp-star-empty')
                    .addClass('pdp-star-filled')
                    .attr('fill', 'currentColor')
                    .attr('stroke', 'currentColor');
            } else {
                $star
                    .removeClass('pdp-star-filled')
                    .addClass('pdp-star-empty')
                    .attr('fill', 'none')
                    .attr('stroke', 'currentColor');
            }
        });

        $('[data-role="pdp-review-summary-average"]').text(Number(average || 0).toFixed(1) + '/5');
        $('[data-role="pdp-review-summary-count-text"]').text(
            Number($section.data('review-count') || 0) > 0
                ? Number($section.data('review-count')).toString() + ' đánh giá'
                : 'Chưa có đánh giá'
        );
    }

    function updateSummary($section, summary) {
        var count = parseInt(summary && summary.count ? summary.count : 0, 10);
        var average = parseFloat(summary && summary.average ? summary.average : 0);

        $section.data('review-count', count);
        $('[data-role="pdp-review-tab-count"]').text('(' + count + ')');
        $('[data-role="pdp-review-summary-count-text"]').text(count > 0 ? count + ' đánh giá' : 'Chưa có đánh giá');
        $('[data-role="pdp-review-summary-average"]').text(average.toFixed(1) + '/5');
        updateSummaryStars($section, average);
    }

    function renderReviewItem(review) {
        var dateHtml = review.date
            ? '<span class="pdp-review-item-date">' + escapeHtml(review.date) + '</span>'
            : '';

        return '<div class="pdp-review-item">'
            + '<div class="pdp-review-item-header">'
            + '<div class="pdp-review-item-meta">'
            + '<span class="pdp-review-item-author">' + escapeHtml(review.nickname) + '</span>'
            + dateHtml
            + '</div>'
            + '<div class="pdp-review-item-stars">' + renderReviewStars(parseInt(review.stars, 10) || 0) + '</div>'
            + '</div>'
            + '<div class="pdp-review-item-body">' + nl2br(review.detail) + '</div>'
            + '</div>';
    }

    function applyReviewState($section, state) {
        var summary = state && state.summary ? state.summary : {};
        var reviews = state && $.isArray(state.reviews) ? state.reviews : [];
        var $reviewList = $section.find('[data-role="pdp-review-list"]');
        var $emptyState = $section.find('[data-role="pdp-review-empty"]');
        var listHtml = '';

        updateSummary($section, summary);

        $.each(reviews, function (_, review) {
            listHtml += renderReviewItem(review);
        });

        $reviewList.html(listHtml);

        if (reviews.length > 0) {
            $reviewList.removeClass('is-hidden');
            $emptyState.addClass('is-hidden');
        } else {
            $reviewList.addClass('is-hidden');
            $emptyState.removeClass('is-hidden');
        }

        syncTabContentHeight($section);
    }

    function fetchReviewState($section) {
        var stateUrl = $section.data('review-state-url');

        if (!stateUrl) {
            return $.Deferred().resolve().promise();
        }

        return $.ajax({
            url: stateUrl,
            type: 'GET',
            dataType: 'json',
            cache: false,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        }).done(function (response) {
            if (!response || response.success !== true) {
                return;
            }

            applyReviewState($section, response);
        });
    }

    function showTopMessage(messageHtml, type) {
        var $placeholder = $('[data-placeholder="messages"]').first();
        var $messages;
        var messageClass = type === 'error'
            ? 'message message-error error'
            : 'message message-success success';

        if (!$placeholder.length) {
            return;
        }

        $messages = $placeholder.children('.messages');
        if (!$messages.length) {
            $messages = $('<div class="messages"></div>');
            $placeholder.append($messages);
        }

        var $message = $('<div class="' + messageClass + '"><div>' + messageHtml + '</div></div>');
        $messages.append($message);

        window.setTimeout(function () {
            $message.addClass('toast-dismiss');
            window.setTimeout(function () {
                $message.remove();
            }, 350);
        }, 3200);
    }

    $('.pdp-tabs-section').on('click', '.pdp-tab-btn', function () {
        var section = $(this).closest('.pdp-tabs-section');
        var tabId = $(this).data('tab');

        section.find('.pdp-tab-btn').removeClass('active');
        $(this).addClass('active');
        section.find('.pdp-tab-panel').removeClass('active');
        section.find('#tab-' + tabId).addClass('active');
        syncTabContentHeight(section);
    });

    $('.pdp-tabs-section').each(function () {
        var $section = $(this);
        var $modal = $section.find('[data-role="pdp-review-modal"]');
        var $loginPanel = $modal.find('[data-role="review-login-panel"]');
        var $formPanel = $modal.find('[data-role="review-form-panel"]');
        var $form = $modal.find('#pdpReviewForm');
        var $ratingInput = $form.find('[data-role="review-rating-input"]');
        var $detailInput = $form.find('textarea[name="detail"]');
        var $submitButton = $form.find('[data-role="review-submit-button"]');
        var selectedRating = 0;

        function clearFieldErrors() {
            $form.find('[data-role="review-rating-error"]').text('');
            $form.find('[data-role="review-detail-error"]').text('');
            $form.find('[data-role="review-form-message"]').removeClass('is-error is-success').text('');
        }

        function paintInputStars(activeValue) {
            $form.find('.pdp-review-star-btn').each(function () {
                var $button = $(this);
                var starValue = parseInt($button.data('rating'), 10);
                var $icon = $button.find('svg');

                if (starValue <= activeValue) {
                    $button.addClass('active');
                    $icon.attr('fill', 'currentColor');
                } else {
                    $button.removeClass('active');
                    $icon.attr('fill', 'none');
                }
            });
        }

        function resetForm() {
            selectedRating = 0;
            $ratingInput.val('');
            $detailInput.val('');
            clearFieldErrors();
            paintInputStars(0);
        }

        function openModal() {
            var isLoggedIn = $section.data('review-auth') === 1 || $section.data('review-auth') === '1';

            clearFieldErrors();
            $loginPanel.toggleClass('is-hidden', isLoggedIn);
            $formPanel.toggleClass('is-hidden', !isLoggedIn);
            $modal.addClass('is-open').attr('aria-hidden', 'false');
            $('body').addClass('pdp-review-modal-open');
        }

        function closeModal() {
            $modal.removeClass('is-open').attr('aria-hidden', 'true');
            $('body').removeClass('pdp-review-modal-open');
            resetForm();
        }

        function validateForm() {
            var detailValue = $.trim($detailInput.val());
            var isValid = true;

            clearFieldErrors();

            if (!selectedRating) {
                $form.find('[data-role="review-rating-error"]').text('Vui lòng chọn số sao đánh giá.');
                isValid = false;
            }

            if (!detailValue) {
                $form.find('[data-role="review-detail-error"]').text('Vui lòng nhập nội dung đánh giá.');
                isValid = false;
            }

            return isValid;
        }

        $section.on('click', '[data-action="open-review-modal"]', function () {
            openModal();
        });

        $modal.on('click', '[data-action="close-review-modal"]', function () {
            closeModal();
        });

        $(document).on('keydown.pdpReviewModal', function (event) {
            if (event.key === 'Escape' && $modal.hasClass('is-open')) {
                closeModal();
            }
        });

        $form.on('click', '.pdp-review-star-btn', function () {
            selectedRating = parseInt($(this).data('rating'), 10) || 0;
            $ratingInput.val(selectedRating);
            paintInputStars(selectedRating);
            $form.find('[data-role="review-rating-error"]').text('');
        });

        $form.on('mouseenter', '.pdp-review-star-btn', function () {
            paintInputStars(parseInt($(this).data('rating'), 10) || 0);
        });

        $form.find('[data-role="review-rating-select"]').on('mouseleave', function () {
            paintInputStars(selectedRating);
        });

        $form.on('input', 'textarea[name="detail"]', function () {
            $form.find('[data-role="review-detail-error"]').text('');
        });

        $form.on('submit', function (event) {
            event.preventDefault();

            if (!validateForm()) {
                return;
            }

            $submitButton.prop('disabled', true);

            $.ajax({
                url: $form.attr('action'),
                type: 'POST',
                dataType: 'json',
                data: $form.serialize(),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).done(function (response) {
                if (!response || response.success !== true) {
                    if (response && response.requiresLogin) {
                        $section.data('review-auth', '0');
                        openModal();
                        return;
                    }

                    $form.find('[data-role="review-form-message"]')
                        .addClass('is-error')
                        .text(response && response.message ? response.message : 'Không thể gửi đánh giá lúc này.');
                    return;
                }

                if (response.review) {
                    var $reviewList = $section.find('[data-role="pdp-review-list"]');
                    var $emptyState = $section.find('[data-role="pdp-review-empty"]');

                    $reviewList.removeClass('is-hidden').prepend(renderReviewItem(response.review));
                    $emptyState.addClass('is-hidden');
                }

                if (response.summary) {
                    updateSummary($section, response.summary);
                }

                fetchReviewState($section);
                closeModal();
                syncTabContentHeight($section);
                showTopMessage(response.message || 'Đánh giá của bạn đã được đăng thành công.');
            }).fail(function (xhr) {
                var response = xhr.responseJSON || {};

                if (xhr.status === 401 || response.requiresLogin) {
                    $section.data('review-auth', '0');
                    openModal();
                    return;
                }

                $form.find('[data-role="review-form-message"]')
                    .addClass('is-error')
                    .text(response.message || 'Không thể gửi đánh giá lúc này. Vui lòng thử lại sau.');
            }).always(function () {
                $submitButton.prop('disabled', false);
            });
        });

        fetchReviewState($section);
        syncTabContentHeight($section);
    });

    $(window).on('resize', function () {
        $('.pdp-tabs-section').each(function () {
            syncTabContentHeight($(this));
        });
    });

    $(function () {
        stabilizePdpLayout();
        $('.pdp-tabs-section').each(function () {
            syncTabContentHeight($(this));
        });
    });

    $(window).on('load', function () {
        stabilizePdpLayout();
        $('.pdp-tabs-section').each(function () {
            syncTabContentHeight($(this));
        });
    });
});
</script>
