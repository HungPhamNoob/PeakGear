                                    </svg>
                                <?php endfor; ?>
                            </div>
                        </div>
                        <?php if ($review->getTitle()): ?>
                            <div class="pdp-review-item-title"><?= $block->escapeHtml($review->getTitle()) ?></div>
                        <?php endif; ?>
                        <div class="pdp-review-item-body"><?= $block->escapeHtml($review->getDetail()) ?></div>
                    </div>
                <?php endforeach; ?>
            </div>
            <?php else: ?>
            <div class="pdp-reviews-empty">
                <svg class="pdp-reviews-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
