<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Product Detail Page Layout
 * Completely custom PDP matching React reference design
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <attribute name="class" value="page-product-view"/>

        <!-- Hide Magento's default breadcrumbs (we render our own inside the template) -->
        <referenceBlock name="breadcrumbs" remove="true"/>

        <!-- Hide Magento default page title -->
        <referenceBlock name="page.main.title" remove="true"/>

        <!-- Hide default product info blocks we replace with our own -->
        <referenceBlock name="product.info.stock.sku" remove="true"/>
        <referenceBlock name="product.info.review" remove="true"/>
        <referenceBlock name="product.price.final" remove="true"/>
        <referenceBlock name="product.info.overview" remove="true"/>
        <referenceBlock name="product.info.social" remove="true"/>
        <referenceBlock name="product.info.mailto" remove="true"/>
        <referenceBlock name="product.info.addtocart.additional" remove="true"/>
        

        <!-- Override the product media/gallery template -->
        <referenceBlock name="product.info.media.image">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/view/gallery.phtml</argument>
            </action>
        </referenceBlock>

        <!-- Custom Product Info block (breadcrumb rendered here) -->
        <referenceContainer name="product.info.main">
            <block class="Magento\Catalog\Block\Product\View"
                   name="peakgear.product.info"
                   template="Magento_Catalog::product/view/info.phtml"
                   before="-"/>
        </referenceContainer>

        <!-- Override add-to-cart template (contains all right-column content) -->
        <referenceBlock name="product.info.addtocart">
            <arguments>
                <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\ProductViewData</argument>
            </arguments>
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/view/addtocart.phtml</argument>
            </action>
        </referenceBlock>

        <!-- Product Form wrapper -->
        <referenceBlock name="product.info.form">
            <arguments>
                <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\ProductViewData</argument>
            </arguments>
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/view/form.phtml</argument>
            </action>
        </referenceBlock>

        <!-- Custom tabs section - replace Magento's default detailed info -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="peakgear.product.tabs"
                   template="Magento_Catalog::product/view/tabs.phtml"
                 after="-">
                <block class="Magento\Catalog\Block\Product\View\Description"
                       name="peakgear.tab.description"
                       template="Magento_Catalog::product/view/tabs/description.phtml"/>
                <block class="Magento\Catalog\Block\Product\View\Attributes"
                       name="peakgear.tab.attributes"
                       template="Magento_Catalog::product/view/tabs/attributes.phtml"/>
            </block>
        </referenceContainer>

        <!-- Remove Magento's default tab rendering -->
        <referenceBlock name="product.info.details" remove="true"/>

        <!-- Remove PageBuilder full-width sections (reviews, attributes, description wrappers) -->
        <!-- We handle all of these in our custom tabs template -->
        <referenceBlock name="product.reviews.wrapper" remove="true"/>
        <referenceBlock name="product.attributes.wrapper" remove="true"/>
        <referenceBlock name="reviews.tab" remove="true"/>
        <referenceBlock name="product.info.product_additional_data.wrapper" remove="true"/>
        <referenceBlock name="product.attributes.only.pagebuilder" remove="true"/>
        <referenceBlock name="product.attributes.exclude.pagebuilder" remove="true"/>
        <referenceContainer name="product.info.details.wrapper" remove="true"/>
        <referenceContainer name="product.info.description.wrapper" remove="true"/>
        <referenceContainer name="product.info.details.after.wrapper" remove="true"/>
        <referenceContainer name="product.attributes.pagebuilder.wrapper" remove="true"/>

        <!-- Related Products -->
        <referenceBlock name="catalog.product.related">
            <arguments>
                <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\ProductViewData</argument>
            </arguments>
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/list/related.phtml</argument>
            </action>
        </referenceBlock>

        <!-- Upsell Products -->
        <referenceBlock name="product.info.upsell">
            <arguments>
                <argument name="view_model" xsi:type="object">PeakGear\Catalog\ViewModel\ProductViewData</argument>
            </arguments>
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/list/upsell.phtml</argument>
            </action>
        </referenceBlock>

        <!-- Remove unnecessary sidebar/additional blocks for clean 1-column PDP -->
        <referenceContainer name="sidebar.main" remove="true"/>
        <referenceContainer name="sidebar.additional" remove="true"/>
    </body>
</page>
