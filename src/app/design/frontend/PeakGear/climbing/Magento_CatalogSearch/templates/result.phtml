<script>
require(['jquery'], function($) {
    'use strict';

    /* ---- Tab switching ---- */
    $(document).ready(function() {
        $('.search-tab-btn').on('click', function() {
            var target = $(this).data('target');
            $('.search-tab-btn').removeClass('active');
            $(this).addClass('active');
            $('.search-tab-content').removeClass('active');
            $('#' + target).addClass('active');
            $(window).trigger('resize');
        });

        /* ---- News Client-side Pagination ---- */
        var newsData   = <?= /* @noEscape */ $newsJson ?>;
        var perPage    = 6;   // Số bài viết mỗi trang
        var curPage    = 1;
        var container  = document.getElementById('news-grid-container');
        var pagination = document.getElementById('news-pagination');

        if (!container || !newsData || !newsData.length) return;

        function renderPage(page) {
            var start = (page - 1) * perPage;
            var end   = Math.min(start + perPage, newsData.length);
            var html  = '';

            for (var i = start; i < end; i++) {
                var item = newsData[i];
                var imgHtml = item.image_url
                    ? '<img class="news-page-card-image" src="' + escHtml(item.image_url) + '" alt="' + escHtml(item.title) + '" loading="lazy"/>'
                    : '<div class="news-page-card-image news-page-card-image-placeholder">PeakGear</div>';

                html += '<article class="news-page-card">'
                    + '<a href="' + escHtml(item.link) + '" target="_blank" rel="noopener noreferrer" class="news-page-card-image-link">'
                    + imgHtml + '</a>'
                    + '<div class="news-page-card-content">'
                    + '<h3 class="news-page-card-title"><a href="' + escHtml(item.link) + '" target="_blank" rel="noopener noreferrer">' + escHtml(item.title) + '</a></h3>'
                    + (item.description ? '<p class="news-page-card-desc">' + escHtml(item.description) + '</p>' : '')
                    + '<div class="news-page-card-meta"><span>' + escHtml(item.pub_date) + '</span>'
                    + '<a href="' + escHtml(item.link) + '" target="_blank" rel="noopener noreferrer">Đọc tiếp</a></div>'
                    + '</div></article>';
            }
            container.innerHTML = html;
        }

        function renderPagination(page) {
            var totalPages = Math.ceil(newsData.length / perPage);
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                return;
            }

            var html = '';
            // Prev button
            html += '<button class="pg-btn" id="pg-prev" ' + (page === 1 ? 'disabled' : '') + ' aria-label="Trang trước">&#8592;</button>';

            // Page numbers with ellipsis
            var pages = buildPageRange(page, totalPages);
            for (var j = 0; j < pages.length; j++) {
                if (pages[j] === '...') {
                    html += '<span class="pg-ellipsis">…</span>';
                } else {
                    html += '<button class="pg-btn' + (pages[j] === page ? ' active' : '') + '" data-p="' + pages[j] + '" aria-label="Trang ' + pages[j] + '">' + pages[j] + '</button>';
                }
            }

            // Next button
            html += '<button class="pg-btn" id="pg-next" ' + (page === totalPages ? 'disabled' : '') + ' aria-label="Trang tiếp">&#8594;</button>';

            pagination.innerHTML = html;

            // Events
            $('#pg-prev').on('click', function() { goTo(curPage - 1); });
            $('#pg-next').on('click', function() { goTo(curPage + 1); });
            pagination.querySelectorAll('.pg-btn[data-p]').forEach(function(btn) {
                btn.addEventListener('click', function() { goTo(parseInt(this.dataset.p)); });
            });
        }

        function buildPageRange(current, total) {
            var delta = 2, range = [], result = [], last;
            for (var i = Math.max(2, current - delta); i <= Math.min(total - 1, current + delta); i++) {
                range.push(i);
            }
            if (current - delta > 2)  range.unshift('...');
            if (current + delta < total - 1) range.push('...');
            range.unshift(1);
            if (total > 1) range.push(total);

            range.forEach(function(val) {
                if (last) {
                    if (val === '...' && last !== '...') result.push('...');
                    else if (val !== '...') result.push(val);
                } else {
                    result.push(val);
                }
                last = val;
            });
            return result;
        }

        function goTo(page) {
            var totalPages = Math.ceil(newsData.length / perPage);
            if (page < 1 || page > totalPages) return;
            curPage = page;
            renderPage(curPage);
            renderPagination(curPage);
            // Scroll to top of news tab
            var tabEl = document.getElementById('tab-news');
            if (tabEl) tabEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function escHtml(str) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(String(str || '')));
            return div.innerHTML;
        }

        // Initial render
        renderPage(curPage);
        renderPagination(curPage);
    });
});
</script>
