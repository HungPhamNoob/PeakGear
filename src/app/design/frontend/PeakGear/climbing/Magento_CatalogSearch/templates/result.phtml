<?php
/**
 * PeakGear Theme - Custom Search Results Page
 */
// @codingStandardsIgnoreFile

use Magento\CatalogSearch\Block\Result;
use Vendor\NewsRss\Block\News as NewsBlock;

/** @var $block Result */
$productList = $block->getProductListHtml();

// Search Query Text — dùng trực tiếp helper để lấy đúng từ khóa (tránh getSearchQueryText() trả về chuỗi tiếng Anh)
$queryTextRaw = \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\CatalogSearch\Helper\Data::class)->getEscapedQueryText();
$queryText = $block->escapeHtml($queryTextRaw);

// News Module Logic
$filteredNews = [];
$newsBlock = null;

try {
    $newsBlock = $this->getLayout()->createBlock(NewsBlock::class);
    if ($newsBlock) {
        $newsItems = $newsBlock->getNewsItems();
        $queryLower = mb_strtolower((string)$queryTextRaw);

        foreach ($newsItems as $item) {
            $title = mb_strtolower($item['title'] ?? '');
            $desc = mb_strtolower($item['description'] ?? '');

            if (empty($queryLower) || mb_strpos($title, $queryLower) !== false || mb_strpos($desc, $queryLower) !== false) {
                $filteredNews[] = $item;
            }
        }
    }
} catch (\Exception $e) {
    // Gracefully handle if module is missing or error happens
}

$productCount = $block->getResultCount();
$newsCount = count($filteredNews);

// Encode news for JS pagination
$newsJson = json_encode(array_map(function($item) use ($block, $newsBlock) {
    return [
        'title'       => $item['title'] ?? '',
        'link'        => $item['link'] ?? '#',
        'description' => $newsBlock ? $newsBlock->truncateText((string)($item['description'] ?? ''), 160) : ($item['description'] ?? ''),
        'pub_date'    => $newsBlock ? $newsBlock->formatPubDate((string)($item['pub_date'] ?? '')) : ($item['pub_date'] ?? ''),
        'image_url'   => $item['image_url'] ?? '',
    ];
}, $filteredNews));
?>

<div class="custom-search-results">
    <div class="search-header-container">
        <h1 class="page-title">
            Kết quả tìm kiếm cho: <span class="search-highlight">"<?= /* @noEscape */ $queryText ?>"</span>
        </h1>
        <p class="search-summary">Hiển thị kết quả từ sản phẩm và tin bài.</p>
    </div>

    <div class="search-tabs-navigation">
        <button class="search-tab-btn active" data-target="tab-products" id="btn-tab-products">
            Sản phẩm (<?= (int)$productCount ?>)
        </button>
        <button class="search-tab-btn" data-target="tab-news" id="btn-tab-news">
            Bài viết (<?= (int)$newsCount ?>)
        </button>
    </div>

    <!-- TAB 1: PRODUCTS — always rendered, empty state shown when no results -->
    <div class="search-tab-content active" id="tab-products">
        <?php if ($productCount) : ?>

            <div class="search results">
                <?php if ($messages = $block->getNoteMessages()) : ?>
                    <div class="message notice">
                        <div>
                            <?php foreach ($messages as $message) : ?>
                                <?= /* @noEscape */ $message ?><br />
                            <?php endforeach; ?>
                        </div>
                    </div>
                <?php endif; ?>
                <?= /* @noEscape */ $productList ?>
            </div>
        <?php else : ?>
            <!-- Empty state for products -->
            <div class="search-empty-state" id="search-empty-products">
                <div class="search-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
                        <circle cx="28" cy="28" r="18" stroke="#f59e0b" stroke-width="3"/>
                        <line x1="41" y1="41" x2="56" y2="56" stroke="#f59e0b" stroke-width="3" stroke-linecap="round"/>
                        <line x1="20" y1="28" x2="36" y2="28" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round"/>
                        <line x1="28" y1="20" x2="28" y2="36" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="search-empty-title">Không tìm thấy sản phẩm</h3>
                <p class="search-empty-desc">
                    Không có sản phẩm nào khớp với từ khóa <strong>"<?= /* @noEscape */ $queryText ?>"</strong>.<br>
                    Hãy thử tìm kiếm với từ khóa khác hoặc điều chỉnh bộ lọc.
