        // Helmet / Hat
        if (str_contains($normalized, 'nón') || str_contains($normalized, 'non') || str_contains($normalized, 'mũ') || str_contains($normalized, 'mu') || str_contains($normalized, 'helmet') || str_contains($normalized, 'bảo hiểm')) {
