</div>

<script>
var mobileCategoriesData = <?= json_encode($mobileCategoriesJson, JSON_UNESCAPED_UNICODE) ?>;
document.addEventListener('DOMContentLoaded', function() {
    if (window.peakgearCategoryMenuReady) {
        return;
    }
    window.peakgearCategoryMenuReady = true;
    window.mobileCategoryCache = window.mobileCategoryCache || {};

    var mobileSidebarItems = document.querySelectorAll('.category-sidebar-item');
    var mobileMainTitle = document.getElementById('mobileMainTitle');
    var mobileMainViewAll = document.getElementById('mobileMainViewAll');
    var mobileSubcategoryChips = document.getElementById('mobileSubcategoryChips');
    var mobileProductsGrid = document.getElementById('mobileProductsGrid');
    var mobileProductsLoading = document.getElementById('mobileProductsLoading');

    function renderMobileCategoryContent(catId, catName) {
        if (!mobileCategoriesData || !mobileProductsGrid) return;
        
        if (mobileMainTitle) mobileMainTitle.textContent = catName;
        
        if (catId === 'all') {
            if (mobileMainViewAll) mobileMainViewAll.href = '<?= $block->escapeJs($block->getUrl("products")) ?>';
            if (mobileSubcategoryChips) mobileSubcategoryChips.innerHTML = '';
        } else {
            if (mobileMainViewAll) mobileMainViewAll.href = '<?= $block->escapeJs($block->getUrl("products")) ?>?category=' + catId;
            var catData = mobileCategoriesData.find(function(c) { return c.id === catId; });
            if (catData && catData.subcategories && catData.subcategories.length > 0) {
                if (mobileSubcategoryChips) {
                    mobileSubcategoryChips.innerHTML = catData.subcategories.map(function(sub) {
                        return '<a class="category-chip" href="' + (mobileMainViewAll ? mobileMainViewAll.href : '') + '&sub=' + encodeURIComponent(sub.slug) + '">' + window.escapeHtml(sub.name) + '</a>';
                    }).join('');
                }
            } else {
                if (mobileSubcategoryChips) mobileSubcategoryChips.innerHTML = '';
            }
        }

        if (mobileProductsGrid) mobileProductsGrid.innerHTML = '';
        if (mobileProductsLoading) mobileProductsLoading.style.display = 'block';

        if (window.mobileCategoryCache[catId]) {
            if (mobileProductsLoading) mobileProductsLoading.style.display = 'none';
            if (mobileProductsGrid) mobileProductsGrid.innerHTML = window.mobileCategoryCache[catId];
            return;
        }

        var query = '';
        if (catId !== 'all') {
            query = 'query { products(filter: { category_id: { eq: "' + catId + '" } }, pageSize: 10) { items { name url_key url_suffix price_range { minimum_price { final_price { value currency } } } image { url label } } } }';
        } else {
            query = 'query { products(search: "", pageSize: 10) { items { name url_key url_suffix price_range { minimum_price { final_price { value currency } } } image { url label } } } }';
        }

        var fetchUrl = '<?= $block->escapeJs($block->getUrl("graphql")) ?>?query=' + encodeURIComponent(query);
        fetch(fetchUrl, {
            method: 'GET',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            if (mobileProductsLoading) mobileProductsLoading.style.display = 'none';
            if (data.data && data.data.products && data.data.products.items && data.data.products.items.length > 0) {
                var products = data.data.products.items.map(function(item) {
                    var value = item.price_range && item.price_range.minimum_price && item.price_range.minimum_price.final_price ? item.price_range.minimum_price.final_price.value : 0;
                    var suffix = item.url_suffix || '.html';
                    var url = item.url_key ? ('<?= $block->escapeJs($block->getBaseUrl()) ?>' + item.url_key + suffix) : window.searchResultBaseUrl + '?q=' + encodeURIComponent(item.name);
                    var img = (item.image && item.image.url) ? item.image.url : '';
                    return { name: item.name || '', url: url, imageUrl: img, price: value };
                });
                
                if (mobileProductsGrid) {
                    var html = products.map(function(p) {
                        return window.buildProductCard(p, mobileMainViewAll ? mobileMainViewAll.href : '');
                    }).join('');
                    mobileProductsGrid.innerHTML = html;
                    window.mobileCategoryCache[catId] = html;
                }
            } else {
                var emptyHtml = '<div class="category-products-empty">Không có sản phẩm nào.</div>';
                if (mobileProductsGrid) mobileProductsGrid.innerHTML = emptyHtml;
                window.mobileCategoryCache[catId] = emptyHtml;
            }
        })
        .catch(function() {
            if (mobileProductsLoading) mobileProductsLoading.style.display = 'none';
            if (mobileProductsGrid) mobileProductsGrid.innerHTML = '<div class="category-products-empty">Lỗi tải sản phẩm.</div>';
        });
    }

    mobileSidebarItems.forEach(function(item) {
        item.addEventListener('click', function(e) {
            e.preventDefault();
            var catId = this.getAttribute('data-cat-id');
            var catName = this.querySelector('.category-sidebar-name').textContent;
            
            mobileSidebarItems.forEach(function(btn) { btn.classList.remove('active'); });
            this.classList.add('active');
            
            renderMobileCategoryContent(catId, catName);
        });
    });

    // Initial render for "Tất cả"
    if (mobileSidebarItems.length > 0) {
        renderMobileCategoryContent('all', 'Tất cả sản phẩm');
    }

    // Laptop Hover logic
    var desktopCategoryContainer = document.getElementById('desktopCategoryContainer');
    var desktopCategoryTrigger = document.getElementById('desktopCategoryTrigger');
    var categoryMenu = document.getElementById('categoryMenu');
    var desktopHoverTimeout;

    function openCategoryMenu() {
        clearTimeout(desktopHoverTimeout);
        categoryMenu.classList.add('open');
        categoryMenu.setAttribute('aria-hidden', 'false');
        if (desktopCategoryTrigger) {
            desktopCategoryTrigger.setAttribute('aria-expanded', 'true');
        }
    }

    function closeCategoryMenu(delay) {
        clearTimeout(desktopHoverTimeout);
        desktopHoverTimeout = setTimeout(function() {
            categoryMenu.classList.remove('open');
            categoryMenu.setAttribute('aria-hidden', 'true');
            if (desktopCategoryTrigger) {
                desktopCategoryTrigger.setAttribute('aria-expanded', 'false');
            }
        }, delay || 0);
    }

    if (desktopCategoryContainer && categoryMenu) {
        desktopCategoryContainer.addEventListener('mouseenter', function() {
            if(window.innerWidth >= 768) {
                openCategoryMenu();
            }
        });
        desktopCategoryContainer.addEventListener('mouseleave', function() {
            if(window.innerWidth >= 768) {
                closeCategoryMenu(150);
            }
        });
        if (desktopCategoryTrigger) {
            desktopCategoryTrigger.setAttribute('aria-expanded', 'false');
            desktopCategoryTrigger.addEventListener('click', function(e) {
                if (window.innerWidth < 768) {
                    return;
                }
                e.preventDefault();
                if (categoryMenu.classList.contains('open')) {
                    closeCategoryMenu(0);
                } else {
                    openCategoryMenu();
                }
            });
        }
        categoryMenu.addEventListener('mouseenter', function() {
            if(window.innerWidth >= 768) {
                clearTimeout(desktopHoverTimeout);
            }
        });
        categoryMenu.addEventListener('mouseleave', function() {
            if(window.innerWidth >= 768) {
                closeCategoryMenu(150);
            }
        });
        document.addEventListener('click', function(e) {
            if (
                window.innerWidth >= 768 &&
                categoryMenu.classList.contains('open') &&
                !categoryMenu.contains(e.target) &&
                !desktopCategoryContainer.contains(e.target)
            ) {
                closeCategoryMenu(0);
            }
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && categoryMenu.classList.contains('open')) {
                closeCategoryMenu(0);
            }
        });
    }
});
</script>
