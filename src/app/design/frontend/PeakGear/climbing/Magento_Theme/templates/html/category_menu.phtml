$mobileCategoriesJson = array_map(function($cat) {
    return [
        'id' => (string)($cat['id'] ?? ''),
        'name' => (string)($cat['name'] ?? ''),
        'subcategories' => array_map(function($sub) {
            return [
                'name' => (string)($sub['name'] ?? ''),
                'slug' => (string)($sub['slug'] ?? '')
            ];
        }, $cat['subcategories'] ?? []),
    ];
}, $categories);
