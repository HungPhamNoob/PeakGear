<script>
document.addEventListener('DOMContentLoaded', function() {
    var header = document.getElementById('peakgear-header');
    var categoryDropdown = document.getElementById('categoryDropdown');
    var categoryPanel = document.getElementById('categoryPanel');
    var subcategoriesPanel = document.getElementById('subcategoriesPanel');
    var searchToggle = document.getElementById('searchToggle');
    var searchPanel = document.getElementById('searchPanel');
    var searchClose = document.getElementById('searchClose');
    var mobileMenuToggle = document.getElementById('mobileMenuToggle');
    var mobileMenu = document.getElementById('mobileMenu');
    var mobileCategoryToggle = document.getElementById('mobileCategoryToggle');
    var mobileCategoryContent = document.getElementById('mobileCategoryContent');
    var accountDropdown = document.getElementById('accountDropdown');
    var accountPanel = document.getElementById('accountPanel');

    // Sticky header
    var lastScrollTop = 0;
    window.addEventListener('scroll', function() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (Math.abs(lastScrollTop - scrollTop) <= 5) return;
        if (scrollTop > lastScrollTop && scrollTop > 80) {
            header.classList.add('header-hidden');
        } else {
            header.classList.remove('header-hidden');
            if (scrollTop > 100) {
                header.classList.add('header-scrolled');
            } else {
                header.classList.remove('header-scrolled');
            }
        }
        lastScrollTop = scrollTop;
    });

    // Desktop category dropdown
    var dropdownTimeout;
    categoryDropdown.addEventListener('mouseenter', function() {
        clearTimeout(dropdownTimeout);
        categoryPanel.classList.add('open');
    });
    categoryDropdown.addEventListener('mouseleave', function() {
        dropdownTimeout = setTimeout(function() {
            categoryPanel.classList.remove('open');
            // Hide all subcategory groups
            var groups = subcategoriesPanel.querySelectorAll('.subcategory-group');
            groups.forEach(function(g) { g.classList.remove('active'); });
            subcategoriesPanel.classList.remove('open');
            // Remove active from all items
            var items = categoryDropdown.querySelectorAll('.dropdown-item');
            items.forEach(function(i) { i.classList.remove('active'); });
        }, 100);
    });

    // Category hover -> show subcategories
    var categoryItems = categoryDropdown.querySelectorAll('.dropdown-item[data-category]');
    categoryItems.forEach(function(item) {
        item.addEventListener('mouseenter', function() {
            var slug = this.getAttribute('data-category');
            // Remove active from all items
            categoryItems.forEach(function(i) { i.classList.remove('active'); });
            this.classList.add('active');

            if (slug) {
                // Show subcategories panel
                subcategoriesPanel.classList.add('open');
                var groups = subcategoriesPanel.querySelectorAll('.subcategory-group');
                groups.forEach(function(g) { g.classList.remove('active'); });
                var target = subcategoriesPanel.querySelector('[data-subcategory="' + slug + '"]');
                if (target) target.classList.add('active');
            } else {
                // "All Products" item - hide subcategories
                subcategoriesPanel.classList.remove('open');
                var groups = subcategoriesPanel.querySelectorAll('.subcategory-group');
                groups.forEach(function(g) { g.classList.remove('active'); });
            }
        });
    });

    // Account dropdown (desktop) - click toggle
    var accountDropdownOpen = false;
    if (accountDropdown && accountPanel) {
        var accountToggle = accountDropdown.querySelector('.account-toggle');
        if (accountToggle) {
            accountToggle.addEventListener('click', function(e) {
                if (accountDropdown.getAttribute('data-logged-in') === 'false') {
                    window.location.href = '<?= $block->escapeUrl($block->getUrl('customer/account/login')) ?>';
                    return;
                }
                e.preventDefault();
                e.stopPropagation();
                accountDropdownOpen = !accountDropdownOpen;
                if (accountDropdownOpen) {
                    accountPanel.classList.add('open');
                } else {
                    accountPanel.classList.remove('open');
                }
            });
        }

        // Prevent clicks inside the panel from closing it
        accountPanel.addEventListener('click', function(e) {
            e.stopPropagation();
        });

        // Close when clicking outside
        document.addEventListener('click', function(e) {
            if (accountDropdownOpen && !accountDropdown.contains(e.target)) {
                accountDropdownOpen = false;
                accountPanel.classList.remove('open');
            }
        });

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && accountDropdownOpen) {
                accountDropdownOpen = false;
                accountPanel.classList.remove('open');
            }
        });
    }

    // Search toggle
    var searchOpen = false;
    searchToggle.addEventListener('click', function() {
        searchOpen = !searchOpen;
        if (searchOpen) {
            searchPanel.classList.add('open');
            var input = searchPanel.querySelector('.search-input');
            if (input) input.focus();
        } else {
            searchPanel.classList.remove('open');
        }
    });
    if (searchClose) {
        searchClose.addEventListener('click', function() {
            searchOpen = false;
            searchPanel.classList.remove('open');
        });
    }

    // Mobile menu toggle
    var mobileOpen = false;
    var menuIcon = mobileMenuToggle.querySelector('.mobile-menu-icon');
    var closeIcon = mobileMenuToggle.querySelector('.mobile-close-icon');
    mobileMenuToggle.addEventListener('click', function() {
        mobileOpen = !mobileOpen;
        if (mobileOpen) {
            mobileMenu.classList.add('open');
            menuIcon.style.display = 'none';
            closeIcon.style.display = 'block';
            document.body.classList.add('mobile-menu-active');
        } else {
            mobileMenu.classList.remove('open');
            menuIcon.style.display = 'block';
            closeIcon.style.display = 'none';
            document.body.classList.remove('mobile-menu-active');
        }
    });

    // Mobile category toggle
    var mobileCatOpen = false;
    mobileCategoryToggle.addEventListener('click', function() {
        mobileCatOpen = !mobileCatOpen;
        var chevron = this.querySelector('.mobile-chevron');
        if (mobileCatOpen) {
            mobileCategoryContent.classList.add('open');
            if (chevron) chevron.classList.add('rotate');
        } else {
            mobileCategoryContent.classList.remove('open');
            if (chevron) chevron.classList.remove('rotate');
        }
    });

    // Mobile subcategory toggles
    var mobileCatToggles = document.querySelectorAll('.mobile-category-toggle');
    mobileCatToggles.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var slug = this.getAttribute('data-mobile-category');
            var subcats = document.querySelector('[data-mobile-subcategory="' + slug + '"]');
            var chevron = this.querySelector('.mobile-category-chevron');
            
            if (subcats.classList.contains('open')) {
                subcats.classList.remove('open');
                if (chevron) chevron.classList.remove('rotate');
            } else {
                // Close others
                document.querySelectorAll('.mobile-subcategories.open').forEach(function(el) {
                    el.classList.remove('open');
                });
                document.querySelectorAll('.mobile-category-chevron.rotate').forEach(function(el) {
                    el.classList.remove('rotate');
                });
                subcats.classList.add('open');
                if (chevron) chevron.classList.add('rotate');
            }
        });
    });

    // Customer data integration (Magento)
    try {
        require(['Magento_Customer/js/customer-data'], function(customerData) {
            function applyCustomerState(data) {
                var fullName = (data && (data.fullname || data.firstname || '') || '').toString().trim();
                var email = (data && data.email || '').toString();
                var isLogged = !!(data && (fullName || email || data.firstname));

                if (isLogged) {
                    var initial = fullName ? fullName.charAt(0).toUpperCase() : 'U';

                    document.getElementById('accountAvatar').textContent = initial;
                    document.getElementById('accountName').textContent = fullName || 'Tài khoản';
                    document.getElementById('accountEmail').textContent = email;
                    document.getElementById('accountDropdown').setAttribute('data-logged-in', 'true');
                    document.getElementById('authButtons').style.display = 'none';

                    document.getElementById('mobileAuthAvatar').textContent = initial;
                    document.getElementById('mobileAuthName').textContent = fullName || 'Tài khoản';
                    document.getElementById('mobileAuthEmail').textContent = email;
                    document.getElementById('mobileAuthLoggedIn').style.display = '';
                    document.getElementById('mobileAuthButtons').style.display = 'none';
                    return;
                }

                document.getElementById('accountAvatar').innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" style="display:block;margin:auto;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
                document.getElementById('accountDropdown').setAttribute('data-logged-in', 'false');
                document.getElementById('authButtons').style.display = '';
                document.getElementById('mobileAuthLoggedIn').style.display = 'none';
                document.getElementById('mobileAuthButtons').style.display = '';
            }

            var customer = customerData.get('customer');
            customer.subscribe(function(data) {
                applyCustomerState(data || {});
            });

            // Check initial value
            applyCustomerState(customer() || {});
        });
    } catch(e) {}

    // Minicart counter
    try {
        require(['Magento_Customer/js/customer-data'], function(customerData) {
            var cart = customerData.get('cart');
            cart.subscribe(function(data) {
                var counter = document.getElementById('minicartCounter');
                if (data && data.summary_count > 0) {
                    counter.textContent = data.summary_count;
                    counter.style.display = '';
                } else {
                    counter.style.display = 'none';
                }
            });
        });
    } catch(e) {}
});
</script>
