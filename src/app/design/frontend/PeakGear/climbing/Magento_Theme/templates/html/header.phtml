    var searchOverlayInput = document.getElementById('searchOverlayInput');
    var searchOverlayClose = document.getElementById('searchOverlayClose');
    var searchOverlayDefault = document.getElementById('searchOverlayDefault');
    var searchOverlayResults = document.getElementById('searchOverlayResults');
    var searchKeywordSection = document.getElementById('searchKeywordSection');
    var searchKeywordChips = document.getElementById('searchKeywordChips');
    var searchSuggestionList = document.getElementById('searchSuggestionList');
    var searchResultGrid = document.getElementById('searchResultGrid');
    var searchViewAll = document.getElementById('searchViewAll');
    var searchEmptyState = document.getElementById('searchEmptyState');
    var categoryMenu = document.getElementById('categoryMenu');
    var appBottomNav = document.getElementById('appBottomNav');
    var appNavCategory = document.getElementById('appNavCategory');
    var appNavSearch = document.getElementById('appNavSearch');
    var mobileOpen = false;
    var mobileCategoryToggle = document.getElementById('mobileCategoryToggle');
    var mobileCategoryContent = document.getElementById('mobileCategoryContent');
    var accountDropdown = document.getElementById('accountDropdown');
    var accountPanel = document.getElementById('accountPanel');
    var searchSuggestions = <?= /* @noEscape */ json_encode($searchSuggestions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    var searchProducts = <?= /* @noEscape */ json_encode(array_map(static function (array $product): array {
        return [
            'name' => (string)($product['name'] ?? ''),
            'url' => (string)($product['url'] ?? ''),
            'imageUrl' => (string)($product['imageUrl'] ?? ''),
            'price' => isset($product['price']) ? (float)$product['price'] : 0,
            'category' => (string)($product['category'] ?? '')
        ];
    }, $searchFeaturedProducts), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    window.searchResultBaseUrl = '<?= $block->escapeJs($block->getUrl("catalogsearch/result")) ?>';

    // Sticky header
    var lastScrollTop = 0;
    window.addEventListener('scroll', function() {
        if (mobileOpen) {
            return;
        }
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (Math.abs(lastScrollTop - scrollTop) <= 5) return;
        if (scrollTop > lastScrollTop && scrollTop > 80) {
            header.classList.add('header-hidden');
        } else {
            header.classList.remove('header-hidden');
            if (scrollTop > 100) {
                header.classList.add('header-scrolled');
            } else {
                header.classList.remove('header-scrolled');
            }
        }
        lastScrollTop = scrollTop;
    });

    function updateCategoryMenuViewport() {
        if (!categoryMenu) {
            return;
        }

        var headerHeight = header ? Math.ceil(header.getBoundingClientRect().height) : 72;
        var bottomNavHeight = appBottomNav && window.getComputedStyle(appBottomNav).display !== 'none'
            ? Math.ceil(appBottomNav.getBoundingClientRect().height)
            : 0;

        categoryMenu.style.setProperty('--pg-category-menu-top', headerHeight + 'px');
        categoryMenu.style.setProperty('--pg-bottom-nav-height', bottomNavHeight + 'px');
    }

    // Account dropdown (desktop) - click toggle
    var accountDropdownOpen = false;
    if (accountDropdown && accountPanel) {
        var accountToggle = accountDropdown.querySelector('.account-toggle');
        if (accountToggle) {
            accountToggle.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                accountDropdownOpen = !accountDropdownOpen;
                if (accountDropdownOpen) {
                    accountPanel.classList.add('open');
                } else {
                    accountPanel.classList.remove('open');
                }
            });
        }

        // Prevent clicks inside the panel from closing it
        accountPanel.addEventListener('click', function(e) {
            e.stopPropagation();
        });

        // Close when clicking outside
        document.addEventListener('click', function(e) {
            if (accountDropdownOpen && !accountDropdown.contains(e.target)) {
                accountDropdownOpen = false;
                accountPanel.classList.remove('open');
            }
        });

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && accountDropdownOpen) {
                accountDropdownOpen = false;
                accountPanel.classList.remove('open');
            }
        });
    }

    // Close category menu when clicking overlay/outside
    document.addEventListener('click', function(e) {
            if (mobileOpen && categoryMenu && !categoryMenu.contains(e.target) && (!appNavCategory || !appNavCategory.contains(e.target))) {
                mobileOpen = false;
                categoryMenu.classList.remove('open');
            categoryMenu.setAttribute('aria-hidden', 'true');
            if (appNavCategory) appNavCategory.classList.remove('active');
            document.body.classList.remove('mobile-menu-active');
        }
    });

    window.addEventListener('resize', function() {
        if (mobileOpen) {
            updateCategoryMenuViewport();
        }
    });

    var searchOpen = false;
    var searchDebounceTimer = null;

    window.escapeHtml = function(value) {
        return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    };

    window.formatPrice = function(value, currency) {
        if (typeof value !== 'number' || isNaN(value)) {
            return '';
        }

        try {
            return new Intl.NumberFormat('vi-VN', {
                style: 'currency',
                currency: currency || 'VND',
                maximumFractionDigits: 0
            }).format(value);
        } catch (error) {
            return value.toLocaleString('vi-VN') + ' ' + (currency || 'VND');
        }
    };

    window.buildProductCard = function(item, fallbackUrl) {
        var imageUrl = item.imageUrl || '';
        var amount = typeof item.price === 'number' ? item.price : null;
        var productUrl = item.url || (fallbackUrl || window.searchResultBaseUrl);

        return '<a class="search-result-card" href="' + window.escapeHtml(productUrl) + '">' +
            '<span class="search-result-image">' +
                (imageUrl ? '<img src="' + window.escapeHtml(imageUrl) + '" alt="' + window.escapeHtml(item.name) + '" loading="lazy">' : '<span class="search-result-image-fallback">PeakGear</span>') +
            '</span>' +
            '<span class="search-result-content">' +
                '<span class="search-result-name">' + window.escapeHtml(item.name) + '</span>' +
                '<span class="search-result-price">' + window.escapeHtml(window.formatPrice(amount, 'VND')) + '</span>' +
            '</span>' +
        '</a>';
    };

    function renderDefaultSuggestions(items) {
        if (!searchSuggestionList) {
            return;
        }

        if (items && items.length) {
            searchSuggestionList.innerHTML = items.map(function (item) {
                return buildProductCard(item, '<?= $block->escapeJs($block->getUrl('products')) ?>');
            }).join('');
            return;
        }

        searchSuggestionList.innerHTML = searchSuggestions.map(function (item) {
            return '<a class="search-chip search-chip-keyword" href="' + escapeHtml(item.url) + '">' + escapeHtml(item.label) + '</a>';
        }).join('');
    }

    function renderKeywordSuggestions(items) {
        if (!searchKeywordChips || !searchKeywordSection) {
            return;
        }

        if (!items.length) {
            searchKeywordSection.hidden = true;
            searchKeywordChips.innerHTML = '';
            return;
        }

        searchKeywordSection.hidden = false;
        searchKeywordChips.innerHTML = items.map(function (item) {
            var label = item.title || item.label || '';
            var href = item.url || (searchResultBaseUrl + '?q=' + encodeURIComponent(label));
            return '<a class="search-chip search-chip-keyword" href="' + escapeHtml(href) + '">' + escapeHtml(label) + '</a>';
        }).join('');
    }

    function renderProductResults(items, query) {
        if (!searchResultGrid || !searchViewAll || !searchEmptyState) {
            return;
        }

        searchViewAll.href = searchResultBaseUrl + '?q=' + encodeURIComponent(query);

        if (!items.length) {
            searchResultGrid.innerHTML = '';
            searchEmptyState.hidden = false;
            return;
        }

        searchEmptyState.hidden = true;
        searchResultGrid.innerHTML = items.map(function (item) {
            return buildProductCard(item, searchResultBaseUrl + '?q=' + encodeURIComponent(query));
        }).join('');
    }

    function setSearchMode(hasQuery) {
        if (!searchOverlayDefault || !searchOverlayResults) {
            return;
        }

        if (hasQuery) {
            searchOverlayDefault.hidden = true;
            searchOverlayResults.hidden = false;
        } else {
            searchOverlayDefault.hidden = false;
            searchOverlayResults.hidden = true;
        }
    }

    function closeSearchOverlay() {
        if (!searchOverlay || !searchTrigger) {
            return;
        }

        searchOpen = false;
        searchOverlay.classList.remove('open');
        searchOverlay.setAttribute('aria-hidden', 'true');
        searchTrigger.setAttribute('aria-expanded', 'false');
        if (appNavSearch) {
            appNavSearch.classList.remove('active');
        }
        document.body.classList.remove('search-overlay-active');
    }

    function openSearchOverlay() {
        if (!searchOverlay || !searchTrigger) {
            return;
        }

        if (mobileOpen && categoryMenu) {
            mobileOpen = false;
            categoryMenu.classList.remove('open');
            categoryMenu.setAttribute('aria-hidden', 'true');
            if (appNavCategory) {
                appNavCategory.classList.remove('active');
            }
            document.body.classList.remove('mobile-menu-active');
        }

        searchOpen = true;
        searchOverlay.classList.add('open');
        searchOverlay.setAttribute('aria-hidden', 'false');
        searchTrigger.setAttribute('aria-expanded', 'true');
        document.body.classList.add('search-overlay-active');
        setSearchMode(!!(searchOverlayInput && searchOverlayInput.value.trim()));

        if (searchOverlayInput && searchOverlayInput.value.trim()) {
            handleSearchInput();
        }

        window.setTimeout(function () {
            if (searchOverlayInput) {
                searchOverlayInput.focus();
                searchOverlayInput.select();
            }
        }, 60);
    }

    function fetchKeywordSuggestions(query) {
        return fetch('<?= $block->escapeJs($block->getUrl("search/ajax/suggest")) ?>?q=' + encodeURIComponent(query))
            .then(function(res) { return res.json(); })
            .then(function(data) {
                return data.map(function(item) {
                    return {
                        title: item.title,
                        url: searchResultBaseUrl + '?q=' + encodeURIComponent(item.title)
                    };
                });
            })
            .catch(function() { return []; });
    }

    function fetchProductResults(query) {
        var graphqlQuery = 'query { products(search: "' + query.replace(/"/g, '\\"') + '", pageSize: 10) { items { name url_key url_suffix price_range { minimum_price { final_price { value currency } } } image { url label } } } }';

        return fetch('<?= $block->escapeJs($block->getUrl("graphql")) ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ query: graphqlQuery })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            if (data.data && data.data.products && data.data.products.items) {
                return data.data.products.items.map(function(item) {
                    var currency = item.price_range && item.price_range.minimum_price && item.price_range.minimum_price.final_price && item.price_range.minimum_price.final_price.currency ? item.price_range.minimum_price.final_price.currency : 'VND';
                    var value = item.price_range && item.price_range.minimum_price && item.price_range.minimum_price.final_price && item.price_range.minimum_price.final_price.value ? item.price_range.minimum_price.final_price.value : 0;
                    var suffix = item.url_suffix || '.html';
                    var url = item.url_key ? ('<?= $block->escapeJs($block->getBaseUrl()) ?>' + item.url_key + suffix) : searchResultBaseUrl + '?q=' + encodeURIComponent(item.name);
                    
                    return {
                        name: item.name || '',
                        url: url,
                        imageUrl: (item.image && item.image.url) ? item.image.url : '',
                        price: value
                    };
                });
            }
            return [];
        })
        .catch(function() { return []; });
    }

    function handleSearchInput() {
        var query = searchOverlayInput ? searchOverlayInput.value.trim() : '';

        window.clearTimeout(searchDebounceTimer);

        if (!query) {
            setSearchMode(false);
            renderKeywordSuggestions([]);
            searchResultGrid.innerHTML = '';
            searchEmptyState.hidden = true;
            return;
        }

        setSearchMode(true);
        searchResultGrid.innerHTML = '<div style="grid-column: 1 / -1; padding: 20px 0; text-align: center; color: #9ca3af;">Đang tìm kiếm...</div>';
        searchEmptyState.hidden = true;

        searchDebounceTimer = window.setTimeout(function () {
            if (!searchOverlayInput || searchOverlayInput.value.trim() !== query) {
                return;
            }

            Promise.all([
                fetchKeywordSuggestions(query),
                fetchProductResults(query)
            ]).then(function(results) {
                var keywords = results[0];
                var products = results[1];

                if (searchOverlayInput && searchOverlayInput.value.trim() !== query) {
                    return;
                }

                renderKeywordSuggestions(keywords);
                renderProductResults(products, query);
            });
        }, 300);
    }

    renderDefaultSuggestions(searchProducts);

    if (searchTrigger && searchOverlay) {
        searchTrigger.addEventListener('click', function () {
            if (searchOpen) {
                closeSearchOverlay();
            } else {
                openSearchOverlay();
            }
        });
    }

    if (searchOverlayClose) {
        searchOverlayClose.addEventListener('click', closeSearchOverlay);
    }

    if (searchOverlay) {
        searchOverlay.addEventListener('click', function (event) {
            if (event.target.hasAttribute('data-search-close')) {
                closeSearchOverlay();
            }
        });
    }

    if (searchOverlayInput) {
        searchOverlayInput.addEventListener('input', handleSearchInput);
    }

    // Customer data integration (Magento)
    try {
        require(['Magento_Customer/js/customer-data'], function(customerData) {
            function applyCustomerState(data) {
                var fullName = (data && (data.fullname || data.firstname || '') || '').toString().trim();
                var email = (data && data.email || '').toString();
                var isLogged = !!(data && (fullName || email || data.firstname));

                if (isLogged) {
                    var initial = fullName ? fullName.charAt(0).toUpperCase() : 'U';

                    // Desktop account dropdown
                    document.getElementById('accountAvatar').textContent = initial;
                    document.getElementById('accountName').textContent = fullName || 'Tài khoản';
                    document.getElementById('accountEmail').textContent = email;
                    document.getElementById('accountDropdown').setAttribute('data-logged-in', 'true');
                    document.getElementById('accountDropdown').style.display = '';
                    document.getElementById('authButtons').style.display = 'none';

                    // Mobile: hide entire auth section (account is in header dropdown)
                    var mobileAuth = document.getElementById('mobileAuth');
                    if (mobileAuth) mobileAuth.style.display = 'none';
                    return;
                }

                // Not logged in
                document.getElementById('accountDropdown').setAttribute('data-logged-in', 'false');
                document.getElementById('accountDropdown').style.display = 'none';
                document.getElementById('authButtons').style.display = '';
                var mobileAuth = document.getElementById('mobileAuth');
                if (mobileAuth) mobileAuth.style.display = '';
                var mobileAuthButtons = document.getElementById('mobileAuthButtons');
                if (mobileAuthButtons) mobileAuthButtons.style.display = '';
            }

            var customer = customerData.get('customer');
            customer.subscribe(function(data) {
                applyCustomerState(data || {});
            });

            // Check initial value
            applyCustomerState(customer() || {});
        });
    } catch(e) {}

    // Minicart counter
    try {
        require(['Magento_Customer/js/customer-data'], function(customerData) {
            var cart = customerData.get('cart');
            cart.subscribe(function(data) {
                var counter = document.getElementById('minicartCounter');
                if (data && data.summary_count > 0) {
                    counter.textContent = data.summary_count;
                    counter.style.display = '';
                }
            });
        });
    } catch(e) {}

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && searchOpen) {
            closeSearchOverlay();
        }
    });

    // (Desktop hover logic moved to category_menu.phtml)
    // App Bottom Nav Logic

    if (appNavSearch) {
        appNavSearch.addEventListener('click', function(e) {
            e.preventDefault();
            if (searchOpen) {
                closeSearchOverlay();
                appNavSearch.classList.remove('active');
            } else {
                openSearchOverlay();
                appNavSearch.classList.add('active');
            }
        });
    }

    // App Bottom Nav Category Trigger active state toggle
    if (appNavCategory) {
        appNavCategory.addEventListener('click', function(e) {
            e.preventDefault();
            if (!categoryMenu) {
                return;
            }
            if (searchOpen) {
                closeSearchOverlay();
            }
            mobileOpen = !mobileOpen;
            if (mobileOpen) {
                header.classList.remove('header-hidden');
                updateCategoryMenuViewport();
                categoryMenu.classList.add('open');
                categoryMenu.setAttribute('aria-hidden', 'false');
                document.body.classList.add('mobile-menu-active');
                appNavCategory.classList.add('active');
            } else {
                categoryMenu.classList.remove('open');
                categoryMenu.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('mobile-menu-active');
                appNavCategory.classList.remove('active');
            }
        });
    }


});
</script>
