<?php
/**
 * PeakGear Climbing Theme - Header Template
 * Dynamic categories loaded from Magento catalog database
 *
 * @var \PeakGear\Catalog\Block\CategoryList|\Magento\Framework\View\Element\Template $block
 */
$logoAlt = $block->getData('logo_alt') ?: 'PeakGear';
$baseUrl = $block->getBaseUrl();

// Dynamic categories from database via CategoryList block
$categories = $block->getCategories();
$isLoggedIn = method_exists($block, 'isCustomerLoggedIn') ? (bool)$block->isCustomerLoggedIn() : false;
$searchSuggestions = [];
$searchFeaturedProducts = [];

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
try {
    /** @var \PeakGear\Catalog\Block\FeaturedProducts $featuredProductsBlock */
    $featuredProductsBlock = $objectManager->create(\PeakGear\Catalog\Block\FeaturedProducts::class);
    $searchFeaturedProducts = $featuredProductsBlock->getFeaturedProducts(10);
} catch (\Throwable $e) {
    $searchFeaturedProducts = [];
}

foreach ($categories as $cat) {
    $categoryUrl = $block->getUrl('products') . '?category=' . (int)$cat['id'];
    $searchSuggestions[] = [
        'label' => (string)$cat['name'],
        'url' => $categoryUrl
    ];

    foreach ($cat['subcategories'] as $sub) {
        $searchSuggestions[] = [
            'label' => (string)$sub['name'],
            'url' => $block->getUrl('products') . '?category=' . (int)$cat['id'] . '&sub=' . $block->escapeHtmlAttr($sub['slug'])
        ];
    }
}

$searchSuggestions = array_slice($searchSuggestions, 0, 12);
?>

