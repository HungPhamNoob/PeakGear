/**
 * PeakGear Catalog - All Products Page Template
 * Matches React design: hero banner, toolbar, sidebar filters, product grid
 * Supports category mode: dynamic title, conditional filters, attribute filters
 *
 * @var \PeakGear\Catalog\Block\AllProducts $block
 */

$products = $block->getProductCollection();
$categories = $block->getCategories();
$currentSort = $block->getCurrentSort();
$currentCategory = $block->getCurrentCategory();
$brands = $block->getBrands();
$currentBrand = $block->getCurrentBrand();
$productCount = $products->getSize();
$searchQuery = trim((string)$block->getRequest()->getParam('q', ''));

// Category mode
$isCategoryMode = $block->isCategoryMode();
$pageTitle = $block->getPageTitle();
$pageDescription = $block->getPageDescription();

// Get Dynamic Price Range
$priceRange = $block->getPriceRange();
$rangeMin = $priceRange['min'];
$rangeMax = $priceRange['max'];

// Dynamic filterable attributes (color, size, etc.)
$filterableAttributes = $block->getFilterableAttributes();

// Build active filters list for tag display
$activeFilters = [];
$baseFilterUrl = $block->getUrl('products');

// Category filter tag (only when viewing "all products" with a category selected, not in category-mode from header)
if ($isCategoryMode) {
    $catInfo = $block->getCurrentCategoryInfo();
    if ($catInfo) {
        $activeFilters[] = [
            'label' => 'Danh mục: ' . $catInfo['name'],
            'param' => 'category',
            'type' => 'category',
        ];
    }
} elseif ($currentCategory) {
    // In all-products mode but with category sidebar filter selected
    $catName = '';
    foreach ($categories as $c) {
        if ($c['id'] === $currentCategory) { $catName = $c['name']; break; }
    }
    if ($catName) {
        $activeFilters[] = [
            'label' => 'Danh mục: ' . $catName,
            'param' => 'category',
            'type' => 'category',
        ];
    }
}

// Brand filter tag
if ($currentBrand) {
    $brandName = '';
    foreach ($brands as $b) {
        if ($b['id'] === $currentBrand) { $brandName = $b['name']; break; }
    }
    if ($brandName) {
        $activeFilters[] = [
            'label' => 'Thương hiệu: ' . $brandName,
            'param' => 'brand',
            'type' => 'brand',
        ];
    }
}

// Dynamic attribute filter tags
foreach ($filterableAttributes as $attr) {
    $attrVal = $block->getCurrentFilterValue($attr['code']);
    if ($attrVal !== null) {
        $optLabel = '';
        foreach ($attr['options'] as $opt) {
            if ($opt['id'] === $attrVal) { $optLabel = $opt['label']; break; }
        }
        if ($optLabel) {
            $directParams = ['color'];
            $paramKey = in_array($attr['code'], $directParams) ? $attr['code'] : 'attr_' . $attr['code'];
            $activeFilters[] = [
                'label' => $attr['label'] . ': ' . $optLabel,
                'param' => $paramKey,
                'type' => 'attr',
            ];
        }
    }
}

// Sort tag (only if not default)
if ($currentSort !== 'newest') {
    $sortLabels = [
        'price_asc' => 'Giá: Thấp đến cao',
        'price_desc' => 'Giá: Cao đến thấp',
        'name' => 'Tên A-Z',
    ];
    $activeFilters[] = [
        'label' => 'Sắp xếp: ' . ($sortLabels[$currentSort] ?? $currentSort),
        'param' => 'sort',
        'type' => 'sort',
    ];
}

$hasActiveFilters = !empty($activeFilters);
