<script>
document.addEventListener('DOMContentLoaded', function() {
    // Mobile filter sidebar toggle
    var filterToggle = document.getElementById('allprodFilterToggle');
    var sidebar = document.getElementById('allprodSidebar');
    var sidebarClose = document.getElementById('allprodSidebarClose');

    if (filterToggle) {
        filterToggle.addEventListener('click', function() {
            sidebar.classList.add('open');
            document.body.classList.add('allprod-sidebar-active');
        });
    }
    if (sidebarClose) {
        sidebarClose.addEventListener('click', function() {
            sidebar.classList.remove('open');
            document.body.classList.remove('allprod-sidebar-active');
        });
    }

    // View mode toggle
    var gridBtn = document.getElementById('allprodGridView');
    var listBtn = document.getElementById('allprodListView');
    var grid = document.getElementById('allprodGrid');

    if (gridBtn && listBtn && grid) {
        gridBtn.addEventListener('click', function() {
            grid.classList.remove('allprod-grid-list');
            gridBtn.classList.add('active');
            listBtn.classList.remove('active');
        });
        listBtn.addEventListener('click', function() {
            grid.classList.add('allprod-grid-list');
            listBtn.classList.add('active');
            gridBtn.classList.remove('active');
        });
    }

    // Initialize price range slider
    allprodUpdatePriceRange();
});

/**
 * Apply sort filter via URL (preserves other params)
 */
function allprodApplyFilters() {
    var sort = document.getElementById('allprodSort').value;
    var params = new URLSearchParams(window.location.search);
    params.set('sort', sort);
    window.location.href = window.location.pathname + '?' + params.toString();
}

function allprodFilterCategory(catId) {
    var params = new URLSearchParams(window.location.search);
    if (catId) {
        params.set('category', catId);
    } else {
        params.delete('category');
    }
    window.location.href = window.location.pathname + '?' + params.toString();
}

function allprodFilterBrand(brandId) {
    var params = new URLSearchParams(window.location.search);
    if (brandId) {
        params.set('brand', brandId);
    } else {
        params.delete('brand');
    }
    window.location.href = window.location.pathname + '?' + params.toString();
}

/**
 * Filter by a dynamic attribute (color, size, etc.)
 * Sets the attribute value as a direct query param: ?color=5 or ?attr_size=3
 */
function allprodFilterAttr(attrCode, value) {
    var params = new URLSearchParams(window.location.search);

    // Known direct params
    var directParams = ['color'];
    var paramKey = directParams.indexOf(attrCode) !== -1 ? attrCode : 'attr_' + attrCode;

    if (value) {
        params.set(paramKey, value);
    } else {
        params.delete(paramKey);
    }
    window.location.href = window.location.pathname + '?' + params.toString();
}

/**
 * Remove a single filter by its param key.
 * Preserves all other params.
 */
function allprodRemoveFilter(paramKey) {
    var params = new URLSearchParams(window.location.search);
    params.delete(paramKey);
    var qs = params.toString();
    window.location.href = window.location.pathname + (qs ? '?' + qs : '');
}

/**
 * Clear all filters.
 * In category mode (entered via header/homepage link), preserve the category param.
 * In "all products" mode, clear everything.
 */
function allprodClearFilters() {
    var isCategoryMode = <?= $isCategoryMode ? 'true' : 'false' ?>;
    if (isCategoryMode) {
        var params = new URLSearchParams(window.location.search);
        var catId = params.get('category');
        window.location.href = window.location.pathname + (catId ? '?category=' + catId : '');
    } else {
        window.location.href = window.location.pathname;
    }
}

/**
 * Price range slider - client-side filtering (hides/shows cards)
 */
function allprodUpdatePriceRange() {
    var minInput = document.getElementById('allprodRangeMin');
    var maxInput = document.getElementById('allprodRangeMax');
    if (!minInput || !maxInput) return;

    var min = parseInt(minInput.value);
    var max = parseInt(maxInput.value);

    // Prevent crossing
    if (min > max) {
        var temp = min;
        min = max;
        max = temp;
        minInput.value = min;
        maxInput.value = max;
    }

    // Update display
    var minDisplay = document.getElementById('allprodPriceMin');
    var maxDisplay = document.getElementById('allprodPriceMax');
    if (minDisplay) minDisplay.textContent = '$' + min.toLocaleString();
    if (maxDisplay) maxDisplay.textContent = '$' + max.toLocaleString();

    // Update fill bar
    var fill = document.getElementById('allprodRangeFill');
    if (fill) {
        var minBound = parseFloat(minInput.getAttribute('min')) || 0;
        var maxBound = parseFloat(minInput.getAttribute('max')) || 10000;
        var rangeBound = maxBound - minBound;
        
        var leftPercent = 0;
        var rightPercent = 0;
        
        if (rangeBound > 0) {
            leftPercent = ((min - minBound) / rangeBound) * 100;
            rightPercent = 100 - ((max - minBound) / rangeBound) * 100;
        }
        
        fill.style.left = leftPercent + '%';
        fill.style.right = rightPercent + '%';
    }

    // Filter product cards client-side
    var cards = document.querySelectorAll('#allprodGrid .product-card');
    cards.forEach(function(card) {
        var price = parseFloat(card.getAttribute('data-price'));
        if (price >= min && price <= max) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });

    // Update quick-select button active states
    var quickBtns = document.querySelectorAll('.allprod-price-btn');
    quickBtns.forEach(function(btn) { btn.classList.remove('active'); });
}

function allprodSetPriceRange(min, max) {
    var minInput = document.getElementById('allprodRangeMin');
    var maxInput = document.getElementById('allprodRangeMax');
    if (minInput) minInput.value = min;
    if (maxInput) maxInput.value = max;
    allprodUpdatePriceRange();

    // Highlight the clicked quick-select button
    event.target.classList.add('active');
}
</script>
