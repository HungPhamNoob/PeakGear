        </div>
        <?php else: ?>
        <div class="categories-empty">
            <p>Chưa có danh mục nào. Vui lòng thêm danh mục trong Admin Panel.</p>
        </div>
        <?php endif; ?>
    </div>
</section>

<?php if ($totalSlides > 1): ?>
<script>
require(['jquery'], function ($) {
    'use strict';

    $('.categories-slider').each(function () {
        var $slider = $(this);
        var $track = $slider.find('.categories-slider-track').first();
        var $prev = $slider.find('.categories-nav-prev');
        var $next = $slider.find('.categories-nav-next');
        var totalSlides = parseInt($slider.data('total-slides'), 10) || 1;
        var currentSlide = 0;

        function updateSlider() {
            $track.css('transform', 'translate3d(-' + (currentSlide * 100) + '%, 0, 0)');
            $prev.prop('disabled', currentSlide === 0);
            $next.prop('disabled', currentSlide >= totalSlides - 1);
        }

        $prev.on('click', function () {
            if (currentSlide > 0) {
                currentSlide -= 1;
                updateSlider();
            }
        });

        $next.on('click', function () {
            if (currentSlide < totalSlides - 1) {
                currentSlide += 1;
                updateSlider();
            }
        });

        $slider.on('keydown', function (event) {
            if (event.key === 'ArrowLeft') {
                $prev.trigger('click');
            }
            if (event.key === 'ArrowRight') {
                $next.trigger('click');
            }
        });

        updateSlider();
    });
});
</script>
<?php endif; ?>
