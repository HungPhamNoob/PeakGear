<?php
/**
 * Homepage News Carousel
 *
 * @var \Vendor\NewsRss\Block\News $block
 */
$items = array_slice($block->getNewsItems(), 0, 8);
$badge = (string)$block->getData('badge');
$title = (string)$block->getData('title');
$sourceUrl = (string)$block->getData('source_url');
$feedAnchor = 'news-' . $block->getFeedCode();
?>

<section class="home-news-section" data-mage-init='{"js/news-carousel": {}}'>
    <div class="home-news-container">
        <div class="home-news-header">
            <div>
                <span class="home-news-badge"><?= $block->escapeHtml($badge) ?></span>
                <h3 class="home-news-title"><?= $block->escapeHtml($title) ?></h3>
                <p class="home-news-subtitle">
                    Nguồn dữ liệu:
                    <a href="<?= $block->escapeUrl($sourceUrl) ?>" target="_blank" rel="noopener noreferrer">
                        <?= $block->escapeHtml($sourceUrl) ?>
                    </a>
                </p>
            </div>
            <a href="<?= $block->escapeUrl($block->getUrl('news', ['_fragment' => $feedAnchor])) ?>"
               class="home-news-view-all">Xem thêm</a>
        </div>

        <?php if (!empty($items)): ?>
        <div class="home-news-carousel">
            <button type="button" class="home-news-nav home-news-nav-prev" aria-label="Tin trước">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
            </button>

            <div class="home-news-track-wrap">
                <div class="home-news-track">
                    <?php foreach ($items as $item): ?>
                    <article class="home-news-card">
                        <a href="<?= $block->escapeUrl($item['link'] ?? '#') ?>" target="_blank" rel="noopener noreferrer" class="home-news-card-image-link">
                            <?php if (!empty($item['image_url'])): ?>
                            <img class="home-news-card-image"
                                 src="<?= $block->escapeUrl($item['image_url']) ?>"
                                 alt="<?= $block->escapeHtmlAttr($item['title'] ?? '') ?>"
                                 loading="lazy"/>
                            <?php else: ?>
                            <div class="home-news-card-image home-news-card-image-placeholder">PeakGear</div>
                            <?php endif; ?>
                        </a>

                        <div class="home-news-card-body">
                            <h4 class="home-news-card-title">
                                <a href="<?= $block->escapeUrl($item['link'] ?? '#') ?>" target="_blank" rel="noopener noreferrer">
                                    <?= $block->escapeHtml($item['title'] ?? '') ?>
                                </a>
                            </h4>
                            <?php if (!empty($item['description'])): ?>
                            <p class="home-news-card-desc"><?= $block->escapeHtml($block->truncateText((string)$item['description'], 120)) ?></p>
                            <?php endif; ?>
                            <span class="home-news-card-date"><?= $block->escapeHtml($block->formatPubDate((string)($item['pub_date'] ?? ''))) ?></span>
                        </div>
                    </article>
                    <?php endforeach; ?>
                </div>
            </div>

            <button type="button" class="home-news-nav home-news-nav-next" aria-label="Tin sau">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </button>
        </div>
        <?php else: ?>
        <div class="home-news-empty">Chưa có dữ liệu tin tức. Hệ thống sẽ tự đồng bộ lại.</div>
        <?php endif; ?>
    </div>
</section>
