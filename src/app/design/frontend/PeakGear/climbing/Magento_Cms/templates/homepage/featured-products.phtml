<?php
/**
 * PeakGear Climbing Theme - Featured Products Section
 * Dynamic products loaded from Magento catalog database (newest products)
 *
 * @var \PeakGear\Catalog\Block\FeaturedProducts $block
 */

$products = $block->getFeaturedProducts(8);
?>

<section class="featured-products-section">
    <div class="featured-products-container">
        <!-- Section Header -->
        <div class="featured-header">
            <div class="featured-header-left">
                <h2 class="featured-badge">Sản Phẩm Nổi Bật</h2>
                <h3 class="featured-title">Được Yêu Thích Nhất</h3>
            </div>
            <a href="<?= $block->escapeUrl($block->getUrl('products')) ?>" class="featured-view-all">
                Xem tất cả sản phẩm
                <span class="featured-view-all-arrow">&rarr;</span>
            </a>
        </div>

        <!-- Products Grid -->
        <?php if (!empty($products)): ?>
        <div class="featured-grid">
            <?php foreach ($products as $index => $product): ?>
                <?php
                    $discount = $product['originalPrice']
                        ? round((1 - $product['price'] / $product['originalPrice']) * 100)
                        : 0;
                    $rating = $product['rating'];
                    $fullStars = floor($rating);
                    $hasHalfStar = ($rating - $fullStars) >= 0.3;
                    $emptyStars = 5 - $fullStars - ($hasHalfStar ? 1 : 0);
                ?>
                <div class="product-card hover-lift animate-fade-in-up" style="animation-delay: <?= 0.1 * ($index + 1) ?>s">
                    <!-- Sale Badge -->
                    <?php if ($discount > 0): ?>
                        <div class="product-sale-badge">-<?= $discount ?>%</div>
                    <?php endif; ?>

                    <!-- Image Container -->
                    <a href="<?= $block->escapeUrl($product['url']) ?>" class="product-image-container">
                        <?php if (!empty($product['imageUrl'])): ?>
                            <!-- Real Product Image from DB -->
                            <img src="<?= $block->escapeUrl($product['imageUrl']) ?>"
                                 alt="<?= $block->escapeHtmlAttr($product['name']) ?>"
                                 class="product-real-image"
                                 loading="lazy"
                                 width="300"
                                 height="300"/>
                        <?php else: ?>
                            <!-- Placeholder Pattern (when no image uploaded) -->
                            <div class="product-placeholder">
                                <div class="product-placeholder-circle">
                                    <span class="product-placeholder-initial"><?= $block->escapeHtml($block->getCategoryInitial($product['category'])) ?></span>
                                </div>
                            </div>
                        <?php endif; ?>

                        <!-- Quick Actions Overlay -->
                        <div class="product-quick-actions">
                            <button type="button" class="product-action-btn product-action-wishlist" title="Yêu thích">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                            </button>
                            <span class="product-action-btn product-action-view" title="Xem chi tiết">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                            </span>
                            <button type="button" class="product-action-btn product-action-cart" title="Thêm vào giỏ">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                            </button>
                        </div>
                    </a>

                    <!-- Content -->
                    <div class="product-content">
                        <!-- Category -->
                        <?php if (!empty($product['category'])): ?>
                        <span class="product-category-tag"><?= $block->escapeHtml($product['category']) ?></span>
                        <?php endif; ?>

                        <!-- Name -->
                        <h4 class="product-card-name">
                            <a href="<?= $block->escapeUrl($product['url']) ?>"><?= $block->escapeHtml($product['name']) ?></a>
                        </h4>

                        <!-- Rating -->
                        <?php if ($rating > 0): ?>
                        <div class="product-rating-row">
                            <div class="product-stars">
                                <?php for ($i = 0; $i < $fullStars; $i++): ?>
                                    <svg class="star star-filled" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                <?php endfor; ?>
                                <?php if ($hasHalfStar): ?>
                                    <svg class="star star-half" viewBox="0 0 24 24">
                                        <defs>
                                            <linearGradient id="half-star-<?= $index ?>">
                                                <stop offset="50%" stop-color="#fbbf24"/>
                                                <stop offset="50%" stop-color="#374151"/>
                                            </linearGradient>
                                        </defs>
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="url(#half-star-<?= $index ?>)"/>
                                    </svg>
                                <?php endif; ?>
                                <?php for ($i = 0; $i < $emptyStars; $i++): ?>
                                    <svg class="star star-empty" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                <?php endfor; ?>
                            </div>
                            <span class="product-rating-value"><?= number_format($product['rating'], 1) ?></span>
                            <span class="product-reviews-count">(<?= (int)$product['reviews'] ?>)</span>
                        </div>
                        <?php endif; ?>

                        <!-- Price -->
                        <div class="product-price-row">
                            <span class="product-current-price"><?= $block->formatPriceVnd($product['price']) ?></span>
                            <?php if ($product['originalPrice']): ?>
                                <span class="product-original-price"><?= $block->formatPriceVnd($product['originalPrice']) ?></span>
                            <?php endif; ?>
                        </div>
                    </div>

                    <!-- Bottom Accent Line -->
                    <div class="product-accent-line"></div>
                </div>
            <?php endforeach; ?>
        </div>
        <?php else: ?>
        <div class="featured-products-empty">
            <p>Hiện chưa có sản phẩm yêu thích để hiển thị vì admin chưa thêm sản phẩm vào shop.</p>
        </div>
        <?php endif; ?>
    </div>
</section>
