<script>
document.addEventListener('DOMContentLoaded', function () {
    var track = document.getElementById('featuredTrack');
    var prev = document.getElementById('featuredPrev');
    var next = document.getElementById('featuredNext');
    if (!track || !prev || !next) return;

    var cards = Array.prototype.slice.call(track.querySelectorAll('.product-card'));
    if (!cards.length) return;

    var currentIndex = 0;

    function normalizeIndex(index) {
        var length = cards.length;
        return ((index % length) + length) % length;
    }

    function scrollToIndex(index, behavior) {
        currentIndex = normalizeIndex(index);
        var target = cards[currentIndex];
        if (!target) return;
        track.scrollTo({ left: target.offsetLeft, behavior: behavior || 'smooth' });
    }

    function detectCurrentIndex() {
        var scrollLeft = track.scrollLeft;
        var closest = 0;
        var minDiff = Number.POSITIVE_INFINITY;
        cards.forEach(function (card, idx) {
            var diff = Math.abs(card.offsetLeft - scrollLeft);
            if (diff < minDiff) { minDiff = diff; closest = idx; }
        });
        currentIndex = closest;
    }

    prev.addEventListener('click', function () { scrollToIndex(currentIndex - 1, 'smooth'); });
    next.addEventListener('click', function () { scrollToIndex(currentIndex + 1, 'smooth'); });
    track.addEventListener('scroll', function () { window.requestAnimationFrame(detectCurrentIndex); });
    window.addEventListener('resize', function () { scrollToIndex(currentIndex, 'auto'); });
});
</script>

