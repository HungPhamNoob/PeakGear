<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Homepage Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    
    <body>
        <attribute name="class" value="cms-home"/>
        
        <!-- Hero Section -->
        <referenceContainer name="content">
            <block class="Vendor\Weather\Block\Weather" 
                   name="peakgear.hero" 
                   template="Magento_Cms::homepage/hero.phtml"
                   before="-"/>
            
            <!-- Features Section -->
            <block class="Magento\Framework\View\Element\Template" 
                   name="peakgear.features" 
                   template="Magento_Cms::homepage/features.phtml"
                   after="peakgear.hero"/>

            <!-- Flash Sale Section -->
            <block class="PeakGear\FlashSale\Block\Home\FlashSale"
                   name="peakgear.flashsale.home"
                   template="PeakGear_FlashSale::home/flash-sale.phtml"
                   after="peakgear.features"/>
            
            <!-- Categories Section (dynamic from DB) -->
            <block class="PeakGear\Catalog\Block\CategoryList" 
                   name="peakgear.categories" 
                   template="Magento_Cms::homepage/categories.phtml"
                   after="peakgear.flashsale.home"/>
            
            <!-- Featured Products (newest products from DB) -->
            <block class="PeakGear\Catalog\Block\FeaturedProducts" 
                   name="peakgear.featured.products" 
                   template="Magento_Cms::homepage/featured-products.phtml"
                   after="peakgear.categories"/>

            <!-- Home News Carousels -->
            <block class="Vendor\NewsRss\Block\News"
                   name="peakgear.home.news.travel"
                   template="Magento_Cms::homepage/news-carousel.phtml"
                   after="peakgear.featured.products">
                <arguments>
                    <argument name="feed_code" xsi:type="string">travel</argument>
                    <argument name="badge" xsi:type="string">VNExpress Du lịch</argument>
                    <argument name="title" xsi:type="string">Tin Tức Điểm Đến Mới Nhất</argument>
                    <argument name="source_url" xsi:type="string">https://vnexpress.net/du-lich/diem-den</argument>
                </arguments>
            </block>

            <block class="Vendor\NewsRss\Block\News"
                   name="peakgear.home.news.business"
                   template="Magento_Cms::homepage/news-carousel.phtml"
                   after="peakgear.home.news.travel">
                <arguments>
                    <argument name="feed_code" xsi:type="string">business</argument>
                    <argument name="badge" xsi:type="string">VNExpress Kinh doanh</argument>
                    <argument name="title" xsi:type="string">Bản Tin Kinh Doanh Mới Nhất</argument>
                    <argument name="source_url" xsi:type="string">https://vnexpress.net/rss/kinh-doanh.rss</argument>
                </arguments>
            </block>

            <!-- Brand logos strip -->
            <block class="Magento\Framework\View\Element\Template"
                   name="peakgear.home.brand.strip"
                   template="Magento_Cms::homepage/brand-strip.phtml"
                   after="peakgear.home.news.business"/>
        </referenceContainer>
        
        <!-- Remove default page title + CMS content block for homepage -->
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="cms_page" remove="true"/>
    </body>
</page>
