<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Checkout Page Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="checkout"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    
    <body>
        <attribute name="class" value="checkout-index-index"/>
        
        <!-- Custom Checkout Styles -->
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template" 
                   name="peakgear.checkout.wrapper" 
                   template="Magento_Checkout::checkout-wrapper.phtml"
                   before="-"/>
        </referenceContainer>
        
        <!-- Checkout Progress Bar -->
        <referenceBlock name="checkout.progress.wrapper">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Checkout::onepage/progress-bar.phtml</argument>
            </action>
        </referenceBlock>
    </body>
</page>
