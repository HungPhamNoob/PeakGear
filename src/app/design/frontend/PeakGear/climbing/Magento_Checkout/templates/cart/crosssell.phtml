<?php
/**
 * PeakGear Climbing Theme - Cross-sell Products
 *
 * @var \Magento\Checkout\Block\Cart\Crosssell $block
 */
$items = $block->getItems();
$viewModel = $block->getData('view_model');
?>

<?php if (count($items) > 0): ?>
<section class="crosssell-products-section">
    <div class="section-header">
        <h2 class="section-title">Gợi Ý Cho Bạn</h2>
    </div>

    <div class="products-grid">
        <?php foreach ($items as $product): ?>
            <?php
                $productUrl = $product->getProductUrl();
                $productName = $block->escapeHtml($product->getName());
                $productImage = $viewModel ? $viewModel->getImageUrl($product, 'cart_cross_sell_products') : '';
                $price = $viewModel ? $viewModel->formatPrice((float)$product->getFinalPrice()) : '';
            ?>
            <div class="product-card">
                <a href="<?= $block->escapeUrl($productUrl) ?>" class="product-image-wrapper">
                    <img src="<?= $block->escapeUrl($productImage) ?>"
                         alt="<?= $block->escapeHtmlAttr($productName) ?>"
                         class="product-image"
                         loading="lazy"/>
                </a>
                <div class="product-info">
                    <h3 class="product-name">
                        <a href="<?= $block->escapeUrl($productUrl) ?>"><?= /* @noEscape */ $productName ?></a>
                    </h3>
                    <div class="product-price">
                        <span class="price"><?= /* @noEscape */ $price ?></span>
                    </div>
                </div>
            </div>
        <?php endforeach; ?>
    </div>
</section>
<?php endif; ?>
