<div class="slides-container" data-role="slides-container">
  <div class="slides" data-role="slides">
    <div class="slide-template" style="display: none;">
      <div class="slide">
        <input type="hidden" name="parameters[slides][]" />
        <div class="slide-content">
          <div class="field">
            <label>Image</label>
            <input type="text" class="slide-image" />
            <button type="button" class="action-default browse">Browse</button>
          </div>
          <div class="field">
            <label>Title</label>
            <input type="text" class="slide-title" />
          </div>
          <div class="field">
            <label>Subtitle</label>
            <input type="text" class="slide-subtitle" />
          </div>
          <div class="field">
            <label>Button Text</label>
            <input type="text" class="slide-button-text" />
          </div>
          <div class="field">
            <label>Button URL</label>
            <input type="text" class="slide-button-url" />
          </div>
        </div>
        <button type="button" class="action-delete">Delete Slide</button>
      </div>
    </div>
  </div>
  <button type="button" class="action-add">Add Slide</button>
</div>