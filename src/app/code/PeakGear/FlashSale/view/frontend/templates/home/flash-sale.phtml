<?php if (!empty($saleGroups)): ?>
<script>
require(['jquery'], function ($) {
    'use strict';
    function pad(value) {
        return value < 10 ? '0' + value : String(value);
    }
    function tick() {
        $('.pg-flash-sale').each(function () {
            var $sale = $(this);
            var target = new Date($sale.data('countdown-to')).getTime();
            var diff = Math.max(0, target - Date.now());
            var days = Math.floor(diff / 86400000);
            var hours = Math.floor((diff % 86400000) / 3600000);
            var minutes = Math.floor((diff % 3600000) / 60000);
            var seconds = Math.floor((diff % 60000) / 1000);
            $sale.find('[data-countdown-days]').text(pad(days));
            $sale.find('[data-countdown-hours]').text(pad(hours));
            $sale.find('[data-countdown-minutes]').text(pad(minutes));
            $sale.find('[data-countdown-seconds]').text(pad(seconds));
        });
    }
    tick();
    window.setInterval(tick, 1000);
});
</script>
<script type="text/x-magento-init">
{
    "*": {
        "peakgearProductActions": {}
    }
}
</script>
