    .flashsale-product-result span { color: #666; font-size: 12px; }
</style>
<script>
require(['jquery', 'mage/calendar'], function ($) {
    'use strict';

    var searchUrl = '<?= $block->escapeJs($block->getUrl('peakgear_flashsale/product/search')) ?>';
    var searchTimer = null;

    $('.flashsale-datetime').calendar({
        showsTime: true,
        showTime: true,
        timeFormat: 'HH:mm',
        dateFormat: 'yy-mm-dd',
        ampm: false,
        showButtonPanel: true
    });

    function escapeHtml(value) {
        return $('<div/>').text(value || '').html();
    }

    function productCell(index) {
        return '<td class="flashsale-product-cell">' +
            '<input class="admin__control-text flashsale-product-search" type="search" autocomplete="off" placeholder="Tìm tên, SKU hoặc ID">' +
            '<input type="hidden" class="flashsale-product-value" name="items[' + index + '][product]">' +
            '<div class="flashsale-product-results" hidden></div>' +
            '</td>';
    }

    $('#add-flashsale-row').on('click', function () {
        var index = $('#flashsale-items tbody tr').length;
        var row = '<tr>' +
            productCell(index) +
            '<td><input class="admin__control-text" name="items[' + index + '][discount_percent]" type="number" step="0.01" min="0" max="100"></td>' +
            '<td><input class="admin__control-text" name="items[' + index + '][qty_limit]" type="number" min="0"></td>' +
            '<td><input class="admin__control-text" name="items[' + index + '][sold_qty]" type="number" min="0" value="0"></td>' +
            '<td><input class="admin__control-text" name="items[' + index + '][max_per_customer]" type="number" min="0"></td>' +
            '<td><input class="admin__control-text" name="items[' + index + '][max_per_order]" type="number" min="0"></td>' +
            '</tr>';
        $('#flashsale-items tbody').append(row);
    });

    $('#flashsale-items').on('input', '.flashsale-product-search', function () {
        var $input = $(this);
        var $cell = $input.closest('.flashsale-product-cell');
        var $results = $cell.find('.flashsale-product-results');
        var query = $.trim($input.val());

        $cell.find('.flashsale-product-value').val('');
        window.clearTimeout(searchTimer);

        if (query.length < 2) {
            $results.prop('hidden', true).empty();
            return;
        }

        searchTimer = window.setTimeout(function () {
            $.getJSON(searchUrl, {q: query}).done(function (response) {
                var items = response && response.items ? response.items : [];
                if (!items.length) {
                    $results.html('<div class="flashsale-product-result"><span>Không tìm thấy sản phẩm</span></div>').prop('hidden', false);
                    return;
                }

                $results.html(items.map(function (item) {
                    return '<div class="flashsale-product-result" data-id="' + item.id + '" data-label="' + escapeHtml(item.label) + '">' +
                        '<strong>' + escapeHtml(item.name) + '</strong>' +
                        '<span>#' + item.id + ' - ' + escapeHtml(item.sku) + '</span>' +
                        '</div>';
                }).join('')).prop('hidden', false);
            });
        }, 250);
    });

    $('#flashsale-items').on('click', '.flashsale-product-result[data-id]', function () {
        var $result = $(this);
        var $cell = $result.closest('.flashsale-product-cell');
        $cell.find('.flashsale-product-search').val($result.data('label'));
        $cell.find('.flashsale-product-value').val($result.data('id'));
        $cell.find('.flashsale-product-results').prop('hidden', true).empty();
    });

    $(document).on('click', function (event) {
        if (!$(event.target).closest('.flashsale-product-cell').length) {
            $('.flashsale-product-results').prop('hidden', true);
        }
    });
});
</script>
