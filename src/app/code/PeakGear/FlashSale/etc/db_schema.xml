<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="peakgear_flash_sale" resource="default" engine="innodb" comment="PeakGear Flash Sale">
        <column xsi:type="int" name="sale_id" unsigned="true" nullable="false" identity="true" comment="Sale ID"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Title"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="start_at" nullable="false" on_update="false" comment="Start At"/>
        <column xsi:type="timestamp" name="end_at" nullable="false" on_update="false" comment="End At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="sale_id"/>
        </constraint>
        <index referenceId="PEAKGEAR_FLASH_SALE_ACTIVE_TIME" indexType="btree">
            <column name="is_active"/>
            <column name="start_at"/>
            <column name="end_at"/>
        </index>
    </table>
    <table name="peakgear_flash_sale_item" resource="default" engine="innodb" comment="PeakGear Flash Sale Item">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" identity="true" comment="Item ID"/>
        <column xsi:type="int" name="sale_id" unsigned="true" nullable="false" comment="Sale ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="decimal" name="discount_percent" nullable="false" precision="5" scale="2" default="0" comment="Discount Percent"/>
        <column xsi:type="int" name="qty_limit" unsigned="true" nullable="false" default="0" comment="Quantity Limit"/>
        <column xsi:type="int" name="sold_qty" unsigned="true" nullable="false" default="0" comment="Sold Quantity"/>
        <column xsi:type="int" name="max_per_customer" unsigned="true" nullable="false" default="0" comment="Max Per Customer"/>
        <column xsi:type="int" name="max_per_order" unsigned="true" nullable="false" default="0" comment="Max Per Order"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PEAKGEAR_FLASH_SALE_ITEM_SALE_ID_PEAKGEAR_FLASH_SALE_SALE_ID"
                    table="peakgear_flash_sale_item" column="sale_id"
                    referenceTable="peakgear_flash_sale" referenceColumn="sale_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="PEAKGEAR_FLASH_SALE_ITEM_SALE_PRODUCT">
            <column name="sale_id"/>
            <column name="product_id"/>
        </constraint>
        <index referenceId="PEAKGEAR_FLASH_SALE_ITEM_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
    </table>
</schema>
