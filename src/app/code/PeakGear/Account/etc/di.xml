<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\OrderCancellation\Model\CancelOrder">
        <plugin name="peakgear_create_cancellation_request"
                type="PeakGear\Account\Plugin\OrderCancellation\CreateCancellationRequestPlugin"/>
    </type>
    <type name="Magento\OrderCancellation\Model\CustomerCanCancel">
        <plugin name="peakgear_prevent_duplicate_cancellation_request"
                type="PeakGear\Account\Plugin\OrderCancellation\PreventDuplicateRequestPlugin"/>
    </type>
</config>
