<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
    layout="1column">
    <head>
        <title>Tin tức</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="sidebar.main" remove="true"/>
        <referenceBlock name="catalog.compare.sidebar" remove="true"/>
        <referenceBlock name="wishlist_sidebar" remove="true"/>
        <referenceContainer name="content">
            <block class="Vendor\NewsRss\Block\News"
                   name="vendor.news.main"
                   template="Vendor_NewsRss::news.phtml">
                <block class="Vendor\NewsRss\Block\News"
                       name="vendor.news.travel"
                       as="travel_news"
                       template="Vendor_NewsRss::partials/news-grid.phtml">
                    <arguments>
                        <argument name="feed_code" xsi:type="string">travel</argument>
                        <argument name="title" xsi:type="string">Tin tức Điểm đến</argument>
                        <argument name="subtitle" xsi:type="string">Cập nhật tự động từ VNExpress Du lịch - Điểm đến.</argument>
                    </arguments>
                </block>
                <block class="Vendor\NewsRss\Block\News"
                       name="vendor.news.business"
                       as="business_news"
                       template="Vendor_NewsRss::partials/news-grid.phtml">
                    <arguments>
                        <argument name="feed_code" xsi:type="string">business</argument>
                        <argument name="title" xsi:type="string">Bản tin Kinh doanh</argument>
                        <argument name="subtitle" xsi:type="string">Cập nhật tự động từ RSS VNExpress Kinh doanh.</argument>
                    </arguments>
                </block>
                <block class="Vendor\Weather\Block\Weather"
                       name="vendor.news.weather.widget"
                       as="weather_widget"
                       template="Vendor_Weather::partials/news-widget.phtml"/>
                <block class="Vendor\CurrencyRate\Block\CurrencyRate"
                       name="vendor.news.currency.widget"
                       as="currency_widget"
                       template="Vendor_CurrencyRate::partials/news-widget.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
