<?php
/** @var \Vendor\NewsRss\Block\News $block */
$items = $block->getNewsItems(16);
usort($items, static fn(array $a, array $b): int => strtotime((string)($b['pub_date'] ?? '')) <=> strtotime((string)($a['pub_date'] ?? '')));
?>

<section class="news-feed-group">
    <header class="news-page-header">
        <?php if ($block->getFeedCode() === 'travel'): ?>
        <h1 class="news-page-title"><?= $block->escapeHtml((string)$block->getData('title')) ?></h1>
        <?php else: ?>
        <h2 class="news-page-title"><?= $block->escapeHtml((string)$block->getData('title')) ?></h2>
        <?php endif; ?>
        <p class="news-page-subtitle"><?= $block->escapeHtml((string)$block->getData('subtitle')) ?></p>
    </header>

    <?php if (!empty($items)): ?>
    <div class="news-page-grid">
        <?php foreach ($items as $item): ?>
        <article class="news-page-card">
            <a href="<?= $block->escapeUrl($item['link'] ?? '#') ?>" target="_blank" rel="noopener noreferrer" class="news-page-card-image-link">
                <?php if (!empty($item['image_url'])): ?>
                <img class="news-page-card-image"
                     src="<?= $block->escapeUrl($item['image_url']) ?>"
                     alt="<?= $block->escapeHtmlAttr($item['title'] ?? '') ?>"
                     loading="lazy"/>
                <?php else: ?>
                <div class="news-page-card-image news-page-card-image-placeholder">PeakGear</div>
                <?php endif; ?>
            </a>
            <div class="news-page-card-content">
                <h3 class="news-page-card-title">
                    <a href="<?= $block->escapeUrl($item['link'] ?? '#') ?>" target="_blank" rel="noopener noreferrer">
                        <?= $block->escapeHtml($item['title'] ?? '') ?>
                    </a>
                </h3>
                <?php if (!empty($item['description'])): ?>
                <p class="news-page-card-desc"><?= $block->escapeHtml($block->truncateText((string)$item['description'], 160)) ?></p>
                <?php endif; ?>
                <div class="news-page-card-meta">
                    <span><?= $block->escapeHtml($block->formatPubDate((string)($item['pub_date'] ?? ''))) ?></span>
                    <a href="<?= $block->escapeUrl($item['link'] ?? '#') ?>" target="_blank" rel="noopener noreferrer">Đọc tiếp</a>
                </div>
            </div>
        </article>
        <?php endforeach; ?>
    </div>
    <?php else: ?>
    <div class="news-page-empty">Chưa có dữ liệu tin tức. Hệ thống sẽ tự động cập nhật lại.</div>
    <?php endif; ?>
</section>
