<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="vendor_currency_rate_cache" resource="default" engine="innodb" comment="Vendor Currency Rate Cache Table">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="currency_code" nullable="false" length="10" comment="Currency Code"/>
        <column xsi:type="varchar" name="currency_name" nullable="true" length="100" comment="Currency Name"/>
        <column xsi:type="decimal" name="buy_transfer" nullable="true" precision="15" scale="2" comment="Buy Transfer Rate"/>
        <column xsi:type="decimal" name="buy_cash" nullable="true" precision="15" scale="2" comment="Buy Cash Rate"/>
        <column xsi:type="decimal" name="sell" nullable="true" precision="15" scale="2" comment="Sell Rate"/>
        <column xsi:type="timestamp" name="cached_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Cache Timestamp"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="VENDOR_CURRENCY_RATE_CACHE_CURRENCY_CODE">
            <column name="currency_code"/>
        </constraint>
        <index referenceId="VENDOR_CURRENCY_RATE_CACHE_CACHED_AT" indexType="btree">
            <column name="cached_at"/>
        </index>
    </table>
</schema>
