<script>
require([
    'jquery',
    'Magento_Ui/js/modal/modal'
], function ($, modal) {
    var originalEmail = '<?= $block->escapeJs($email) ?>';

    var options = {
        type: 'popup',
        responsive: true,
        innerScroll: true,
        title: 'Yêu cầu mật khẩu',
        buttons: [{
            text: $.mage.__('Xác nhận thay đổi'),
            class: 'action primary',
            click: function () {
                var pwd = $('#modal-current-password').val();
                if (!pwd) {
                    $('#modal-password-error').show();
                    return;
                }
                
                $('#modal-password-error').hide();
                $('#current-password').val(pwd);
                $('#change-email-input').val('1'); 
                
                // Submit form directly skipping jquery intercept hook sequence
                $('#form-validate').off('submit').submit();
            }
        }]
    };

    var popup = modal(options, $('#password-modal'));
    
    $('#form-validate').on('submit', function(e) {
        // Prevent if form is not valid
        if (!$(this).valid()) {
            return false;
        }

        var newEmail = $('#email').val();
        if (newEmail && newEmail !== originalEmail) {
            e.preventDefault();
            $('#modal-current-password').val('');
            $('#modal-password-error').hide();
            $('#password-modal').modal('openModal');
            return false;
        } else {
            $('#change-email-input').val('0');
        }
    });

    $('#modal-current-password').on('keypress', function(e) {
        if (e.which === 13) {
            e.preventDefault();
            $('.modal-popup .action.primary').click();
        }
    });
});
</script>
