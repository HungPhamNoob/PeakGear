<?php
/**
 * PeakGear Climbing Theme - Proceed to Checkout
 * Guest users see a "Đăng nhập để thanh toán" button
 * Logged-in users see "Tiến hành thanh toán" button
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$viewModel = $block->getData('view_model');
$isLoggedIn = $viewModel ? $viewModel->isLoggedIn() : false;
$loginUrl = $block->getUrl('customer/account/login', ['referer' => base64_encode($block->getUrl('checkout'))]);
$checkoutUrl = $block->getUrl('checkout');
?>

<div class="cart-proceed">
    <?php if ($isLoggedIn): ?>
        <button type="button"
                class="btn btn-primary btn-lg btn-block"
                data-role="proceed-to-checkout"
                title="<?= $block->escapeHtmlAttr(__('Tiến hành thanh toán')) ?>"
                onclick="window.location='<?= $block->escapeUrl($checkoutUrl) ?>'">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <rect width="20" height="14" x="2" y="5" rx="2"/>
                <line x1="2" x2="22" y1="10" y2="10"/>
            </svg>
            Tiến Hành Thanh Toán
        </button>
    <?php else: ?>
        <div class="cart-login-notice">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" x2="12" y1="8" y2="12"/>
                <line x1="12" x2="12.01" y1="16" y2="16"/>
            </svg>
            <span>Bạn cần đăng nhập để tiến hành thanh toán</span>
        </div>
        <a href="<?= $block->escapeUrl($loginUrl) ?>"
           class="btn btn-primary btn-lg btn-block">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" x2="3" y1="12" y2="12"/>
            </svg>
            Đăng Nhập Để Thanh Toán
        </a>
        <a href="<?= $block->escapeUrl($block->getUrl('customer/account/create')) ?>"
           class="btn btn-outline btn-lg btn-block cart-register-btn">
            Chưa có tài khoản? Đăng ký ngay
        </a>
    <?php endif; ?>

    <!-- Continue Shopping -->
    <a href="<?= $block->escapeUrl($block->getUrl('products')) ?>" class="btn btn-outline btn-lg btn-block cart-continue-btn">
        Tiếp Tục Mua Sắm
    </a>

    <!-- Trust Badges -->
    <div class="cart-trust-badges">
        <div class="trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Thanh toán an toàn</span>
        </div>
        <div class="trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span>Bảo mật thông tin</span>
        </div>
        <div class="trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <polyline points="23 4 23 10 17 10"/>
                <polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
