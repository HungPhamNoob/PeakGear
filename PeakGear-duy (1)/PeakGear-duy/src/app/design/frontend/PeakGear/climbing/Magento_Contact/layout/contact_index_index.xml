<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Contact Page Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <head>
        <title>Liên hệ PeakGear - Hỗ trợ nhanh chóng</title>
        <meta name="description" content="Liên hệ PeakGear để được tư vấn sản phẩm leo núi, trekking và camping nhanh chóng."/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Contact\Block\ContactForm"
                   name="peakgear.contact.form"
                   template="Magento_Contact::form.phtml"
                   before="-"/>
        </referenceContainer>
        <referenceBlock name="contactForm" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>
    </body>
</page>
