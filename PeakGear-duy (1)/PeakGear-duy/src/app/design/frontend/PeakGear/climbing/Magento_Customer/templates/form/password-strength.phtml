<?php
/**
 * PeakGear Climbing Theme - Password Strength Indicator
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
?>

<div class="password-strength-meter" id="password-strength-meter" style="display:none;">
    <div class="password-strength-bar">
        <div class="password-strength-fill" id="password-strength-fill"></div>
    </div>
    <span class="password-strength-text" id="password-strength-text"></span>
</div>

<script>
require(['jquery'], function($) {
    'use strict';
    var passwordInput = $('#password');
    var meter = $('#password-strength-meter');
    var fill = $('#password-strength-fill');
    var text = $('#password-strength-text');

    passwordInput.on('keyup', function() {
        var value = $(this).val();
        if (value.length === 0) {
            meter.hide();
            return;
        }
        meter.show();

        var strength = 0;
        if (value.length >= 8) strength++;
        if (/[A-Z]/.test(value)) strength++;
        if (/[0-9]/.test(value)) strength++;
        if (/[^A-Za-z0-9]/.test(value)) strength++;

        var labels = ['Yếu', 'Trung bình', 'Khá', 'Mạnh'];
        var colors = ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
        var widths = ['25%', '50%', '75%', '100%'];

        var idx = Math.max(0, strength - 1);
        fill.css({width: widths[idx], background: colors[idx]});
        text.text(labels[idx]).css('color', colors[idx]);
    });
});
</script>
