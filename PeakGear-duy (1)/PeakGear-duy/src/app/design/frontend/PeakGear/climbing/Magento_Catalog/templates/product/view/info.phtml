<?php
/**
 * PeakGear Climbing Theme - Product View Info
 * Renders: breadcrumb, category badge, product name, rating, price, description, stock, qty, cart, wishlist, trust badges
 * Matches React PDP right column exactly
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
$product = $block->getProduct();

// Get category info
$categoryCollection = $product->getCategoryCollection();
$category = $categoryCollection->getFirstItem();
$categoryName = ($category && $category->getId()) ? $category->getName() : '';
$categoryUrl = ($category && $category->getId())
    ? $block->getUrl('products', ['_query' => ['category' => $category->getId()]])
    : '';

// Rating data (use reviews if available, otherwise defaults)
$reviewCount = 0;
$ratingSummary = 0;
try {
    $reviewSummary = $product->getRatingSummary();
    if ($reviewSummary) {
        $ratingSummary = $reviewSummary->getRatingSummary() ?: 0;
        $reviewCount = $reviewSummary->getReviewsCount() ?: 0;
    }
} catch (\Exception $e) {
    // No reviews available
}
$ratingStars = $ratingSummary ? round($ratingSummary / 20, 1) : 0;

// Stock status
$stockStatus = $product->isAvailable();
?>

<!-- Breadcrumb -->
<div class="pdp-breadcrumb">
    <nav class="pdp-breadcrumb-nav">
        <a href="<?= $block->escapeUrl($block->getBaseUrl()) ?>" class="pdp-breadcrumb-link">Trang chủ</a>
        <svg class="pdp-breadcrumb-separator" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <?php if ($categoryName): ?>
            <a href="<?= $block->escapeUrl($categoryUrl) ?>" class="pdp-breadcrumb-link"><?= $block->escapeHtml($categoryName) ?></a>
            <svg class="pdp-breadcrumb-separator" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <?php endif; ?>
        <span class="pdp-breadcrumb-current"><?= $block->escapeHtml($product->getName()) ?></span>
    </nav>
</div>
