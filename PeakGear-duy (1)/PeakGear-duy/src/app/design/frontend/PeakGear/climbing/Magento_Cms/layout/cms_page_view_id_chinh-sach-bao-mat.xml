<?xml version="1.0"?>
<!--
/**
 * PeakGear Climbing Theme - Privacy Policy Page Layout
 *
 * CMS Page layout handle: set URL key "chinh-sach-bao-mat".
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <head>
        <title>Chính sách bảo mật - PeakGear</title>
        <meta name="description" content="Chính sách bảo mật thông tin khách hàng của PeakGear."/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="legal.privacy"
                   template="Magento_Cms::legal/privacy.phtml"
                   before="-"/>
        </referenceContainer>
        <referenceBlock name="cms_page" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>
    </body>
</page>
