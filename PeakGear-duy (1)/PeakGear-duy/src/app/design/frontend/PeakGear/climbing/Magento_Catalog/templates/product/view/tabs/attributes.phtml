<?php
/**
 * PeakGear Climbing Theme - Product Attributes Tab
 *
 * @var \Magento\Catalog\Block\Product\View\Attributes $block
 */
$product = $block->getProduct();
$additionalData = $block->getAdditionalData();
?>

<?php if ($additionalData): ?>
<div class="product-tab-attributes" id="tab-attributes">
    <h3 class="product-tab-title">Thông Số Kỹ Thuật</h3>
    <div class="product-tab-content">
        <table class="product-attributes-table">
            <tbody>
                <?php foreach ($additionalData as $data): ?>
                    <tr>
                        <th class="attribute-label"><?= $block->escapeHtml($data['label']) ?></th>
                        <td class="attribute-value"><?= /* @noEscape */ $data['value'] ?></td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
</div>
<?php endif; ?>
