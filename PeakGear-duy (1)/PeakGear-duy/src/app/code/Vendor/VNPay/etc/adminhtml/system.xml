<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="vnpay" translate="label" type="text" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>VNPay</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1">
                    <label>Title</label>
                </field>
                <field id="tmn_code" translate="label" type="text" sortOrder="30" showInDefault="1">
                    <label>TMN Code (Terminal ID)</label>
                    <validate>required-entry</validate>
                </field>
                <field id="hash_secret" translate="label" type="obscure" sortOrder="40" showInDefault="1">
                    <label>Hash Secret Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <validate>required-entry</validate>
                </field>
                <field id="vnp_url" translate="label" type="text" sortOrder="50" showInDefault="1">
                    <label>VNPay Payment URL</label>
                    <comment>Sandbox: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html</comment>
                    <validate>required-entry validate-url</validate>
                </field>
                <field id="sandbox" translate="label" type="select" sortOrder="60" showInDefault="1">
                    <label>Sandbox Mode</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="bank_code" translate="label" type="text" sortOrder="70" showInDefault="1">
                    <label>Preferred Bank Code</label>
                    <comment>Optional. Leave empty to let the customer choose inside VNPay.</comment>
                </field>
                <field id="instructions" translate="label" type="textarea" sortOrder="80" showInDefault="1" showInWebsite="1">
                    <label>Instructions</label>
                </field>
            </group>
        </section>
    </system>
</config>
